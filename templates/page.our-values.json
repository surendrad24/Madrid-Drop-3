    },
    "or_image_text_qwVJUp": {
      "type": "or-image-text",
      "blocks": {
        "heading_WhY6WR": {
          "type": "heading",
          "settings": {
            "heading": "Sustainable Practices //"
          }
        },
        "richtext_DjLrER": {
          "type": "richtext",
          "settings": {
            "content": "<p>Phoria is committed to reducing our ecological footprint. We’ll always strive to minimize waste and utilise eco-friendly packaging as much as we can. From carefully selected family-run workshops to responsibly sourcing materials, we want to make sure every part of our journey is respectful to the environment and the people involved.</p>"
          }
        },
        "richtext_CjRQ3t": {
          "type": "richtext",
          "settings": {
            "content": "<p>Our two suppliers have these sustainability initiatives in place:</p>"
          }
        },
        "richtext_FmpGyB": {
          "type": "richtext",
          "settings": {
            "content": "<p>– Workplace Compliance Audited<br/>– Responsible Jewellery Council Code of Practice Certified (Since 2018)<br/>– ISO 9001 Quality Management Systems Certified<br/>– United Nations Global Compact Member<br/>– United Nations Women’s Empowerment Principles Signatory<br/>– 2% of energy is sourced from Renewable Energy sources<br/>– 9% of water used is recycled</p>"
          }
        }
      },
      "block_order": [
        "heading_WhY6WR",
        "richtext_DjLrER",
        "richtext_CjRQ3t",
        "richtext_FmpGyB"
      ],
      "name": "Or-Image-text",
      "settings": {
        "media_position": "right",
