      }
    },
    "or_image_text_Uz7KMx": {
      "type": "or-image-text",
      "blocks": {
        "heading_6rH9ey": {
          "type": "heading",
          "settings": {
            "heading": "Supporting Communities //"
          }
        },
        "richtext_dPzcRP": {
          "type": "richtext",
          "settings": {
            "content": "<p>Our two suppliers are family-run workshops in Thailand, who we want to support by enabling them to thrive. These workshops are the backbone of their communities, providing employment opportunities and preserving traditional craftsmanship, which we love. Charlotte – our founder, grew up in South East Asia so supporting these communities is close to her heart.</p>"
          }
        }
      },
