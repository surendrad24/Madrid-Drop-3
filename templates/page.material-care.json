    "or_image_text_dCRVCV": {
      "type": "or-image-text",
      "blocks": {
        "heading_6eL8j9": {
          "type": "heading",
          "settings": {
            "heading": "Anti-Tarnish Layer //"
          }
        },
        "richtext_tkfMgW": {
          "type": "richtext",
          "settings": {
            "content": "<p>An anti-tarnish coating is applied to all Phoria jewellery to protect it from tarnishing and to help maintain its appearance over time. Tarnishing can naturally happen to all jewellery, it’s a process that occurs when certain metals, such as silver react with elements in the environment, such as oxygen and sulfur compounds.</p>"
          }
        }
      },
      "block_order": [
        "heading_6eL8j9",
        "richtext_tkfMgW"
      ],
      "name": "Or-Image-text",
      "settings": {
        "media_position": "left",
