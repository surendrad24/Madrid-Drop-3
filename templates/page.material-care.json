    "or_image_text_BNUDgF": {
      "type": "or-image-text",
      "blocks": {
        "heading_7WdDte": {
          "type": "heading",
          "settings": {
            "heading": "Care + Cleaning Gemstones //"
          }
        },
        "richtext_6xktBC": {
          "type": "richtext",
          "settings": {
            "content": "<p>We recommend keeping any Phoria Jewellery with gemstones out of direct sunlight as prolonged exposure can cause many gemstones to fade and lose their color. Take care with your gemstones to ensure that they do not knock against one another when stored.</p>"
          }
        },
        "richtext_xB7D39": {
          "type": "richtext",
          "settings": {
            "content": "<p>You shouldn’t leave your jewellery immersed in water for too long. Liquids and oils can seep into the gems through the tiny cracks between the crystals, causing permanent discoloration and damage.</p>"
          }
        }
      },
      "block_order": [
