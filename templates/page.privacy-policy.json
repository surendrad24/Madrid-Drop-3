    "ph_heading_text_Dg8VUN": {
      "type": "ph-heading-text",
      "blocks": {
        "richtext_ibnrdb": {
          "type": "richtext",
          "settings": {
            "content": "<p>PHORIA USES COOKIES TO:</p><ul><li>ENABLE ESSENTIAL WEBSITE FUNCTIONALITY</li><li>IMPROVE USER EXPERIENCE</li><li>ANALYSE WEBSITE PERFORMANCE</li><li>DELIVER MARKETING (WHERE CONSENTED)</li></ul><p>TYPES OF COOKIES:</p><ul><li>ESSENTIAL</li><li>PERFORMANCE</li><li>ANALYTICS</li><li>MARKETING</li></ul><p>NON-ESSENTIAL COOKIES ARE DEPLOYED ONLY WITH USER CONSENT.</p><p>YOU MAY MANAGE COOKIES THROUGH YOUR BROWSER SETTINGS OR OUR COOKIE BANNER.</p>"
          }
        }
      },
      "block_order": [
        "richtext_ibnrdb"
      ],
      "settings": {
        "title": "COOKIES + TRACKING TECHNOLOGIES",
        "bg_color": "#ffffff",
