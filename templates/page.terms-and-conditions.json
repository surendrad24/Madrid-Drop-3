    "ph_heading_text_MkNdqY": {
      "type": "ph-heading-text",
      "blocks": {
        "richtext_ywUAiP": {
          "type": "richtext",
          "settings": {
            "content": "<p>YOUR PRIVACY IS IMPORTANT TO US.</p><p>PHORIA JEWELLERY LTD COMPLIES WITH:</p><ul><li>UK GENERAL DATA PROTECTION REGULATION (UK GDPR)</li><li>DATA PROTECTION ACT 2018</li><li>PRIVACY AND ELECTRONIC COMMUNICATIONS REGULATIONS (PECR)</li><li>APPLICABLE ICO GUIDANCE (AS UPDATED FOR 2026)</li></ul>"
          }
        }
      },
      "block_order": [
        "richtext_ywUAiP"
      ],
      "settings": {
        "title": "PRIVACY, DATA PROTECTION + GDPR COMPLIANCE",
        "bg_color": "#ffffff",
        "text_color": "#000000",
        "enable_animations": true
      }
    },
    "ph_heading_text_4LwA8t": {
      "type": "ph-heading-text",
      "blocks": {
        "richtext_c3NVTa": {
          "type": "richtext",
          "settings": {
            "content": "<p>WE MAY COLLECT:</p><ul><li>NAME, EMAIL ADDRESS, TELEPHONE NUMBER</li><li>SHIPPING AND BILLING ADDRESS</li><li>ORDER AND TRANSACTION HISTORY</li><li>PAYMENT INFORMATION (PROCESSED SECURELY BY THIRD-PARTY PROVIDERS)</li><li>WEBSITE USAGE DATA, COOKIES AND ANALYTICS DATA</li><li>MARKETING PREFERENCES</li><li>EMAIL/SMS CONSENT RECORDS (INCLUDING DATE, TIME, SOURCE AND METHOD OF OPT-IN)</li></ul><p>WE DO NOT STORE FULL CARD DETAILS.</p>"
          }
        }
      },
      "block_order": [
        "richtext_c3NVTa"
      ],
      "settings": {
        "title": "WHAT DATA WE COLLECT",
        "bg_color": "#ffffff",
        "text_color": "#000000",
        "enable_animations": true
      }
    },
    "ph_heading_text_hejNXe": {
      "type": "ph-heading-text",
      "blocks": {
        "richtext_JrkaMc": {
          "type": "richtext",
          "settings": {
            "content": "<p>WE PROCESS PERSONAL DATA FOR THE FOLLOWING PURPOSES:</p><ul><li>ORDER FULFILMENT</li><li>CUSTOMER SERVICE</li><li>FRAUD PREVENTION AND RISK MANAGEMENT</li><li>WEBSITE SECURITY</li><li>ANALYTICS AND PERFORMANCE IMPROVEMENT</li><li>ACCOUNT MANAGEMENT</li><li>LEGAL AND REGULATORY COMPLIANCE</li><li>EMAIL AND SMS MARKETING (ONLY WHERE A VALID LEGAL BASIS EXISTS)</li></ul>"
          }
        }
      },
      "block_order": [
        "richtext_JrkaMc"
      ],
      "settings": {
        "title": "HOW WE USE YOUR DATA",
        "bg_color": "#ffffff",
        "text_color": "#000000",
        "enable_animations": true
      }
    },
    "ph_heading_text_GURzPV": {
      "type": "ph-heading-text",
      "blocks": {
        "richtext_jCfD3c": {
          "type": "richtext",
          "settings": {
            "content": "<p>WE RELY ON:</p><ul><li>CONTRACT (TO FULFIL ORDERS)</li><li>CONSENT (FOR EMAIL/SMS MARKETING AND NON-ESSENTIAL COOKIES)</li><li>LEGITIMATE INTEREST (FRAUD PREVENTION, SECURITY, ANALYTICS)</li><li>LEGAL OBLIGATION (ACCOUNTING, TAX, REGULATORY REQUIREMENTS)</li></ul><p>WE DO NOT SEND ELECTRONIC MARKETING WITHOUT A VALID LEGAL BASIS UNDER UK GDPR AND PECR.</p>"
          }
        }
      },
      "block_order": [
        "richtext_jCfD3c"
      ],
      "settings": {
        "title": "LAWFUL BASES FOR PROCESSING",
        "bg_color": "#ffffff",
        "text_color": "#000000",
        "enable_animations": true
      }
    },
    "ph_heading_text_wX7Y6m": {
      "type": "ph-heading-text",
      "blocks": {
        "richtext_6QWrGQ": {
          "type": "richtext",
          "settings": {
            "content": "<p>UNDER UK GDPR YOU HAVE THE RIGHT TO:</p><ul><li>ACCESS YOUR PERSONAL DATA</li><li>REQUEST CORRECTION OF INACCURATE DATA</li><li>REQUEST ERASURE (“RIGHT TO BE FORGOTTEN”)</li><li>RESTRICT OR OBJECT TO PROCESSING</li><li>WITHDRAW CONSENT AT ANY TIME</li><li>REQUEST DATA PORTABILITY</li><li>LODGE A COMPLAINT WITH THE INFORMATION COMMISSIONER’S OFFICE (ICO)</li></ul><p>TO EXERCISE YOUR RIGHTS, CONTACT: INFO@PHORIAJEWELLERY.COM</p>"
          }
        }
      },
      "block_order": [
        "richtext_6QWrGQ"
      ],
      "settings": {
        "title": "YOUR LEGAL RIGHTS",
        "bg_color": "#ffffff",
        "text_color": "#000000",
        "enable_animations": true
      }
    },
