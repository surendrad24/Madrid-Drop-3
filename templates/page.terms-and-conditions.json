      "type": "ph-heading-text",
      "blocks": {
        "richtext_ibnrdb": {
          "type": "richtext",
          "settings": {
            "content": "<p>WE SEND MARKETING COMMUNICATIONS ONLY WHERE:</p><ul><li>YOU HAVE PROVIDED CLEAR, INFORMED, FREELY GIVEN AND UNAMBIGUOUS CONSENT; OR</li><li>YOU QUALIFY FOR “SOFT OPT-IN” UNDER PECR</li></ul><p>YOU MAY WITHDRAW CONSENT AT ANY TIME BY:</p><ul><li>CLICKING THE UNSUBSCRIBE LINK IN EMAILS</li><li>TEXTING STOP TO OUR SMS NUMBER</li><li>CONTACTING US DIRECTLY</li></ul><p>UNSUBSCRIBE REQUESTS ARE PROCESSED PROMPTLY.</p><p>CONSENT FOR EMAIL AND SMS IS RECORDED AND STORED FOR COMPLIANCE PURPOSES.</p>"
          }
        }
      },
      "block_order": [
        "richtext_ibnrdb"
      ],
      "settings": {
        "title": "MARKETING - EMAIL + SMS",
        "bg_color": "#ffffff",
