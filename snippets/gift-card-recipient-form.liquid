{% comment %}
  Renders gift card recipient form.
  Accepts:
  - product: {Object} product object.
  - form: {Object} the product form object.
  - section: {Object} section to which this snippet belongs.

  Usage:
  {% render 'gift-card-recipient-form', product: product, form: form, section: section %}
{% endcomment %}

<div class="customer">
  {%- assign gift_card_recipient_control_flag = 'properties[__shopify_send_gift_card_to_recipient]' -%}
  <script src="{{ 'recipient-form.js' | asset_url }}" defer="defer"></script>
  <style>
    /* Ensure all placeholder text is 10px */
    .recipient-form input::placeholder,
    .recipient-form textarea::placeholder {
      font-size: 10px !important;
    }
  </style>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const checkbox = document.getElementById('Recipient-checkbox-{{ section.id }}');
      const recipientFields = document.querySelector('[data-section-id="{{ section.id }}"] .recipient-fields');
      
      if (checkbox && recipientFields) {
        checkbox.addEventListener('change', function() {
          if (this.checked) {
            recipientFields.style.display = 'block';
          } else {
            recipientFields.style.display = 'none';
            // Clear form fields when hiding
            const inputs = recipientFields.querySelectorAll('input, textarea');
            inputs.forEach(input => {
              if (input.type !== 'hidden') {
                input.value = '';
              }
            });
          }
        });
      }
    });
  </script>
  <recipient-form
    class="recipient-form"
    data-section-id="{{ section.id }}"
    data-product-variant-id="{{ product.selected_or_first_available_variant.id }}"
  >
    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 18px;">
      <input
        id="Recipient-checkbox-{{ section.id }}"
        type="checkbox"
        name="{{ gift_card_recipient_control_flag }}"
      >
      <label class="recipient-checkbox" for="Recipient-checkbox-{{ section.id }}">
        <svg
          class="icon icon-checkmark"
          width="8"
          height="7"
          viewBox="0 0 8 7"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path d="M1 3.5L3 5.5L7 1.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>{{ 'recipient.form.checkbox' | t }}</span>
      </label>
    </div>
    <div class="recipient-fields" style="display: none;">
      <hr>
      <div class="recipient-fields__field">
        <div class="field">
          <input
            class="field__input"
            id="Recipient-email-{{ section.id }}"
            type="email"
            placeholder="ENTER GIFT CARD RECIPIENT EMAIL"
            name="properties[Recipient email]"
            value="{{ form.email }}"
            pattern="[a-z0-9._%+\-]+@[a-z0-9.\-]+\.[a-z]{2,}$"
            style="margin: 9px 0px 0px; padding: 10px 15px; text-transform: uppercase; font-family: 'PhoriaRegular'; font-size: 10px; border: 1px solid #1d1d1d;"
            {% if form.errors contains 'email' %}
              aria-invalid="true"
              aria-describedby="RecipientForm-email-error-{{ section.id }}"
            {% endif %}
          >
          <label class="field__label" for="Recipient-email-{{ section.id }}" style="font-family: 'PhoriaBold'; font-size: 10px;">
            TO *
          </label>
        </div>

        <div
          id="RecipientForm-email-error-{{ section.id }}"
          class="form__message{% unless form.errors contains 'email' %} hidden{% endunless %}"
        >
          <span class="error-message">
            {%- if form.errors contains 'email' -%}
              {{ form.errors.messages.email }}.
            {%- endif -%}
          </span>
        </div>
      </div>

      <div class="recipient-fields__field">
        <div class="field">
          <input
            class="field__input"
            autocomplete="name"
            type="text"
            id="Recipient-name-{{ section.id }}"
            name="properties[Recipient name]"
            placeholder="ENTER YOUR NAME"
            value="{{ form.name }}"
            style="margin: 9px 0px 0px; padding: 10px 15px; text-transform: uppercase; font-family: 'PhoriaRegular'; font-size: 10px; border: 1px solid #1d1d1d;"
            {% if form.errors contains 'name' %}
              aria-invalid="true"
              aria-describedby="RecipientForm-name-error-{{ section.id }}"
            {% endif %}
          >
          <label class="field__label" for="Recipient-name-{{ section.id }}" style="font-family: 'PhoriaBold'; font-size: 10px;">
            FROM *
          </label>
        </div>

        <div
          id="RecipientForm-name-error-{{ section.id }}"
          class="form__message{% unless form.errors contains 'name' %} hidden{% endunless %}"
        >
          <span class="error-message">
            {%- if form.errors contains 'name' -%}
              {{ form.errors.messages.name }}.
            {%- endif -%}
          </span>
        </div>
      </div>

      <div class="recipient-fields__field">
        {%- assign max_chars_message = 200 -%}
        {%- assign max_chars_message_rendered = 'recipient.form.max_characters' | t: max_chars: max_chars_message -%}
        {%- assign message_label_rendered = 'Message' -%}
        <div class="field">
          <textarea
            rows="10"
            id="Recipient-message-{{ section.id }}"
            class="text-area field__input"
            name="properties[Message]"
            maxlength="{{ max_chars_message }}"
            placeholder="ADD YOUR MESSAGE (OPTIONAL)"
            aria-label="{{ message_label_rendered }} {{ max_chars_message_rendered }}"
            style="margin: 9px 0px 0px; padding: 10px 15px; text-transform: uppercase; resize: vertical; font-family: 'PhoriaRegular'; font-size: 10px; border: 1px solid #1d1d1d;"
            {% if form.errors contains 'message' %}
              aria-invalid="true"
              aria-describedby="RecipientForm-message-error-{{ section.id }}"
            {% endif %}
          >{{ form.message }}</textarea>
          <label class="form__label field__label" for="Recipient-message-{{ section.id }}" style="font-family: 'PhoriaBold'; font-size: 10px;">
            MESSAGE
          </label>
          <label class="form__label recipient-form-field-label recipient-form-field-label--space-between">
          </label>
        </div>


        <div
          id="RecipientForm-message-error-{{ section.id }}"
          class="form__message{% unless form.errors contains 'message' %} hidden{% endunless %}"
        >
          <span class="error-message">
            {%- if form.errors contains 'message' -%}
              {{ form.errors.messages.message }}.
            {%- endif -%}
          </span>
        </div>
      </div>
      {% comment %}
      <div class="recipient-fields__field">
        <div class="field">
          <input
            class="field__input text-body"
            autocomplete="send_on"
            type="date"
            id="Recipient-send-on-{{ section.id }}"
            name="properties[Send on]"
            placeholder="{{ 'recipient.form.send_on' | t }}"
            pattern="\d{4}-\d{2}-\d{2}"
            value="{{ form.send_on }}"
            required
            {% if form.errors contains 'send_on' %}
              aria-invalid="true"
              aria-describedby="RecipientForm-send_on-error-{{ section.id }}"
            {% endif %}
          >
          <label class="form__label field__label" for="Recipient-send-on-{{ section.id }}">
            {{ 'recipient.form.send_on_label' | t }}
          </label>
        </div>

        <div
          id="RecipientForm-send_on-error-{{ section.id }}"
          class="form__message{% unless form.errors contains 'send_on' %} hidden{% endunless %}"
        >
          <span class="error-message">
            {%- if form.errors contains 'send_on' -%}
              {{ form.errors.messages.send_on }}.
            {%- endif -%}
          </span>
        </div>
      </div>
      {% endcomment %}
      <p class="ph-gift-card-note-pdp">Please note, if you are gifting credit to someone else 
        this will be sent virtually to them 
        in the form of an email with a coupon code and not a physical gift card</p>
    </div>
    <input
      type="hidden"
      name="{{ gift_card_recipient_control_flag }}"
      value="if_present"
      id="Recipient-control-{{ section.id }}"
    >
    <input
      type="hidden"
      name="properties[__shopify_offset]"
      value=""
      id="Recipient-timezone-offset-{{ section.id }}"
      disabled
    >
  </recipient-form>
</div>