{% comment %}
  Orders Tab Snippet - ph-orders-snippet.liquid
  Usage: {% render 'ph-orders-snippet' %}
{% endcomment %}

<style>
/* Base styles */
.ph-cust-orders-container {
  width: 100%;
}

.ph-cust-tab-title {
  font-size: 1.25vw;
  font-family: "PhoriaBold";
  margin: 0;
  margin-left: -0.15vw !important;
  color: #1d1d1d;
}

/* Desktop table styles */
.ph-cust-orders-table {
  width: 100%;
  font-family: "PhoriaRegular";
  color: #1d1d1d;
  border-collapse: collapse;
  margin-top: 36px;
}

.ph-cust-orders-table th{
  padding: 4px 0 18px 0;
  font-weight: normal;
  text-align: left;
  border-bottom: 1px solid #eee;
  font-size: 10px;
}

  
.ph-cust-orders-table td {
  padding: 18px 0 18px 0;
  text-align: left;
  font-size: 10px;
}

.ph-cust-orders-table th:last-child,
.ph-cust-orders-table td:last-child {
  text-align: right;
}

.ph-cust-orders-table td:first-child,
.ph-cust-orders-table td:last-child {
  font-weight: bold;
}


.ph-cust-btn-view {
  background: none;
  border: none;
  padding: 18px 0px;
  text-decoration: none;
  font-size: 10px;
}
  
/* Mobile card styles */
.ph-cust-order-card {
  background: #fff;
  margin-bottom: 54px;
  border-bottom: 1px solid #81847a !important;
}

.ph-cust-order-card:last-child {
  border-bottom: none;
}

.ph-cust-mobile-order-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18px 0;
  border-bottom: 1px solid #f1f2ee !important;
  font-size: 10px;
  text-transform: uppercase;
}

.ph-cust-mobile-order-row:last-child {
  margin-bottom: 0;
}

.ph-cust-mobile-label {
  color: #666;
  font-weight: normal;
}

.ph-cust-mobile-value {
  color: #000;
  font-weight: normal;
  text-align: right;
}

.ph-cust-mobile-value a {
  color: #000;
  text-decoration: none;
  font-weight: bold;
  font-family: "PhoriaBold";
}

.ph-cust-order-mobile-bold{
  font-family: "PhoriaBold";
}

.ph-cust-no-orders {
  text-align: center;
  padding: 40px 20px;
  color: #666;
  font-size: 10px;
}

.ph-cust-btn-account {
  background: #000;
  color: #fff;
  padding: 12px 24px;
  text-decoration: none;
  font-size: 10px;
  display: inline-block;
  margin-top: 16px;
}
  
/* Responsive utilities */
.ph-cust-desktop-only {
  display: table;
}

.ph-cust-mobile-only {
  display: none;
}

/* Mobile styles */
@media (max-width: 760px) {
  .ph-cust-desktop-only {
    display: none;
  }
  
  .ph-cust-mobile-only {
    display: block;
  }
  
  .ph-cust-tab-title {
    font-size: 18px;
    margin-bottom: 36px;
  }
}
</style>


<div class="ph-cust-orders-container">
  <h2 class="ph-cust-tab-title">ORDERS</h2>
  
  {% if customer.orders.size > 0 %}
    <!-- Desktop Table View -->
    <table class="ph-cust-orders-table ph-cust-desktop-only">
      <thead>
        <tr>
          <th>ORDER</th>
          <th>DATE</th>
          <th>STATUS</th>
          <th>TOTAL</th>
          <th>ACTIONS</th>
        </tr>
      </thead>
      <tbody>
        {% for order in customer.orders %}
          <tr>
            <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
            <td>{{ order.created_at | date: "%b %d, %Y" }}</td>
            <td>{{ order.fulfillment_status }}</td>
            <td><strong>{{ order.total_price | money }}</strong> FOR {{ order.line_items.size }} ITEMS</td>
            <td><a href="{{ order.customer_url }}" class="ph-cust-btn-view">VIEW</a></td>
          </tr>
        {% endfor %}
      </tbody>
    </table>

    <!-- Mobile Card View -->
    <div class="ph-cust-orders-cards ph-cust-mobile-only">
      {% for order in customer.orders %}
        <div class="ph-cust-order-card">
          <div class="ph-cust-mobile-order-row">
            <span class="ph-cust-mobile-label">ORDER:</span>
            <span class="ph-cust-mobile-value ph-cust-order-mobile-bold">{{ order.name }}</span>
          </div>
          
          <div class="ph-cust-mobile-order-row">
            <span class="ph-cust-mobile-label">DATE:</span>
            <span class="ph-cust-mobile-value">{{ order.created_at | date: "%b %d, %Y" | upcase }}</span>
          </div>
          
          <div class="ph-cust-mobile-order-row">
            <span class="ph-cust-mobile-label">STATUS:</span>
            <span class="ph-cust-mobile-value">{{ order.fulfillment_status | upcase }}</span>
          </div>
          
          <div class="ph-cust-mobile-order-row">
            <span class="ph-cust-mobile-label">TOTAL:</span>
            <span class="ph-cust-mobile-value"><strong>{{ order.total_price | money | upcase }}</strong> FOR {{ order.line_items.size }} ITEMS</span>
          </div>
          
          <div class="ph-cust-mobile-order-row">
            <span class="ph-cust-mobile-label">ACTIONS:</span>
            <span class="ph-cust-mobile-value">
              <a href="{{ order.customer_url }}">VIEW</a>
            </span>
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <p class="ph-cust-no-orders">
      <span>BROWSE PRODUCTS.</span> NO ORDER HAS BEEN MADE YET.
    </p>
    <a href="{{ routes.all_products_collection_url }}" class="ph-cust-btn-account">CONTINUE SHOPPING</a>
  {% endif %}
</div>