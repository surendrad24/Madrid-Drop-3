        // Look for any link with text "VIP ACCESS"
        footerLinks.forEach(function(link) {
          if (link.textContent.trim() === "VIP ACCESS") {
            // Add the klaviyo_form_trigger class to the link
            link.classList.add('klaviyo_form_trigger');

            // Add the klaviyo form trigger event listener to this specific link
            link.addEventListener('click', function(e) {
              e.preventDefault(); // Prevent the default link behavior
              window._klOnsite = window._klOnsite || [];
              window._klOnsite.push(['openForm', 'TdgdaL']);
