  "min": 30,
  "max": 100,
  "step": 1,
  "unit": "%",
  "default": 100
},
{
  "type": "range",
  "id": "para_width_mobile",
  "label": "Paragraph Width (Mobile, %)",
  "min": 50,
  "max": 100,
  "step": 1,
  "unit": "%",
  "default": 100
},
{
  "type": "range",
  "id": "extra_width_desktop",
  "label": "Extra Text Width (Desktop)",
  "min": 20,
  "max": 100,
  "step": 1,
  "default": 100,
  "unit": "%"
},
{
  "type": "range",
  "id": "extra_width_mobile",
  "label": "Extra Text Width (Mobile)",
  "min": 20,
  "max": 100,
  "step": 1,
  "default": 100,
  "unit": "%"
}

  ],
  "presets": [
    {
      "name": "Ph Collection Description"
    }
  ]
}
