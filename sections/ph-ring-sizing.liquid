<style>
  .ph-ring-size-container {
    width: 100%;
    padding: 60px 0 0;
  }
  
  .ph-ring-size-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 80vw;
    margin: 0 auto;
    padding: 0 20px;
  }
  
  .ph-ring-size-pre-heading {
    font-size: 1.25vw;
    margin-bottom: 0;
    text-transform: uppercase;
    font-weight: 500;
  }
  
  .ph-ring-size-heading {
     font-size: 1.25vw;
    margin-bottom: 0;
    word-spacing: 2.2px;
    text-transform: uppercase;
    font-weight: 500;
    width: 100%;
  }
  
  .ph-ring-size-description {
    font-size: 10px;
    line-height: 2.3;
    margin-top: 27px;
    text-transform: uppercase;
    max-width: 900px;
  }
  
  .ph-ring-size-video-wrapper {
    width: 100%;
    margin: 0 auto;
  }
  
  .ph-ring-size-video {
    width: 100%;
    position: relative;
  }
  
  .ph-video-aspect-ratio {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    overflow: hidden;
    max-width: 640px;
    width: 100%;
    margin: 0 auto;
    aspect-ratio: 1;
  }
  
  .ph-video-element {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .ph-video-cover {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  
  .ph-placeholder-video {
    width: 100%;
    aspect-ratio: 16/9;
    background-color: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #777;
    border: 1px dashed #ccc;
  }

   @media screen and (max-width: 1030px) {
    .ph-ring-size-container {
      padding: 80px 0 0;
    }

   }
  @media screen and (max-width: 959px) {
    .ph-ring-size-container {
      padding: 70px 18px 0;
    }

  .ph-ring-size-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: none;
    margin: 0 auto;
    padding: 0;
  }

    .ph-ring-size-heading {
     font-size: 18px;
     margin: 0;
     word-spacing: 2.2px;
     text-transform: uppercase;
     font-weight: 500;
     width: 100%;
   }
  
    
    .ph-ring-size-video-wrapper {
      max-width: 100% !important;
    }
  }
  
  @media screen and (max-width: 756px) {
     .ph-ring-size-container {
      padding: 60px 18px 0;
    }
  }
</style>

<div class="ph-ring-size-container">
  <div class="ph-ring-size-inner">
    {% if section.settings.pre_heading != blank %}
      <div class="ph-ring-size-pre-heading">{{ section.settings.pre_heading }}</div>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="ph-ring-size-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.description != blank %}
      <div class="ph-ring-size-description">{{ section.settings.description }}</div>
    {% endif %}
    
    <div class="ph-ring-size-video-wrapper" style="max-width: {{ section.settings.video_width }}%;">
      {% if section.settings.guide_video != blank %}
        <div class="ph-ring-size-video">
          <div class="ph-video-aspect-ratio">
            {{ section.settings.guide_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: "ph-video-element" }}
          </div>
        </div>
      {% else %}
        <div class="ph-placeholder-video">
          <span>Upload ring size guide video</span>
        </div>
      {% endif %}
    </div>
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', () =>{
    const { animate, inView, transform } = Motion;
    inView(document.querySelector(".ph-ring-size-container"), (elem) =>{
      [...elem.querySelector('.ph-ring-size-inner').children].forEach((child, index) =>{
        animate(child, { opacity: [0, 1], y: [20, 0] }, { duration: 0.5, delay: 0.2 * index, easing: "ease-out" })
      })
    })
  })
</script>
{% schema %}
{
  "name": "Ph Ring Head",
  "tag": "section",
  "class": "ph-ring-size-section",
  "settings": [
    {
      "type": "text",
      "id": "pre_heading",
      "label": "Pre-Heading",
      "default": "PHORIA"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "HOW TO // FIND YOUR RING SIZE"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "THERE ARE MULTIPLE WAYS TO CHECK YOUR RING SIZE, AND WE WANT TO MAKE IT AS EASY AS POSSIBLE FOR YOU TO DO."
    },
    {
      "type": "video",
      "id": "guide_video",
      "label": "Ring Size Guide Video"
    },
    {
      "type": "image_picker",
      "id": "video_cover_image",
      "label": "Video Cover Image (optional)"
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show Video Controls",
      "default": true
    },
    {
      "type": "range",
      "id": "video_width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Video Width",
      "default": 70
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Ph Ring Head"
    }
  ]
}
{% endschema %}