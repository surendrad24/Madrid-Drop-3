<style>
  .ph-modular-combinations-container {
    width: 100%;
    padding-top: 90px;
    padding-bottom: 90px;
    max-width: 80vw;
    margin: 0 auto;
  }
  
  .ph-modular-combinations-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin: 0 auto;
    padding: 0 20px;
    max-width: 900px;
  }
  
  .ph-modular-combinations-heading {
    font-size: 1.23vw;
    letter-spacing: 0.1em;
    margin-bottom: 30px;
    text-transform: uppercase;
    font-weight: 500;
    width: 100%;
  }
  
  .ph-modular-combinations-description {
    font-size: 10px;
    line-height: 2.3;
    margin-bottom: 40px;
    text-transform: uppercase;
    max-width: 900px;
  }
  
  .ph-modular-combinations-table-wrapper {
    width: 100%;
  }
  
  .ph-modular-combinations-table {
    width: 100%;
    border-collapse: collapse;
  }
  
  .ph-modular-combinations-header {
    background-color: #d9d9d9;
    color: #000;
    padding: 18px;
    text-align: center;
    font-size: 10px;
    text-transform: uppercase;
    font-weight: 500;
    font-family: "PhoriaBold";
    line-height: 2.3;
  }
  
  .ph-modular-combinations-row {
    border-bottom: 1px solid #eee;
  }
  
  .ph-modular-combinations-cell {
    padding: 18px;
    text-align: center;
    font-size: 10px;
    text-transform: uppercase;
    border: 1px solid #f1f2ee;
    line-height: 2.3;
    font-weight: 600;
  }
  
  @media screen and (max-width: 989px) {
    .ph-modular-combinations-container {
      padding-left: 18px;
      padding-right: 18px;
      max-width: none;
    }
    .ph-modular-combinations-inner{
      padding: 0;
    }
    .ph-modular-combinations-heading {
      font-size: 18px;
      margin-bottom: 20px;
    }
    
    .ph-modular-combinations-description {
      margin-bottom: 30px;
    }
    
    .ph-modular-combinations-header {
      padding: 9px 5px;
    }
    
    .ph-modular-combinations-cell {
      padding: 9px 5px;
    }
  }
</style>

<div class="ph-modular-combinations-container">
  <div class="ph-modular-combinations-inner">
    {% if section.settings.heading != blank %}
      <h2 class="ph-modular-combinations-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.description != blank %}
      <div class="ph-modular-combinations-description">{{ section.settings.description }}</div>
    {% endif %}
    
    <div class="ph-modular-combinations-table-wrapper">
      <table class="ph-modular-combinations-table">
        {% if section.settings.table_header != blank %}
          <thead>
            <tr>
              <th class="ph-modular-combinations-header">{{ section.settings.table_header }}</th>
            </tr>
          </thead>
        {% endif %}
        
        <tbody>
          {% for block in section.blocks %}
            {% if block.type == 'combination' %}
              <tr class="ph-modular-combinations-row" {{ block.shopify_attributes }}>
                <td class="ph-modular-combinations-cell">{{ block.settings.combination_text }}</td>
              </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Ph Modular Necklace Combo",
  "tag": "section",
  "class": "ph-modular-combinations-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FIND YOUR MODULAR NECKLACE CHAIN LENGTH"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "BELOW ARE A FEW EXAMPLES AND SUGGESTIONS OF BRACELET COMBINATIONS THAT WORK REALLY NICELY AS MODULAR NECKLACES:"
    },
    {
      "type": "text",
      "id": "table_header",
      "label": "Table Header",
      "default": "OUR RECOMMENDATIONS: MODULAR COMBINATIONS"
    }
  ],
  "blocks": [
    {
      "type": "combination",
      "name": "Combination",
      "settings": [
        {
          "type": "text",
          "id": "combination_text",
          "label": "Combination Description",
          "default": "X1 SCREW + X2 SCREW DOUBLED UP"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ph Modular Necklace Combo",
      "blocks": [
        {
          "type": "combination",
          "settings": {
            "combination_text": "X1 SCREW + X2 SCREW DOUBLED UP"
          }
        },
        {
          "type": "combination",
          "settings": {
            "combination_text": "X2 SCREW DOUBLED UP + X1 BOND"
          }
        },
        {
          "type": "combination",
          "settings": {
            "combination_text": "X1 HYPE + X1 BOND"
          }
        },
        {
          "type": "combination",
          "settings": {
            "combination_text": "X1 BOND + X1 BOND + X1 SCREW ATTACHED FROM THE SIDE"
          }
        },
        {
          "type": "combination",
          "settings": {
            "combination_text": "X1 HYPE + X1 HYPE"
          }
        },
        {
          "type": "combination",
          "settings": {
            "combination_text": "X1 HYPE + X1 HYPE + X1 SCREW ATTACHED FROM THE SIDE"
          }
        }
      ]
    }
  ]
}
{% endschema %}