<style>
  .ph-reversible-hoops-container {
    width: 100%;
    opacity: 0; /* Start invisible for animation */
  }
  
  .ph-reversible-hoops-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  
  .ph-reversible-hoops-header {
    margin-bottom: 50px;
    width: 100%;
    text-align: center;
    opacity: 0; /* Start invisible for animation */
  }
  
  .ph-reversible-hoops-heading,
  .ph-reversible-hoops-heading-line2 {
    font-size: 1.23vw;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    margin: 0;
    line-height: 1.3;
  }
  
  .ph-reversible-hoops-videos {
    display: flex;
    justify-content: center;
    gap: 40px;
    width: 100%;
    margin-bottom: 50px;
    opacity: 0; /* Start invisible for animation */
  }
  
  .ph-reversible-hoops-video-wrapper {
    flex: 0 0 calc(50% - 20px);
    max-width: calc(50% - 20px);
  }
  
  .ph-reversible-hoops-video {
    width: 100%;
    position: relative;
  }
  
  .ph-video-aspect-ratio {
    position: relative;
    width: 100%;
    height: 0;
    overflow: hidden;
  }
  
  .ph-video-aspect-ratio[style*="--aspect-ratio: 16:9"] {
    padding-bottom: 56.25%;
  }
  
  .ph-video-aspect-ratio[style*="--aspect-ratio: 1:1"] {
    padding-bottom: 100%;
  }
  
  .ph-video-aspect-ratio[style*="--aspect-ratio: 4:5"] {
    padding-bottom: 125%;
  }
  
  .ph-video-aspect-ratio[style*="--aspect-ratio: 9:16"] {
    padding-bottom: 177.78%;
  }
  
  .ph-video-element {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    cursor: pointer;
  }
  
  .ph-video-cover {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  
  .ph-video-play-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    background: rgba(0, 0, 0, 0.5);
    border: none;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    cursor: pointer;
    transition: background 0.3s ease;
  }
  
  .ph-video-play-button:hover {
    background: rgba(0, 0, 0, 0.7);
  }
  
  .ph-placeholder-video {
    width: 100%;
    aspect-ratio: 1/1;
    background-color: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #777;
    border: 1px dashed #ccc;
  }
  
  .ph-reversible-hoops-description {
    font-size: 10px;
    line-height: 2.3;
    text-transform: uppercase;
    max-width: 900px;
    opacity: 0; /* Start invisible for animation */
  }
  
  @media screen and (max-width: 989px) {
    .ph-reversible-hoops-container {
      padding: 0px 18px 90px;
    }
    .ph-reversible-hoops-inner{
      padding: 0;
    }
    .ph-reversible-hoops-header {
      margin-bottom: 0px;
    }
    
    .ph-reversible-hoops-heading,
    .ph-reversible-hoops-heading-line2 {
      font-size: 18px;
    }
    
    .ph-reversible-hoops-videos {
      flex-direction: column;
      align-items: center;
      gap: 20px;
      margin-bottom: 0px;
    }
    .ph-reversible-hoops-video {
      min-width: calc(100vw - 36px);
      margin: 0 auto;
    }
    .ph-reversible-hoops-video-wrapper {
      flex: 0 0 100%;
      max-width: 100%;
    }
    
    .ph-video-play-button {
      width: 50px;
      height: 50px;
    }
  }
</style>

<div class="ph-reversible-hoops-container" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="ph-reversible-hoops-inner">
    <div class="ph-reversible-hoops-header">
      {% if section.settings.heading_line1 != blank %}
        <h2 class="ph-reversible-hoops-heading">{{ section.settings.heading_line1 }}</h2>
      {% endif %}
      
      {% if section.settings.heading_line2 != blank %}
        <h2 class="ph-reversible-hoops-heading-line2">{{ section.settings.heading_line2 }}</h2>
      {% endif %}
    </div>
    
    <div class="ph-reversible-hoops-videos">
      {% for block in section.blocks %}
        {% if block.type == 'video' %}
          <div class="ph-reversible-hoops-video-wrapper" {{ block.shopify_attributes }}>
            {% if block.settings.style_video != blank %}
              <div class="ph-reversible-hoops-video">
                {% assign video_aspect_ratio = block.settings.video_aspect_ratio | default: '1:1' %}
                <div class="ph-video-aspect-ratio" style="--aspect-ratio: {{ video_aspect_ratio }};">
                  {% if block.settings.cover_image != blank %}
                    <img 
                      src="{{ block.settings.cover_image | img_url: 'master' }}" 
                      alt="Reversible two-toned hoops styling video" 
                      class="ph-video-cover"
                      loading="lazy"
                      width=""
                      height=""
                    >
                  {% endif %}
                  {{ block.settings.style_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: "ph-video-element" }}
                </div>
              </div>
            {% else %}
              <div class="ph-placeholder-video">
                <span>Upload video</span>
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
    
    {% if section.settings.description_top != blank %}
      <div class="ph-reversible-hoops-description ph-description-top">{{ section.settings.description_top }}</div>
    {% endif %}
    
    {% if section.settings.description_bottom != blank %}
      <div class="ph-reversible-hoops-description ph-description-bottom">{{ section.settings.description_bottom }}</div>
    {% endif %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof Motion !== 'undefined' && {{ section.settings.enable_animations | default: true }}) {
      const { animate, inView } = Motion;
      
      // Animate container
      const container = document.querySelector('.ph-reversible-hoops-container');
      if (container) {
        inView(container, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate header
      const header = document.querySelector('.ph-reversible-hoops-header');
      if (header) {
        inView(header, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.2, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate videos
      const videosGrid = document.querySelector('.ph-reversible-hoops-videos');
      if (videosGrid) {
        inView(videosGrid, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [30, 0] }, 
            { duration: 0.6, delay: 0.4, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate top description
      const descriptionTop = document.querySelector('.ph-description-top');
      if (descriptionTop) {
        inView(descriptionTop, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.6, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate bottom description
      const descriptionBottom = document.querySelector('.ph-description-bottom');
      if (descriptionBottom) {
        inView(descriptionBottom, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.8, easing: "ease-out" }
          );
        }, { once: true });
      }
    }
  });

  // Original video interaction script
  (function() {
    var videoWrappers = document.querySelectorAll('.ph-reversible-hoops-video');
    
    videoWrappers.forEach(function(wrapper) {
      var video = wrapper.querySelector('.ph-video-element');
      var cover = wrapper.querySelector('.ph-video-cover');
      var playButton = wrapper.querySelector('.ph-video-play-button');
      
      if (video && playButton) {
        playButton.addEventListener('click', function() {
          if (cover) {
            cover.style.display = 'none';
          }
          playButton.style.display = 'none';
          video.play();
          video.setAttribute('controls', 'true');
        });
        
        video.addEventListener('click', function() {
          if (video.paused) {
            video.play();
          } else {
            video.pause();
          }
        });
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Ph Earrings How to",
  "tag": "section",
  "class": "ph-reversible-hoops-section",
  "settings": [
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading Line 1",
      "default": "HOW TO STYLE // REVERSIBLE"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading Line 2",
      "default": "+ TWO TONED HOOPS"
    },
    {
      "type": "richtext",
      "id": "description_top",
      "label": "Top Description",
      "default": "<p>OUR REVERSIBLE TWO-TONED HOOPS ALLOW YOU TO SWITCH EFFORTLESSLY BETWEEN SILVER AND GOLD. EMBELLISHED OR PLAIN. ENCOURAGING INDIVIDUALITY THROUGH VERSATILITY.</p>"
    },
    {
      "type": "richtext",
      "id": "description_bottom",
      "label": "Bottom Description",
      "default": "<p>LIGHTWEIGHT WITH A HOLLOWED CONSTRUCTION. OUR EARRINGS ARE HANDCRAFTED FOR ALL-DAY, EVERYDAY COMFORT WHILST KEEPING THAT BOLD LOOK AND FEEL.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "enable_animations",
      "label": "Enable Animations",
      "default": true,
      "info": "Enable fade-in animations when content comes into view"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Style Video",
      "settings": [
        {
          "type": "video",
          "id": "style_video",
          "label": "Video"
        },
        {
          "type": "select",
          "id": "video_aspect_ratio",
          "label": "Aspect ratio",
          "options": [
            {
              "value": "16:9",
              "label": "16:9"
            },
            {
              "value": "1:1",
              "label": "1:1 (Square)"
            },
            {
              "value": "4:5",
              "label": "4:5"
            },
            {
              "value": "9:16",
              "label": "9:16 (Portrait)"
            }
          ],
          "default": "1:1"
        },
        {
          "type": "image_picker",
          "id": "cover_image",
          "label": "Cover Image (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ph Earring How to",
      "blocks": [
        {
          "type": "video"
        },
        {
          "type": "video"
        }
      ]
    }
  ]
}
{% endschema %}