<style>
  .ph-wrist-size-chart-container {
    width: 100%;
    max-width: 80vw;
    margin: 0 auto;
    padding-top: 54px; 
  }
  
  .ph-wrist-size-chart-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin: 0 auto;
    padding: 0 36px;
    max-width: 900px;
  }
  
  .ph-wrist-size-chart-heading {
    font-size: 1.23vw;
    letter-spacing: 0.1em;
    margin-top: 0px;
    margin-bottom: 36px;
    text-transform: uppercase;
    font-weight: 500;
    line-height: 1.3;
    width: 100%;
  }
  
  .ph-wrist-size-chart-table-wrapper {
    width: 100%;
    overflow-x: auto;
    max-width: 900px;
  }
  
  .ph-wrist-size-chart-table {
    width: 100%;
    border-collapse: collapse;
  }
  
  .ph-wrist-size-chart-header {
    background-color: #D5D5D5;
    color: #000;
    padding: 18px;
    line-height: 2.3;
    text-align: center;
    font-size: 10px;
    text-transform: uppercase;
    font-weight: 500;
    font-family: 'PhoriaBold';
    border: 1px solid #f1f2ee;
    width: 33%;
  }
  
  .ph-wrist-size-chart-category-row {
    background-color: #f1f2ee;
    font-size: 10px;
    font-family: 'PhoriaBold';
  }
  
  .ph-wrist-size-chart-category-cell {
    padding: 18px;
    text-align: center;
    font-size: 10px;
    text-transform: uppercase;
    font-weight: 500;
    line-height: 2.3;
  }
  
  .ph-wrist-size-chart-row {
    border-bottom: 1px solid #eee;
  }
  
  .ph-wrist-size-chart-cell {
    padding: 15px 10px;
    text-align: center;
    font-size: 10px;
    text-transform: uppercase;
    font-weight: 600;
    border: 1px solid #f1f2ee;
    line-height: 2.3;
  }
  
  .ph-wrist-size-chart-table tr:nth-child(even):not(.ph-wrist-size-chart-category-row) {
    background-color: #fafafa;
  }
  
  @media screen and (max-width: 989px) {
    .ph-wrist-size-chart-inner{
      padding: 0;
    }
    .ph-wrist-size-chart-container {
      padding: 54px 15px 0 15px;
      max-width: none;
    }
    
    .ph-wrist-size-chart-heading {
      font-size: 18px;
      margin-bottom: 30px;
    }
    
    .ph-wrist-size-chart-header,
    .ph-wrist-size-chart-category-cell,
    .ph-wrist-size-chart-cell {
      padding: 9px 5px;
    }
    .ph-wrist-size-chart-header{
      width: 30%;
    }
    .ph-wrist-size-chart-header:last-child{
      width: 40%;
    }
  }
</style>

<div class="ph-wrist-size-chart-container">
  <div class="ph-wrist-size-chart-inner">
    {% if section.settings.heading != blank %}
      <h2 class="ph-wrist-size-chart-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="ph-wrist-size-chart-table-wrapper">
      <table class="ph-wrist-size-chart-table">
        <thead>
          <tr>
            <th class="ph-wrist-size-chart-header">{{ section.settings.col_heading_1 }}</th>
            <th class="ph-wrist-size-chart-header">{{ section.settings.col_heading_2 }}</th>
            <th class="ph-wrist-size-chart-header">{{ section.settings.col_heading_3 }}</th>
          </tr>
        </thead>
        <tbody>
          {% assign current_category = '' %}
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'category_heading' %}
                <tr class="ph-wrist-size-chart-category-row" {{ block.shopify_attributes }}>
                  <td colspan="3" class="ph-wrist-size-chart-category-cell">{{ block.settings.category_name }}</td>
                </tr>
                {% assign current_category = block.settings.category_name %}
              {% when 'size_row' %}
                <tr class="ph-wrist-size-chart-row" {{ block.shopify_attributes }}>
                  <td class="ph-wrist-size-chart-cell">{{ block.settings.size_name }}</td>
                  <td class="ph-wrist-size-chart-cell">{{ block.settings.wrist_cm }}</td>
                  <td class="ph-wrist-size-chart-cell">{{ block.settings.wrist_inches }}</td>
                </tr>
            {% endcase %}
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof Motion !== 'undefined' && {{ section.settings.enable_animations | default: true }}) {
      const { animate, inView } = Motion;
      
      // Animate container
      const container = document.querySelector('.ph-wrist-size-chart-container');
      if (container) {
        inView(container, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate heading
      const heading = document.querySelector('.ph-wrist-size-chart-heading');
      if (heading) {
        inView(heading, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.2, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate table wrapper
      const tableWrapper = document.querySelector('.ph-wrist-size-chart-table-wrapper');
      if (tableWrapper) {
        inView(tableWrapper, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [30, 0] }, 
            { duration: 0.6, delay: 0.4, easing: "ease-out" }
          );
        }, { once: true });
      }
    }
  });
</script>

