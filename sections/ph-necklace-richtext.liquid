<style>
  .ph-size-combinations-container {
    max-width: 80vw;
    margin: 0 auto;
    padding: 0px 36px 90px;
  }
  
  .ph-size-combinations-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  
  .ph-size-combinations-heading {
    font-size: 1.25vw;
    line-height: 1.2;
    margin: 0;
    text-transform: uppercase;
    font-weight: 500;
    width: 100%;
    opacity: 0; /* Start invisible for animation */
  }
  
  .ph-size-combinations-description {
    font-size: 10px;
    line-height: 2.3;
    margin-top: 27px;
    text-transform: uppercase;
    max-width: 900px;
    opacity: 0; /* Start invisible for animation */
  }
  
  .ph-size-combinations-description p {
    margin: 0px;
  }
  
  .ph-size-chart-image-wrapper {
    width: 100%;
    max-width: 800px;
    margin-bottom: 30px;
    opacity: 0; /* Start invisible for animation */
  }
  
  .ph-size-chart-image {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .ph-additional-text {
    font-size: 10px;
    text-transform: uppercase;
    max-width: 800px;
    margin-top: 20px;
    opacity: 0; /* Start invisible for animation */
  }

  @media screen and (max-width: 1020px) {
    .ph-size-combinations-container {
      max-width: 100%;
      margin: 0 auto;
      padding: 0px 18px 90px;
    }
    
     .ph-size-combinations-heading {
      font-size: 18px;
    }
  }
</style>

<div class="ph-size-combinations-container">
  <div class="ph-size-combinations-inner">
    {% if section.settings.heading != blank %}
      <h2 class="ph-size-combinations-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.description != blank %}
      <div class="ph-size-combinations-description">{{ section.settings.description }}</div>
    {% endif %}
    
    {% if section.settings.size_chart_image != blank %}
      <div class="ph-size-chart-image-wrapper">
        <img 
          src="{{ section.settings.size_chart_image | img_url: 'master' }}" 
          alt="Size chart for modular necklaces" 
          class="ph-size-chart-image"
          loading="lazy"
          width="{{ section.settings.size_chart_image.width }}"
          height="{{ section.settings.size_chart_image.height }}"
        >
      </div>
    {% endif %}
    
    {% if section.settings.additional_text != blank %}
      <div class="ph-additional-text">{{ section.settings.additional_text }}</div>
    {% endif %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof Motion !== 'undefined' && {{ section.settings.enable_animations | default: true }}) {
      const { animate, inView, transform } = Motion;
      
      // Animate heading
      const heading = document.querySelector('.ph-size-combinations-heading');
      if (heading) {
        inView(heading, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate description
      const description = document.querySelector('.ph-size-combinations-description');
      if (description) {
        inView(description, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.2, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate chart image
      const chartImage = document.querySelector('.ph-size-chart-image-wrapper');
      if (chartImage) {
        inView(chartImage, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [30, 0] }, 
            { duration: 0.6, delay: 0.4, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate additional text
      const additionalText = document.querySelector('.ph-additional-text');
      if (additionalText) {
        inView(additionalText, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.6, easing: "ease-out" }
          );
        }, { once: true });
      }
    }
  });
</script>

{% schema %}
{
  "name": "Ph Nacklace RichT",
  "tag": "section",
  "class": "ph-size-combinations-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SIZE COMBINATIONS"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>PLEASE BE AWARE OF OUR CHAIN SIZES WHEN CREATING YOUR DESIRED NECKLACE. DIFFERENT CHAINS WILL SIT DIFFERENTLY ON YOUR NECK DEPENDING ON THE THICKNESS OF THE CHAIN. THE THICKER THE CHAIN THE LONGER IT NEEDS TO BE TO SIT NICELY ON THE NECK.</p><p>PLEASE TAKE THIS INTO ACCOUNT WHEN BUYING MORE THAN ONE BRACELET FOR A MODULAR NECKLACE.</p><p>WE RECOMMEND REFERRING TO THE SIZE CHART BELOW FOR MINIMUM TOTAL LENGTHS:</p>"
    },
    {
      "type": "image_picker",
      "id": "size_chart_image",
      "label": "Size Chart Image (Optional)"
    },
    {
      "type": "text",
      "id": "additional_text",
      "label": "Additional Text (Optional)"
    },
    {
      "type": "checkbox",
      "id": "enable_animations",
      "label": "Enable animations",
      "default": true,
      "info": "Enable fade-in animations when content comes into view"
    }
  ],
  "presets": [
    {
      "name": "Ph Nacklace RichT"
    }
  ]
}
{% endschema %}