<style>
  .ph-necklace-length-guide-container {
    width: 100%;
    padding-top: 90px;
  }
  
  .ph-necklace-length-guide-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin: 0 auto;
    padding: 0 20px;
    max-width: 900px;
  }
  
  .ph-necklace-length-guide-heading {
    font-size: 1.23vw;
    margin-top: 0px;
    margin-bottom: 27px;
    text-transform: uppercase;
    font-weight: 500;
    width: 100%;
  }
  
  .ph-necklace-length-guide-description {
    font-size: 10px;
    line-height: 2.3;
    margin-bottom: 36px;
    text-transform: uppercase;
    max-width: 900px;
  }
  
  .ph-necklace-length-guide-image-wrapper {
    width: 100%;
    margin: 0 auto;
    margin-bottom: 18px;
  }
  
  .ph-necklace-length-guide-image {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .ph-placeholder-image {
    width: 50%;
    height: 600px;
    background-color: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #777;
    border: 1px dashed #ccc;
  }
  
  @media screen and (max-width: 989px) {
    .ph-necklace-length-guide-container {
      padding: 0px 18px;
    }
    .ph-necklace-length-guide-inner{
      padding: 0;
    }
    
    .ph-necklace-length-guide-heading {
      font-size: 18px;
    }
    
    .ph-necklace-length-guide-description {
      margin-bottom: 18px;
    }
    
    .ph-necklace-length-guide-image-wrapper {
      max-width: 100% !important;
    }
    
    .ph-placeholder-image {
      width: 100%;
      height: 400px;
    }
  }
</style>

<div class="ph-necklace-length-guide-container">
  <div class="ph-necklace-length-guide-inner">
    {% if section.settings.heading != blank %}
      <h2 class="ph-necklace-length-guide-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.description != blank %}
      <div class="ph-necklace-length-guide-description">{{ section.settings.description }}</div>
    {% endif %}
    
    {% if section.settings.guide_image != blank %}
      <div class="ph-necklace-length-guide-image-wrapper" style="max-width: {{ section.settings.image_width }}%;">
        <img 
          src="{{ section.settings.guide_image | img_url: 'master' }}" 
          alt="Necklace length guide showing where different lengths will sit on the body" 
          class="ph-necklace-length-guide-image"
          loading="lazy"
          width="{{ section.settings.guide_image.width }}"
          height="{{ section.settings.guide_image.height }}"
        >
      </div>
    {% else %}
      <div class="ph-placeholder-image">
        <span>Upload necklace length guide image</span>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Ph Modular Neck Length",
  "tag": "section",
  "class": "ph-necklace-length-guide-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHERE YOUR NECKLACE WILL SIT"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "PLEASE REFER TO THE SKETCH BELOW FOR A ROUGH ESTIMATION FOR WHERE YOUR NECKLACE WILL SIT. PLEASE REMEMBER TO COMBINE THE TOTAL LENGTHS OF THE BRACELETS OF YOUR CHOICE TO GET YOUR TOTAL LENGTH IN INCHES."
    },
    {
      "type": "image_picker",
      "id": "guide_image",
      "label": "Necklace Length Guide Image"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Image Width",
      "default": 50
    },
  ],
  "presets": [
    {
      "name": "Ph Modular Neck Length"
    }
  ]
}
{% endschema %}