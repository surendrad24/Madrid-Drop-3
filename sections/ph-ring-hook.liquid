<style>
  .ph-hookup-chain-ring-container {
    width: 100%;
  }
  
  .ph-hookup-chain-ring-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 80vw;
    margin: 0 auto;
    padding: 0 20px;
  }
  
  .ph-hookup-chain-ring-heading {
    font-size: 28px;
    letter-spacing: 0.2em;
    margin-bottom: 50px;
    text-transform: uppercase;
    font-weight: 500;
    width: 100%;
    opacity: 0; /* Start invisible for animation */
  }
  
  .ph-hookup-chain-ring-options {
    display: flex;
    justify-content: center;
    gap: 60px;
    width: 100%;
  }
  
  .ph-hookup-chain-ring-option {
    flex: 1;
    max-width: 23vw;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    opacity: 0; /* Start invisible for animation */
  }
  
  .ph-hookup-chain-ring-image-wrapper {
    width: 100%;
    margin-bottom: 30px;
  }
  
  .ph-hookup-chain-ring-image {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .ph-placeholder-image {
    width: 100%;
    aspect-ratio: 1/1;
    background-color: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #777;
    border: 1px dashed #ccc;
    margin-bottom: 30px;
  }
  
  .ph-hookup-chain-option-heading {
    font-size: 20px;
    letter-spacing: 0.2em;
    margin-bottom: 20px;
    text-transform: uppercase;
    font-weight: 500;
  }
  
  .ph-hookup-chain-option-description {
    font-size: 10px;
    line-height: 2.3;
    text-transform: uppercase;
    max-width: 375px;
    
  }
  
  @media screen and (max-width: 768px) {
     .ph-hookup-chain-ring-inner{
        padding: 0px !important;
        max-width: 90vw;
      }
    .ph-hookup-chain-ring-container {
      padding: 0px 18px;
    }
    
    .ph-hookup-chain-ring-heading {
      font-size: 22px;
      margin-bottom: 30px;
    }
    
    .ph-hookup-chain-ring-options {
      flex-direction: column;
      align-items: center;
      gap: 40px;
    }
    
    .ph-hookup-chain-ring-option {
      max-width: 100%;
    }
    
    .ph-hookup-chain-option-heading {
      font-size: 18px;
      margin-bottom: 15px;
    }
  }
</style>

<div class="ph-hookup-chain-ring-container">
  <div class="ph-hookup-chain-ring-inner">
    {% if section.settings.heading != blank %}
      <h2 class="ph-hookup-chain-ring-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="ph-hookup-chain-ring-options">
      <!-- Stack Option -->
      <div class="ph-hookup-chain-ring-option">
        {% if section.settings.stack_image != blank %}
          <div class="ph-hookup-chain-ring-image-wrapper">
            <img 
              src="{{ section.settings.stack_image | img_url: 'master' }}" 
              alt="Hookup chain ring - stack style" 
              class="ph-hookup-chain-ring-image"
              loading="lazy"
              width="{{ section.settings.stack_image.width }}"
              height="{{ section.settings.stack_image.height }}"
            >
          </div>
        {% else %}
          <div class="ph-placeholder-image">
            <span>Upload stack style image</span>
          </div>
        {% endif %}
        
        {% if section.settings.stack_heading != blank %}
          <h3 class="ph-hookup-chain-option-heading">{{ section.settings.stack_heading }}</h3>
        {% endif %}
        
        {% if section.settings.stack_description != blank %}
          <div class="ph-hookup-chain-option-description">{{ section.settings.stack_description }}</div>
        {% endif %}
      </div>
      
      <!-- Separate Option -->
      <div class="ph-hookup-chain-ring-option">
        {% if section.settings.separate_image != blank %}
          <div class="ph-hookup-chain-ring-image-wrapper">
            <img 
              src="{{ section.settings.separate_image | img_url: 'master' }}" 
              alt="Hookup chain ring - separate style" 
              class="ph-hookup-chain-ring-image"
              loading="lazy"
              width="{{ section.settings.separate_image.width }}"
              height="{{ section.settings.separate_image.height }}"
            >
          </div>
        {% else %}
          <div class="ph-placeholder-image">
            <span>Upload separate style image</span>
          </div>
        {% endif %}
        
        {% if section.settings.separate_heading != blank %}
          <h3 class="ph-hookup-chain-option-heading">{{ section.settings.separate_heading }}</h3>
        {% endif %}
        
        {% if section.settings.separate_description != blank %}
          <div class="ph-hookup-chain-option-description">{{ section.settings.separate_description }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof Motion !== 'undefined' && {{ section.settings.enable_animations | default: true }}) {
      const { animate, inView, transform } = Motion;
      
      // Animate heading
      const heading = document.querySelector('.ph-hookup-chain-ring-heading');
      if (heading) {
        inView(heading, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate each option individually
      const options = document.querySelectorAll('.ph-hookup-chain-ring-option');
      options.forEach((elem, index) => {
        inView(elem, (el) => {
          animate(el, 
            { opacity: [0, 1], y: [30, 0] }, 
            { duration: 0.6, delay: 0.2 * index, easing: "ease-out" }
          );
        }, { once: true });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Ph Hookup Ring",
  "tag": "section",
  "class": "ph-hookup-chain-ring-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "HOOKUP CHAIN RING"
    },
    {
      "type": "header",
      "content": "Stack Option"
    },
    {
      "type": "image_picker",
      "id": "stack_image",
      "label": "Stack Image"
    },
    {
      "type": "text",
      "id": "stack_heading",
      "label": "Stack Heading",
      "default": "STACK"
    },
    {
      "type": "textarea",
      "id": "stack_description",
      "label": "Stack Description",
      "default": "1) WRAP THE CONNECTING CHAIN AROUND A SINGLE FINGER AND STACK THE TWO BANDS TOGETHER."
    },
    {
      "type": "header",
      "content": "Separate Option"
    },
    {
      "type": "image_picker",
      "id": "separate_image",
      "label": "Separate Image"
    },
    {
      "type": "text",
      "id": "separate_heading",
      "label": "Separate Heading",
      "default": "SEPARATE"
    },
    {
      "type": "textarea",
      "id": "separate_description",
      "label": "Separate Description",
      "default": "2) OR SEPARATE THE BANDS ACROSS TWO FINGERS, LETTING THE CONNECTING CHAIN HANG FREELY BETWEEN THEM."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "enable_animations",
      "label": "Enable animations",
      "default": true,
      "info": "Enable fade-in animations when content comes into view"
    }
  ],
  "presets": [
    {
      "name": "Ph Hookup Ring"
    }
  ]
}
{% endschema %}