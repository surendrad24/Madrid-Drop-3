{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}

<style>
  .ph-swiper-{{ section.id }} {
    width: 100%;
    padding: 2rem 0;
    margin-bottom: 2rem;
  }
  .ph-swiper-{{ section.id }} .ph-swiper-slide {
    width: 33%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    opacity: 0; /* Start invisible for animation */
  }
  .ph-product__cart-url{
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .ph-swiper-slide .media-container {
    width: 100%;
    max-width: 350px;
    /* height: 350px;  */
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    aspect-ratio: 1;
  }
  .ph-swiper-slide img,
  .ph-swiper-slide video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ph-swiper-slide h3.ph-product__title {
    margin: 18px 0 0 0;
    text-decoration: none !important;
    font-family: "PhoriaBold";
    font-size: 12px;
    text-transform: uppercase;
  }

  .ph-product__subtitle{
    font-size: 10px;
    text-transform: uppercase;
    margin: 9px 0px 0px 0px;
  }
  
  .ph-swiper-slide .ph-product__price {
    color: #333;
    margin: 18px 0px 0px 0px;
    text-decoration: none !important;
    font-family: "PhoriaBold";
    font-size: 12px;
  }
  .ph-swiper-{{ section.id }} .swiper-button-prev,
  .ph-swiper-{{ section.id }} .swiper-button-next {
    color: black; 
    border-radius: 50%;
    width: 50px !important;
    height: 50px !important;
    display: flex;
    align-items: flex-start;
  }
  .ph-swiper-{{ section.id }} .swiper-button-prev{
    justify-content: flex-start;
  }
  .ph-swiper-{{ section.id }} .swiper-button-next {
    justify-content: flex-end;
  }
  .ph-swiper-{{ section.id }} .swiper-button-prev{
    left: 36px;
    top: 50%;
    transform: translateY(-50%);
  }
  .ph-swiper-{{ section.id }} .swiper-button-next{
    right: 36px;
    top: 50% !important;
    transform: translateY(-50%);
  }
  .swiper-button-prev:not(.swiper-button-disabled):hover{
    transform: translateY(-50%);
  }
  .swiper-button-next:not(.swiper-button-disabled):hover{
    transform: translateY(-50%);
  }
  /* .ph-swiper-{{ section.id }} .swiper-button-prev svg,
.ph-swiper-{{ section.id }} .swiper-button-next svg{
  stroke-width: 2;
} */
  .ph-swiper-{{ section.id }} .swiper-button-prev img,
.ph-swiper-{{ section.id }} .swiper-button-next img{
  width: 30px !important;
  height: 21px !important;
  object-fit: contain;
}

.ph-swiper-{{ section.id }} .swiper-button-prev::after,
.ph-swiper-{{ section.id }} .swiper-button-next::after {
  font-size: 18px;
  color: black; 
}

.slider-heading {
  text-align: center;
  margin-bottom: 1rem;
  font-family: "PhoriaBold";
  font-size: 24px;
  text-transform: uppercase;
  opacity: 0; /* Start invisible for animation */
}

@media screen and (max-width: 989px){
   .ph-swiper-{{ section.id }} .swiper-button-prev,
.ph-swiper-{{ section.id }} .swiper-button-next {
  width: 50px !important;
  height: 50px !important;
}
  .ph-swiper-{{ section.id }} .swiper-button-prev img,
.ph-swiper-{{ section.id }} .swiper-button-next img{
  width: 20px !important;
  height: 14px !important;
}
  .ph-swiper-{{ section.id }} .swiper-button-prev{
    left: 15px;
  }
  .ph-swiper-{{ section.id }} .swiper-button-next{
    right: 15px;
  }
  .ph-swiper-slide h3.ph-product__title, .ph-swiper-slide .ph-product__price{
    font-size: 10px;
  }
}
  @media screen and (max-width: 549px){
    .ph-swiper-slide h3.ph-product__title, .ph-swiper-slide .ph-product__price, .ph-swiper-slide .ph-product__subtitle{
      width: 82vw;
    }
    .ph-swiper-slide img,
    .ph-swiper-slide video{
       width: 82vw;
    }
  }

  .ph-pdp-product-compare-price {
    text-decoration: line-through;
    color: #888;
    font-size: 0.9em;
  }

  .ph-pdp-product-compare-price-code {
    font-family: 'PhoriaBold';
    font-size: 11px;
    span {
      font-size: 14px;
    }
  }

  .mt-0 {
    margin-top: 0 !important;
  }

  .mt-18 {
    margin-top: 18px;
  }
</style>

{% if section.settings.title != blank %}
  <h2 class="slider-heading">{{ section.settings.title }}</h2>
{% endif %}

<div class="ph-product-slider">
  <div class="swiper ph-swiper-{{ section.id }}">
    <div class="swiper-wrapper">
      {% assign products_to_display = '' %}
      
      {% if section.settings.source == 'collection' and collections[section.settings.collection].products.size > 0 %}
        {% assign products_to_display = collections[section.settings.collection].products %}
      {% elsif section.settings.source == 'recommendations' %}
        {% assign products_to_display = recommendations.products %}
      {% endif %}
      
      {% for product in products_to_display %}
        <div class="swiper-slide ph-swiper-slide">
          <a href="{{ product.url }}" class="ph-product__cart-url">
            <div class="media-container">
              {% assign first_media = product.media | first %}
              {% if product.media[0].media_type == 'video' %}
                {{ first_media | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: "ph-product__video" }}
              {% else %}
                <img src="{{ product.featured_image | image_url }}" alt="{{ product.title }}" width="" height="">
              {% endif %}
            </div>
            <h3 class="ph-product__title">{{ product.title }}</h3>
            <p class="ph-product__subtitle">{{ product.metafields.custom.product_information.value }}</p>
            <p class="ph-product__price">{{ product.price | money_without_trailing_zeros }}</p>

          </a>
        </div>
      {% endfor %}
    </div>

    <!-- Navigation Buttons -->
    <div class="swiper-button-prev swiper-button-prev-{{ section.id }}">
      <img src="https://cdn.shopify.com/s/files/1/0891/3541/5562/files/left-arrow-phoria.png" width="" height="">
    </div>
    <div class="swiper-button-next swiper-button-next-{{ section.id }}">
      <img src="https://cdn.shopify.com/s/files/1/0891/3541/5562/files/right-arrow-phoria.png" width="" height="">
    </div>
  </div>
</div>

<!-- Load Swiper JS (Only Once in theme.liquid or main layout) -->
<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    // Check if Motion library is available
    if (typeof Motion !== 'undefined') {
      const { animate, inView, transform } = Motion;
      
      // Animate the heading first
      const heading = document.querySelector('.slider-heading');
      if (heading) {
        inView(heading, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: ["100px", 0] }, 
            { duration: 0.6, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Only animate the initially visible slides based on screen size
      const animateInitialVisibleSlides = () => {
        const sliderItems = document.querySelectorAll('.ph-swiper-{{ section.id }} .ph-swiper-slide');
        const windowWidth = window.innerWidth;
        
        // Determine how many slides to animate based on screen size
        let slidesToAnimate = 1; // Default for mobile
        if (windowWidth >= 1024) {
          slidesToAnimate = 3; // Desktop
        } else if (windowWidth >= 768) {
          slidesToAnimate = 2; // Tablet
        }
        
        // Animate only the initially visible slides
        for (let i = 0; i < slidesToAnimate; i++) {
          if (sliderItems[i]) {
            const delay = i * 0.2; // Stagger delay
            
            animate(sliderItems[i], 
              { opacity: [0, 1], y: ["100px", 0] }, 
              { duration: 0.6, delay: delay, easing: "ease-out" }
            );
          }
        }
        
        // Make all other slides visible immediately (without animation)
        for (let i = slidesToAnimate; i < sliderItems.length; i++) {
          if (sliderItems[i]) {
            sliderItems[i].style.opacity = '1';
            sliderItems[i].style.transform = 'translateY(0)';
          }
        }
      };
      
      // Run the animation function once
      animateInitialVisibleSlides();
    }
    
    // Initialize Swiper
    if (typeof Swiper !== 'undefined') {
      new Swiper('.ph-swiper-{{ section.id }}', {
        loop: true,
        {% if section.settings.autoplay %}
        autoplay: {
          delay: 3000,
          disableOnInteraction: false,
        },
        {% endif %}
        spaceBetween: 20,
        navigation: {
          nextEl: '.swiper-button-next-{{ section.id }}',
          prevEl: '.swiper-button-prev-{{ section.id }}',
        },
        breakpoints: {
          320: { slidesPerView: 1 }, 
          549: { slidesPerView: 2 }, 
          989: { slidesPerView: 3 } 
        }
      });
    } else {
      console.error("Swiper JS is not loaded.");
    }
  });
</script>

{% schema %}
{
  "name": "Ph Product Slider",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "select",
      "id": "source",
      "label": "Product Source",
      "options": [
        {
          "value": "collection",
          "label": "Collection"
        },
        {
          "value": "recommendations",
          "label": "Product Recommendations"
        }
      ],
      "default": "collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Select a collection to display if 'Collection' is chosen as the product source"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Maximum products to display"
    },
    {
      "type": "checkbox",
      "id": "enable_animations",
      "label": "Enable animations",
      "default": true,
      "info": "Enable fade-in animations for initially visible slides only"
    }
  ],
  "presets": [
    {
      "name": "Ph Product Slider",
      "settings": {
        "title": "You may also like",
        "source": "recommendations"
      }
    }
  ]
}
{% endschema %}