<style>
  .ph-size-style-guides-container {
    width: 100%;
    padding: 15vh 36px 0px 36px;
  }
  
  .ph-size-style-guides-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin: 0 auto;
  }
  
  .ph-size-style-guides-heading {
    font-size: 2.266vw;
    text-transform: uppercase;
    word-spacing: 2.3px;
    font-weight: 500;
    width: 100%;
    padding-bottom: .15em;
    margin: 0;
    text-align: right;
  }
  
  .ph-size-style-guides-categories {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    width: 100%;
    gap: 36px;
    padding-top: 15vh;
    height: 70vh;
  }
  
  .ph-size-style-guides-category {
    width: 100%;
    max-width: 394px;
    margin: 0 auto;
    opacity: 0; /* Start invisible for animation */
  }
  
  .ph-size-style-guides-category-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  
  .ph-size-style-guides-image-wrapper,
  .ph-size-style-guides-video-wrapper {
    margin-bottom: 15px;
    position: relative;
    aspect-ratio: 1/1;
    overflow: hidden;
  }

  .ph-size-style-guides-image-wrapper img {
    transition: transform 0.4s ease;
   }

  .ph-size-style-guides-image-wrapper:hover img{
    transform: scale(1.05);
  }
  
  .ph-size-style-guides-image,
  .ph-size-style-guides-video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }
  
  /* Text overlay styling */
  .ph-size-style-guides-category-text {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    z-index: 3;
    background-color: rgba(255, 255, 255, 0);
  }
  
  .ph-size-style-guides-category-title {
    font-size: 1.15vw;
    line-height: 1.2;
    font-weight: normal;
    letter-spacing: 0.00em;
    margin-bottom: 5px;
    text-transform: uppercase;
    color: #1d1d1d;
    text-shadow: 0px 0px 5px rgba(255, 255, 255, 0.8);
  }
  
  .ph-size-style-guides-category-subtitle {
    font-size: 14px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #000;
    text-shadow: 0px 0px 5px rgba(255, 255, 255, 0.8);
  }
  
  .ph-video-cover {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
   
  }
  
  .ph-placeholder-image {
    width: 100%;
    aspect-ratio: 1/1;
    background-color: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #777;
    border: 1px dashed #ccc;
    margin-bottom: 15px;
    position: relative;
  }
  
  @media screen and (max-width: 989px) {
    .ph-size-style-guides-container {
      width: 100%;
      padding: 27vw 18px 0px 18px;
     }

     .ph-size-style-guides-heading {
      font-size: 22px;
    }
    
    .ph-size-style-guides-category-title{
      font-size: 17px;
    }
    .ph-size-style-guides-categories {
      grid-template-columns: repeat(2, 1fr);
      padding-top: 36px;
      height: auto;
    }
  
  @media screen and (max-width: 760px) {
    .ph-size-style-guides-container {
      padding: 78px 18px 0 18px;
    }
    
    .ph-size-style-guides-heading {
      word-spacing: 2.3px;
      margin-bottom: 0px;
      text-align: center;
    }
    
    .ph-size-style-guides-categories {
      gap: 8px;
    }
    
    .ph-size-style-guides-category-title {
      font-size: 16px;
    }
    
    .ph-size-style-guides-category-subtitle {
      font-size: 12px;
    }
  }
  
  @media screen and (max-width: 569px) {
    .ph-size-style-guides-categories {
      grid-template-columns: 1fr;
    }
  }
  @media screen and (max-width: 480px) {
    .ph-size-style-guides-category {
      max-width: 100%;
    }
  }
</style>

<div class="ph-size-style-guides-container">
  <div class="ph-size-style-guides-inner">
    {% if section.settings.heading != blank %}
      <h2 class="ph-size-style-guides-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="ph-size-style-guides-categories">
      {% for block in section.blocks %}
        {% if block.type == 'category' %}
          <div class="ph-size-style-guides-category" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.category_link }}" class="ph-size-style-guides-category-link">
              {% if block.settings.media_type == 'image' %}
                {% if block.settings.category_image != blank %}
                  <div class="ph-size-style-guides-image-wrapper">
                    <img 
                      src="{{ block.settings.category_image | image_url }}" 
                      alt="{{ block.settings.category_title | escape }}" 
                      class="ph-size-style-guides-image"
                      loading="lazy"
                      width="{{ block.settings.category_image.width }}"
                      height="{{ block.settings.category_image.height }}"
                    >
                    
                    <!-- Text overlay positioned absolutely in the center -->
                    <div class="ph-size-style-guides-category-text">
                      {% if block.settings.category_title != blank %}
                        <h3 class="ph-size-style-guides-category-title">{{ block.settings.category_title }}</h3>
                      {% endif %}
                      
                      {% if block.settings.category_subtitle != blank %}
                        <div class="ph-size-style-guides-category-subtitle">{{ block.settings.category_subtitle }}</div>
                      {% endif %}
                    </div>
                  </div>
                {% else %}
                  <div class="ph-placeholder-image">
                    <span>Upload image</span>
                    
                    <!-- Text overlay positioned absolutely in the center -->
                    <div class="ph-size-style-guides-category-text">
                      {% if block.settings.category_title != blank %}
                        <h3 class="ph-size-style-guides-category-title">{{ block.settings.category_title }}</h3>
                      {% endif %}
                      
                      {% if block.settings.category_subtitle != blank %}
                        <div class="ph-size-style-guides-category-subtitle">{{ block.settings.category_subtitle }}</div>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              {% else %}
                {% if block.settings.category_video != blank %}
                  <div class="ph-size-style-guides-video-wrapper">
                    {% if block.settings.video_cover_image != blank %}
                      <img 
                        src="{{ block.settings.video_cover_image | img_url: 'master' }}" 
                        alt="{{ block.settings.category_title | escape }}" 
                        class="ph-video-cover"
                        loading="lazy"
                        width=""
                        height=""
                      >
                    {% endif %}
                    {{ block.settings.category_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: "ph-size-style-guides-video" }}
                    
                    <!-- Text overlay positioned absolutely in the center -->
                    <div class="ph-size-style-guides-category-text">
                      {% if block.settings.category_title != blank %}
                        <h3 class="ph-size-style-guides-category-title">{{ block.settings.category_title }}</h3>
                      {% endif %}
                      
                      {% if block.settings.category_subtitle != blank %}
                        <div class="ph-size-style-guides-category-subtitle">{{ block.settings.category_subtitle }}</div>
                      {% endif %}
                    </div>
                  </div>
                {% else %}
                  <div class="ph-placeholder-image">
                    <span>Upload video</span>
                    
                    <!-- Text overlay positioned absolutely in the center -->
                    <div class="ph-size-style-guides-category-text">
                      {% if block.settings.category_title != blank %}
                        <h3 class="ph-size-style-guides-category-title">{{ block.settings.category_title }}</h3>
                      {% endif %}
                      
                      {% if block.settings.category_subtitle != blank %}
                        <div class="ph-size-style-guides-category-subtitle">{{ block.settings.category_subtitle }}</div>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
              {% endif %}
            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Handle video covers
    const videoWrappers = document.querySelectorAll('.ph-size-style-guides-video-wrapper');
    
    videoWrappers.forEach(function(wrapper) {
      const video = wrapper.querySelector('.ph-size-style-guides-video');
      const cover = wrapper.querySelector('.ph-video-cover');
      
      // Auto-hide cover for autoplay videos
      if (video) {
        // Start playing videos automatically
        video.play().catch(function(error) {
          // Autoplay was prevented by browser
          console.log('Autoplay prevented:', error);
        });
        
        // If video is successfully playing, hide the cover
        video.addEventListener('playing', function() {
          if (cover) {
            cover.style.display = 'none';
          }
        });
      }
    });
    
    // Animation with Motion library
    const { animate, inView, transform } = Motion;
    
    // Animate the heading when it comes into view
    const heading = document.querySelector('.ph-size-style-guides-heading');
    if (heading) {
      // Set initial state
      heading.style.opacity = "0";
      
      inView(heading, (elem) => {
        animate(elem, 
          { opacity: [0, 1], y: [20, 0] }, 
          { duration: 0.6, easing: "ease-out" }
        );
      }, { once: true });
    }
    
    // Animate each category individually when it comes into view
    const categories = document.querySelectorAll('.ph-size-style-guides-category');
    categories.forEach((elem) => {
      inView(elem, (el) => {
        animate(el, 
          { opacity: [0, 1], y: [20, 0] }, 
          { duration: 0.5, easing: "ease-out" }
        );
      }, { once: true });
    });
  });
</script>


{% schema %}
{
  "name": "Size + Style Guides",
  "tag": "section",
  "class": "ph-size-style-guides-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SIZE + STYLE GUIDES"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "enable_animations",
      "label": "Enable animations",
      "default": true,
      "info": "Enable fade-in animations when elements come into view"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Product Category",
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "Media Type",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "video",
              "label": "Video"
            }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "category_image",
          "label": "Category Image",
          "info": "Used when Media Type is set to Image"
        },
        {
          "type": "video",
          "id": "category_video",
          "label": "Category Video",
          "info": "Used when Media Type is set to Video"
        },
        {
          "type": "image_picker",
          "id": "video_cover_image",
          "label": "Video Cover Image (Optional)",
          "info": "Used when Media Type is set to Video"
        },
        {
          "type": "text",
          "id": "category_title",
          "label": "Category Title",
          "default": "CATEGORY"
        },
        {
          "type": "text",
          "id": "category_subtitle",
          "label": "Category Subtitle (Optional)",
          "info": "For subcategories like 'BRACELETS // MODULAR CHAINS'"
        },
        {
          "type": "url",
          "id": "category_link",
          "label": "Category Link"
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Text Overlay Background Color",
          "default": "rgba(255, 255, 255, 0)"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#000000"
        },
        {
          "type": "checkbox",
          "id": "text_shadow",
          "label": "Add text shadow for better visibility",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Size + Style Guides",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "category_title": "RINGS"
          }
        },
        {
          "type": "category",
          "settings": {
            "category_title": "BRACELETS",
            "category_subtitle": "MODULAR CHAINS"
          }
        },
        {
          "type": "category",
          "settings": {
            "category_title": "EARRINGS"
          }
        },
        {
          "type": "category",
          "settings": {
            "category_title": "NECKLACES"
          }
        }
      ]
    }
  ]
}
{% endschema %}