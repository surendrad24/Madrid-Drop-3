<style>
.or-redesignable-feature {
  display: flex;
  width: 100%;
  max-width: 100%;
  margin: 0 auto;
}

.or-redesignable-feature__content {
  width: 50%;
  text-transform: uppercase;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  position: relative;
  padding: 0 36px 72px;
}

/* Media position classes */
.or-redesignable-feature--media-left {
  flex-direction: row;
}

.or-redesignable-feature--media-right {
  flex-direction: row-reverse;
}

.or-redesignable-feature__media {
  width: 50%;
  overflow: hidden;
}

/* Media padding classes based on position */
.or-redesignable-feature--media-left .or-redesignable-feature__media {
  padding-left: 0;
}

.or-redesignable-feature--media-right .or-redesignable-feature__media {
  padding-left: 0;
  padding-left: 36px;
}

.or-redesignable-feature__content--text-left {
  text-align: left;
}

.or-redesignable-feature__content--text-right {
  text-align: right;
  padding-right: 0;
}

.or-redesignable-feature__media img,
.or-redesignable-feature__media video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.or-redesignable-feature__heading {
  font-size: 16px;
  margin: 0 0 20px 0;
  padding-top: 37px;
  word-spacing: 2px;
  font-weight: 500;
}

.or-redesignable-feature__richtext {
  font-size: 10px;
  line-height: 2.3;
  margin-top: 18px;
  margin-bottom: 0;
}

.or-redesignable-feature__richtext p {
  font-size: 10px;
  line-height: 2.3;
  margin-top: 0;
  margin-bottom: 18px;
}

.or-redesignable-feature__richtext p:last-child {
  margin-bottom: 0;
}

.or-redesignable-feature__button-container {
  margin-top: 36px;
  /* Will inherit the text alignment from parent */
}

.or-redesignable-feature__button {
  display: inline-block;
  padding: 13px 31px;
  color: #ffffff;
  text-decoration: none;
  font-size: 12px;
  line-height: 2.3;
  font-weight: 800;
}

@media screen and (max-width: 1020px) {
  .or-redesignable-feature__heading {
  font-size: 16px;
  margin: 0 0 9px 0;
  padding-top: 0;
  word-spacing: 2px;
  font-weight: 500;
}
  
  .or-redesignable-feature,
  .or-redesignable-feature--media-left,
  .or-redesignable-feature--media-right {
    flex-direction: column;
  }
  
  .or-redesignable-feature__media,
  .or-redesignable-feature__content {
    width: 100%;
  }

  /* Reset position-based padding for mobile */
  .or-redesignable-feature--media-left .or-redesignable-feature__media,
  .or-redesignable-feature--media-right .or-redesignable-feature__media {
    padding-left: 0;
    padding-right: 0;
  }

 
  .or-redesignable-feature__media {
    padding: 0px;
  }
  
  .or-redesignable-feature__content {
    padding: 36px 18px 72px;
  }
}
</style>

{% for block in section.blocks %}
  <div id="{{ block.settings.heading | handleize }}"></div>
{% endfor %}

<div id="or-redesignable-feature" class="or-redesignable-feature or-redesignable-feature--media-{{ section.settings.media_position }}" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div id="or-redesignable-feature-media" class="or-redesignable-feature__media">
    {% if section.settings.media_type == 'video' and section.settings.video != blank %}
      <video playsinline autoplay muted loop>
        <source src="{{ section.settings.video | video_tag }}">
      </video>
    {% else %}
      {% if section.settings.image != blank %}
        <img src="{{ section.settings.image | img_url: 'master' }}" alt="{{ section.settings.image.alt | escape }}">
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    {% endif %}
  </div>
  
  <div id="or-redesignable-feature-content" class="or-redesignable-feature__content or-redesignable-feature__content--text-{{ section.settings.text_alignment }}">
    {% for block in section.blocks %}
      {% case block.type %}
        
        {% when 'heading' %}
          {% if block.settings.heading != blank %}
            <h2 class="or-redesignable-feature__heading" {{ block.shopify_attributes }}>
              {{ block.settings.heading }}
            </h2>
          {% endif %}
        
        {% when 'richtext' %}
          {% if block.settings.content != blank %}
            <div id="{{ block.settings.content | strip | truncatewords: 5, '' | handleize }}" class="or-redesignable-feature__richtext" {{ block.shopify_attributes }}>
              {{ block.settings.content }}
            </div>
          {% endif %}
        
        {% when 'button' %}
          {% if block.settings.button_text != blank %}
            <div id="or-redesignable-feature-button-container" class="or-redesignable-feature__button-container" {{ block.shopify_attributes }}>
              <a id="{{ block.settings.button_text | handleize }}" href="{{ block.settings.button_link }}" 
                 class="or-redesignable-feature__button"
                 style="background-color: {{ block.settings.button_bg_color }}; color: {{ block.settings.button_text_color }}">
                {{ block.settings.button_text }}
              </a>
            </div>
          {% endif %}
          
      {% endcase %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Or-Image-text",
  "tag": "section",
  "class": "or-redesignable-feature-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout Options"
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Media Position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "info": "Position of the image/video relative to the text"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "info": "Align the text within the content area"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Upload an image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "info": "Upload a video"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading Text",
          "default": "DESIGNED TO BE REDESIGNED //"
        }
      ]
    },
    {
      "type": "richtext",
      "name": "Rich Text",
      "limit": 8,
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>THE RANGE IS MADE UP OF THE ULTIMATE STAPLES – DESIGNED TO BE REDESIGNED. WITH A SIMPLE YET POWERFUL AESTHETIC, AND AN URBAN-INDUSTRIAL EDGE.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "FIND OUT MORE"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Button Background Color",
          "default": "#1a1a1a"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button Text Color",
          "default": "#FFFFFF"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Or-Image-text",
      "category": "Custom Content",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "richtext"
        },
        {
          "type": "richtext"
        }
      ]
    }
  ]
}
{% endschema %}