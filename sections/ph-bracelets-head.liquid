<style>
  .ph-modular-bracelets-container {
    width: 100%;
    max-width: 80vw;
    margin: 0 auto;
    padding-top: 60px;
  }
  
  .ph-modular-bracelets-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 20px;
  }
  
  .ph-modular-bracelets-heading {
    font-size: 2.266vw;
    margin-bottom: 30px;
    text-transform: uppercase;
    font-weight: 500;
    width: 100%;
  }
  
  .ph-modular-bracelets-description {
    font-size: 10px;
    line-height: 2.3;
    text-transform: uppercase;
    max-width: 900px;
    letter-spacing: 0;
  }
  
  .ph-modular-bracelets-content {
    width: 100%;
  }
  
  .ph-modular-bracelets-media {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 36px;
  }
  
  .ph-modular-media-item {
    flex: 1;
    max-width: 640px;
  }
  
  .ph-video-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 100%; /* 1:1 Aspect Ratio */
    overflow: hidden;
  }
  
  .ph-instruction-wrapper {
    width: 100%;
  }
  
  .ph-video-element {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    cursor: pointer;
  }
  
  .ph-video-cover {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  
  .ph-instruction-image {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .ph-video-play-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    background: rgba(0, 0, 0, 0.5);
    border: none;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    cursor: pointer;
    transition: background 0.3s ease;
  }
  
  .ph-video-play-button:hover {
    background: rgba(0, 0, 0, 0.7);
  }
  
  .ph-placeholder-media {
    width: 100%;
    aspect-ratio: 1/1;
    background-color: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #777;
    border: 1px dashed #ccc;
  }
  
  @media screen and (max-width: 989px) {
    .ph-modular-bracelets-inner {
      padding: 0;
    }
    .ph-modular-bracelets-container {
      padding-left: 15px;
      padding-right: 15px;
      max-width: none;
    }
    
    .ph-modular-bracelets-heading {
      font-size: 22px;
      margin-bottom: 20px;
    }
    
    .ph-modular-bracelets-media {
      flex-direction: column;
      align-items: center;
    }
    
    .ph-modular-media-item {
      max-width: 100%;
      width: 100%;
    }
    
    .ph-video-play-button {
      width: 50px;
      height: 50px;
    }
  }
</style>

<div class="ph-modular-bracelets-container">
  <div class="ph-modular-bracelets-inner">
    {% if section.settings.heading != blank %}
      <h2 class="ph-modular-bracelets-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.description != blank %}
      <div class="ph-modular-bracelets-description">{{ section.settings.description }}</div>
    {% endif %}
    
    <div class="ph-modular-bracelets-content">
      <!-- Products Display Area -->
      <div class="ph-modular-bracelets-media">
        <!-- Left Side (Video) -->
        <div class="ph-modular-media-item ph-media-item-video">
          {% if section.settings.product_video != blank %}
            <div class="ph-video-wrapper">
              {% if section.settings.video_cover_image != blank %}
                <img 
                  src="{{ section.settings.video_cover_image | img_url: 'master' }}" 
                  alt="Modular bracelet video cover" 
                  class="ph-video-cover"
                  loading="lazy"
                >
              {% endif %}
              
              {{ section.settings.product_video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: "ph-video-element" }}
            </div>
          {% else %}
            <div class="ph-placeholder-media">
              <span>Upload product video</span>
            </div>
          {% endif %}
        </div>
        
        <!-- Right Side (Instruction Illustration) -->
        <div class="ph-modular-media-item ph-media-item-image">
          {% if section.settings.instruction_image != blank %}
            <div class="ph-instruction-wrapper">
              <img 
                src="{{ section.settings.instruction_image | img_url: 'master' }}" 
                alt="How to connect modular bracelets" 
                class="ph-instruction-image"
                loading="lazy"
                width="{{ section.settings.instruction_image.width }}"
                height="{{ section.settings.instruction_image.height }}"
              >
            </div>
          {% else %}
            <div class="ph-placeholder-media">
              <span>Upload instruction illustration</span>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof Motion !== 'undefined' && {{ section.settings.enable_animations | default: true }}) {
      const { animate, inView } = Motion;
      
      // Animate container
      const container = document.querySelector('.ph-modular-bracelets-container');
      if (container) {
        inView(container, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate heading
      const heading = document.querySelector('.ph-modular-bracelets-heading');
      if (heading) {
        inView(heading, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.2, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate description
      const description = document.querySelector('.ph-modular-bracelets-description');
      if (description) {
        inView(description, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.4, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate media items
      const videoItem = document.querySelector('.ph-media-item-video');
      const imageItem = document.querySelector('.ph-media-item-image');
      
      if (videoItem) {
        inView(videoItem, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [30, 0] }, 
            { duration: 0.6, delay: 0.6, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      if (imageItem) {
        inView(imageItem, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [30, 0] }, 
            { duration: 0.6, delay: 0.8, easing: "ease-out" }
          );
        }, { once: true });
      }
    }
  });
</script>

{% schema %}
{
  "name": "Ph Bracelets Head",
  "tag": "section",
  "class": "ph-modular-bracelets-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "MODULAR BRACELETS"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "WEAR YOUR BRACELET ALONE, OR CONNECT TO ANY OF OUR BRACELET CHAINS USING OUR MODULAR CARABINER CLASPS, TO BUILD YOUR CUSTOMISED NECKLACE."
    },
    {
      "type": "header",
      "content": "Media Content"
    },
    {
      "type": "video",
      "id": "product_video",
      "label": "Product Video (Left)"
    },
    {
      "type": "image_picker",
      "id": "video_cover_image",
      "label": "Video Cover Image (optional)"
    },
    {
      "type": "image_picker",
      "id": "instruction_image",
      "label": "Instruction Illustration (Right)"
    },
    {
      "type": "checkbox",
      "id": "enable_animations",
      "label": "Enable Animations",
      "default": true,
      "info": "Enable fade-in animations when content comes into view"
    }
  ],
  "presets": [
    {
      "name": "Ph Bracelets Head"
    }
  ]
}
{% endschema %}