<style>
  .ph-size-combinations-container {
    width: 100%;
    max-width: 80vw;
    margin: 0 auto;
    padding-top: 90px; 
  }
  
  .ph-size-combinations-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin: 0 auto;
    padding: 0 36px;
  }
  
  .ph-size-combinations-heading {
    font-size: 1.25vw;
    letter-spacing: 0.1em;
    margin-bottom: 18px;
    text-transform: uppercase;
    font-weight: 500;
    width: 100%;
  }
  
  .ph-size-combinations-description {
    font-size: 10px;
    line-height: 2.3;
    margin-bottom: 36px;
    text-transform: uppercase;
    max-width: 900px;
  }
  
  .ph-size-combinations-description p {
    margin-bottom: 20px;
  }
  
  .ph-size-combinations-description p:last-child {
    margin-bottom: 0;
  }
  
  .ph-size-combinations-table-wrapper {
    width: 100%;
    overflow-x: auto;
    max-width: 900px;
  }
  
  .ph-size-combinations-table {
    width: 100%;
    border-collapse: collapse;
  }
  
  .ph-size-combinations-header {
    background-color: #D5D5D5;
    color: #000;
    padding: 18px;
    text-align: center;
    font-size: 10px;
    text-transform: uppercase;
    font-weight: 500;
    font-family: "PhoriaBold";
    border: 1px solid #f1f2ee;
    width: 33%;
    line-height: 2.3;
  }
  
  .ph-size-combinations-category-row {
    background-color: #f2f2f2;
  }
  
  .ph-size-combinations-category-cell {
    padding: 18px;
    text-align: center;
    font-size: 10px;
    text-transform: uppercase;
    font-weight: 500;
    font-family: "PhoriaBold";
    background: #f1f2ee;
    line-height: 2.3;
  }
  
  .ph-size-combinations-row {
    border-bottom: 1px solid #eee;
  }
  
  .ph-size-combinations-row:nth-child(odd):not(.ph-size-combinations-category-row) {
    background-color: #fafafa;
  }
  
  .ph-size-combinations-cell {
    padding: 18px;
    text-align: center;
    font-size: 10px;
    text-transform: uppercase;
    border: 1px solid #f1f2ee;
    line-height: 2.3;
    font-weight: 600;
  }
  
  @media screen and (max-width: 989px) {
    .ph-size-combinations-container {
      padding-left: 18px;
      padding-right: 18px;
      max-width: none;
    }
    .ph-size-combinations-inner{
      padding: 0;
    }
    
    .ph-size-combinations-heading {
      font-size: 18px;
      margin-bottom: 30px;
    }
    
    .ph-size-combinations-description {
      margin-bottom: 30px;
    }
    
    .ph-size-combinations-header,
    .ph-size-combinations-category-cell,
    .ph-size-combinations-cell {
      padding: 9px 5px;
    }
  }
  @media screen and (max-width: 549px){
    .ph-size-combinations-header{
      width: auto;
    }
  }
</style>

<div class="ph-size-combinations-container">
  <div class="ph-size-combinations-inner">
    {% if section.settings.heading != blank %}
      <h2 class="ph-size-combinations-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.description != blank %}
      <div class="ph-size-combinations-description">
        {% assign paragraphs = section.settings.description | split: "\n\n" %}
        {% for paragraph in paragraphs %}
          <p>{{ paragraph }}</p>
        {% endfor %}
      </div>
    {% endif %}
    
    <div class="ph-size-combinations-table-wrapper">
      <table class="ph-size-combinations-table">
        <thead>
          <tr>
            <th class="ph-size-combinations-header">{{ section.settings.table_heading_1 }}</th>
            <th class="ph-size-combinations-header">{{ section.settings.table_heading_2 }}</th>
            <th class="ph-size-combinations-header">{{ section.settings.table_heading_3 }}</th>
          </tr>
        </thead>
        <tbody>
          {% assign current_category = '' %}
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'category_heading' %}
                <tr class="ph-size-combinations-category-row" {{ block.shopify_attributes }}>
                  <td colspan="3" class="ph-size-combinations-category-cell">{{ block.settings.category_name }}</td>
                </tr>
                {% assign current_category = block.settings.category_name %}
              {% when 'size_row' %}
                <tr class="ph-size-combinations-row" {{ block.shopify_attributes }}>
                  <td class="ph-size-combinations-cell">{{ block.settings.combination }}</td>
                  <td class="ph-size-combinations-cell">{{ block.settings.length_cm }}</td>
                  <td class="ph-size-combinations-cell">{{ block.settings.length_inches }}</td>
                </tr>
            {% endcase %}
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof Motion !== 'undefined' && {{ section.settings.enable_animations | default: true }}) {
      const { animate, inView } = Motion;
      
      // Animate container
      const container = document.querySelector('.ph-size-combinations-container');
      if (container) {
        inView(container, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate heading
      const heading = document.querySelector('.ph-size-combinations-heading');
      if (heading) {
        inView(heading, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.2, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate description
      const description = document.querySelector('.ph-size-combinations-description');
      if (description) {
        inView(description, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.4, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate table wrapper
      const tableWrapper = document.querySelector('.ph-size-combinations-table-wrapper');
      if (tableWrapper) {
        inView(tableWrapper, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [30, 0] }, 
            { duration: 0.6, delay: 0.6, easing: "ease-out" }
          );
        }, { once: true });
      }
    }
  });
</script>

