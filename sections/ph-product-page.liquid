<script>
   document.addEventListener("DOMContentLoaded", function () {
    const addToCartButton = document.getElementById("dynamic-button");  // Add to cart button
    const lowStockMessage = document.getElementById('low-in-stock');  // Element to display low stock message

    const variantInput = document.querySelector('input[name="id"]');  // Variant input field

    // Fetch product variants and inventory data
    const variants = [
      {% for variant in product.variants %}
        {
          id: {{ variant.id }},
          title: {{ variant.title | json }},
          inventory_quantity: {{ variant.inventory_quantity | json }}  // Fetch inventory quantity
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];

    console.log("variants", variants);

    // Function to update the "Low In Stock" message and button text
    function updateLowStock() {
      const variantId = parseInt(variantInput.value);  // Get selected variant ID
      const selectedVariant = variants.find(v => v.id === variantId);  // Find the selected variant

      console.log("adddd sv", selectedVariant)


      if (!selectedVariant || !addToCartButton) return;  // If variant or button is missing, exit

      const inv = selectedVariant.inventory_quantity;  // Get inventory quantity of the selected variant
      console.log("Inventory Quantity:", inv);

      // Show "Low In Stock" message if inventory is less than 5
      if (inv < 5 &&  inv > 0) {
        lowStockMessage.style.display = 'inline';  // Display the low stock message
        lowStockMessage.innerText = `LOW IN STOCK`;  // Show how many are left
      } else {
        lowStockMessage.style.display = 'none';  // Hide the low stock message if inventory is sufficient
      }

      // Optionally, disable the add to cart button if stock is zero
      if (inv <= 0) {
        addToCartButton.disabled = true;
        addToCartButton.innerText = "Out of Stock";
      } else {
        addToCartButton.disabled = false;
        addToCartButton.innerText = "Add to Cart";
      }
    }

    // Initial call to update the stock status when the page loads
    updateLowStock();

    // Watch for changes in the variant input field (e.g., when the user selects a different variant)
    const observer = new MutationObserver(updateLowStock);
    observer.observe(variantInput, {
      attributes: true,
      attributeFilter: ['value']  // Watch for changes in the selected variant
    });

    // Also listen to change event (some themes might trigger changes like this)
    variantInput.addEventListener('change', updateLowStock);
  });
</script>

<script>
(function () {
  'use strict';

  /* =========================
     CONFIG
  ========================== */
  const FORM_WRAPPER_SEL       = '.klaviyo-form-VL9sCq';  // Klaviyo embed container inside the modal
  const KLAVIYO_NAME_FIELD_ID  = 'Unique_ID_01K7NR7JFRPY5EBKV6ER4DA8RE'; // optional: product name field id in Klaviyo
  const KLAVIYO_SKU_FIELD_ID   = '';   // optional: SKU field id in Klaviyo (leave blank to auto-detect or inject hidden)
  const MAKE_NAME_READONLY     = true; // lock visible Product Name field if present
  const MAKE_SKU_READONLY      = true; // lock visible SKU field if present
  const FORCE_HIDE_VISIBLE_SKU = true; // force-hide any visible SKU input in the Klaviyo form

  // If product has this tag and you treat it as purchasable even when qty <= 0,
  // keep Add-to-Cart visible and DO NOT show Notify.
  const RESPECT_PREORDER_TAG   = true;
  const PREORDER_TAG_HANDLE    = 'custom-pre-order';
  const FORCE_ADD_TO_BASKET_TAG = 'force-add-to-basket';

  // Optional: if you want to consider tracked qty <= 0 as OOS even when available === true,
  // turn this on. Default false to avoid false positives when tracking is disabled.
  const USE_QTY_GATE           = false;

  /* =========================
     LIQUID DATA
  ========================== */
  const PRODUCT_NAME  = {{ product.title | json }};
  const VARIANTS      = {{ product.variants | json }};
  const PRODUCT_TAGS  = {{ product.tags | json }};

  /* =========================
     DOM REFS
  ========================== */
  const notifyBtn  = document.getElementById('notify-button');
  const addBtn     = document.querySelector('.ph-pdp-add-to-cart-button');
  const stickyBtn  = document.getElementById('phStickyAddToCart');
  const stickyBar  = document.getElementById('phStickyBar');
  const modal      = document.getElementById('phBISModal');
  const backdrop   = modal ? modal.querySelector('.ph-bis-backdrop') : null;
  const closeBtns  = modal ? modal.querySelectorAll('[data-ph-bis-close]') : [];

  if (!notifyBtn || !modal || !addBtn) return;

  /* =========================
     UTILITIES
  ========================== */
  function injectA11yCSSOnce() {
    if (document.getElementById('ph-visually-hidden-style')) return;
    const style = document.createElement('style');
    style.id = 'ph-visually-hidden-style';
    style.textContent = `
      .visually-hidden {
        position: absolute !important;
        width: 1px; height: 1px;
        margin: -1px; padding: 0; border: 0;
        clip: rect(0 0 0 0); clip-path: inset(50%);
        overflow: hidden; white-space: nowrap;
      }
    `;
    document.head.appendChild(style);
  }
  injectA11yCSSOnce();

  function cssEscapeSafe(id){ try { return CSS.escape(id); } catch(e) { return id; } }

  function getSelectedVariantId() {
    const idInput = document.querySelector('input[name="id"]');
    return idInput ? Number(idInput.value) : null;
  }
  function getSelectedVariant() {
    const id = getSelectedVariantId();
    return VARIANTS.find(v => v && Number(v.id) === id);
  }
  function isPreorderProduct() {
    return RESPECT_PREORDER_TAG && Array.isArray(PRODUCT_TAGS) && PRODUCT_TAGS.includes(PREORDER_TAG_HANDLE);
  }
  function hasForceAddToBasketTag() {
    return Array.isArray(PRODUCT_TAGS) && PRODUCT_TAGS.map((tag) => String(tag).toLowerCase()).includes(FORCE_ADD_TO_BASKET_TAG);
  }
  function trackedQty(v){
    if (!v) return null;
    // If Shopify is tracking inventory, v.inventory_management is usually 'shopify'
    return v.inventory_management ? Number(v.inventory_quantity || 0) : null;
  }
  function isVariantOOS(v) {
    if (!v) return false;                 // no variant -> don't flip UI
    if (isPreorderProduct()) return false; // preorder products treated as available for purchase
    // Primary source of truth: Shopify availability
    let oos = !v.available;
    // Optional stricter check: treat qty<=0 as OOS when tracking is enabled
    if (USE_QTY_GATE) {
      const q = trackedQty(v);
      if (q !== null) oos = oos || (q <= 0);
    }
    return oos;
  }
  function currentDisplayName() {
    const picked = [];
    document.querySelectorAll('[data-option-index]').forEach(c => {
      const idx = c.getAttribute('data-option-index');
      const val = document.getElementById(`Option${idx}`)?.value || '';
      if (val) picked[idx] = val;
    });
    const opt = picked.filter(Boolean).join(' / ');
    return opt ? (PRODUCT_NAME + ' – ' + opt) : PRODUCT_NAME;
  }

  /* =========================
     NOTIFY vs ADD VISIBILITY
  ========================== */
  window.__phStickyMode = () => stickyBtn?.dataset?.mode || 'add';

  function applyStockVisibility() {
    const v = getSelectedVariant();

    // Primary: variant.available; fallback to button state (theme may update text/disabled later)
    const oosByVariant = v ? isVariantOOS(v) : false;
    const oosByUI = /out\s*of\s*stock/i.test((addBtn.textContent || '')) || !!addBtn.disabled;

    // Respect preorder tag: never show Notify if preorder product
    const oos =  (oosByVariant || oosByUI);

    // Show only Notify when OOS; otherwise show Add-to-Cart (and sticky add)
    notifyBtn.classList.toggle('hidden', !oos);
    addBtn.classList.toggle('hidden',   oos);

    // Keep sticky visible; change its mode + label instead
    if (stickyBtn) {
  if (oos) {
    stickyBtn.disabled = false;
    stickyBtn.textContent = 'OUT OF STOCK - Notify me';
    stickyBtn.style.opacity = '1';
    stickyBtn.dataset.mode = 'notify';
  } else {
    const disabled = !!addBtn.disabled;
    stickyBtn.disabled = disabled;
    stickyBtn.style.opacity = disabled ? '0.65' : '1';
    stickyBtn.textContent = (isPreorderProduct() && !hasForceAddToBasketTag() ? 'PRE-ORDER' : 'ADD TO BASKET');
    stickyBtn.dataset.mode = 'add';
  }
}


    // make sure Notify is interactable when shown
    if (oos) { notifyBtn.disabled = false; notifyBtn.style.pointerEvents = 'auto'; }
  }

  // Initial + react to Add button mutations (some themes rewrite text/state)
  applyStockVisibility();
  new MutationObserver(applyStockVisibility).observe(addBtn, {
    attributes: true, attributeFilter: ['disabled', 'class'],
    childList: true, subtree: true
  });

  // React to variant changes (hidden input id)
  const idEl = document.querySelector('input[name="id"]');
  const onVariantChange = () => {
    applyStockVisibility();
    if (modal.classList.contains('is-open')) pushCurrentToForm();
  };
  if (idEl) {
    new MutationObserver(onVariantChange).observe(idEl, { attributes: true, attributeFilter: ['value'] });
    idEl.addEventListener('change', onVariantChange);
  }

  // Piggyback your existing variant hook if present
  const prevUpdate = window.updateVariantSelection;
  window.updateVariantSelection = function () {
    if (typeof prevUpdate === 'function') prevUpdate();
    onVariantChange();
  };

  /* =========================
     MODAL OPEN/CLOSE + FOCUS
  ========================== */
  const focusablesSel = 'a[href],button,textarea,input,select,[tabindex]:not([tabindex="-1"])';
  let lastActive = null;

  function openModal() {
    lastActive = document.activeElement;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    notifyBtn.setAttribute('aria-expanded', 'true');

    // lock body + hide sticky bar
    document.body.style.overflow = 'hidden';
    if (stickyBar) stickyBar.classList.add('is-hidden');

    const dialog = modal.querySelector('.ph-bis-dialog') || modal;
    if (!dialog.hasAttribute('tabindex')) dialog.setAttribute('tabindex', '-1');
    // focus first focusable
    const first = modal.querySelector(focusablesSel) || dialog;
    setTimeout(() => first.focus(), 0);

    // ensure form gets current data
    pushCurrentToForm();
  }
  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    notifyBtn.setAttribute('aria-expanded', 'false');

    document.body.style.overflow = '';
    if (stickyBar) stickyBar.classList.remove('is-hidden');

    (lastActive || notifyBtn).focus?.({ preventScroll: true });
  }

  notifyBtn.addEventListener('click', (e) => { e.preventDefault(); openModal(); });
  backdrop?.addEventListener('click', closeModal);
  closeBtns.forEach(el => el.addEventListener('click', closeModal));
  document.addEventListener('keydown', (e) => {
    if (!modal.classList.contains('is-open')) return;
    if (e.key === 'Escape') { e.preventDefault(); closeModal(); return; }
    if (e.key === 'Tab') {
      const dialog = modal.querySelector('.ph-bis-dialog') || modal;
      const nodes  = dialog.querySelectorAll(focusablesSel);
      if (!nodes.length) return;
      const first = nodes[0], last = nodes[nodes.length - 1];
      if (e.shiftKey && document.activeElement === first) { last.focus(); e.preventDefault(); }
      else if (!e.shiftKey && document.activeElement === last) { first.focus(); e.preventDefault(); }
    }
  }, { passive: false });

  /* =========================
     KLAVIYO FIELD PREFILL + HIDE SKU
  ========================== */
  function findFormEl() {
    return modal.querySelector(`${FORM_WRAPPER_SEL} form`) ||
           modal.querySelector(FORM_WRAPPER_SEL);
  }
  function ensureHiddenProp(key, value) {
    const form = findFormEl();
    if (!form) return false;
    const name = `properties[${key}]`;
    let input = form.querySelector(`input[name="${name}"]`);
    if (!input) {
      input = document.createElement('input');
      input.type = 'hidden';
      input.name = name;
      form.appendChild(input);
    }
    if (String(input.value) !== String(value)) input.value = value;
    return true;
  }
  function lockInput(input) {
    if (!input) return;
    input.readOnly = true;
    input.setAttribute('readonly','');
    input.setAttribute('aria-readonly','true');
    const block = (e)=>{ e.preventDefault(); };
    ['beforeinput','keydown','paste','drop'].forEach(evt => input.addEventListener(evt, block));
    input.style.caretColor = 'transparent';
  }
  function hideInput(input) {
    if (!input) return;
    input.removeAttribute('required');
    // Prefer native hiding
    try { input.type = 'hidden'; }
    catch(e) {
      // If type flip not allowed (e.g. non-text input), visually hide
      input.classList.add('visually-hidden');
      input.tabIndex = -1;
      // Hide its label if tied by for=ID
      if (input.id) {
        const label = input.form && input.form.querySelector(`label[for="${cssEscapeSafe(input.id)}"]`);
        if (label) label.classList.add('visually-hidden');
      }
    }
  }
  function setInputEl(input, val, makeReadOnly, alsoHide = false) {
    if (!input) return false;
    if (String(input.value) !== String(val)) {
      input.value = val;
      input.dispatchEvent(new Event('input', { bubbles:true }));
      input.dispatchEvent(new Event('change',{ bubbles:true }));
    }
    if (makeReadOnly) lockInput(input);
    if (alsoHide && FORCE_HIDE_VISIBLE_SKU) hideInput(input);
    return true;
  }
  function setByIdInForm(id, val, makeReadOnly, alsoHide = false) {
    if (!id) return false;
    const form = findFormEl();
    if (!form) return false;
    const el = form.querySelector('#' + cssEscapeSafe(id));
    return setInputEl(el, val, makeReadOnly, alsoHide);
  }
  function findInputLike(re) {
    const root = findFormEl();
    if (!root) return null;
    const nodes = root.querySelectorAll('input, textarea, select');
    for (const el of nodes) {
      const hay = [
        el.id||'', el.name||'', el.placeholder||'', el.getAttribute('aria-label')||''
      ].join(' ').toLowerCase();
      if (re.test(hay)) return el;
    }
    return null;
  }
  function setKlaviyoName(val) {
    if (KLAVIYO_NAME_FIELD_ID && setByIdInForm(KLAVIYO_NAME_FIELD_ID, val, MAKE_NAME_READONLY, false)) return true;
    const guessed = findInputLike(/\b(product|item)\b.*\b(name|title)\b|\bproduct name\b/);
    if (setInputEl(guessed, val, MAKE_NAME_READONLY, false)) return true;
    return ensureHiddenProp('Product', val);
  }

  // *** FULL SKU HANDLING (prefill + hide + hidden fallback) ***
  function setKlaviyoSku(val) {
    // 1) If you have a fixed field ID, set it, make it read-only, and hide it
    if (KLAVIYO_SKU_FIELD_ID &&
        setByIdInForm(KLAVIYO_SKU_FIELD_ID, val, MAKE_SKU_READONLY, true)) {
      return true;
    }

    // 2) Otherwise, guess a visible SKU input, set it, make it read-only, and hide it
    const guessed = findInputLike(/\bsku\b/);
    if (setInputEl(guessed, val, MAKE_SKU_READONLY, true)) {
      return true;
    }

    // 3) Robust fallback: always ensure hidden properties[SKU]
    return ensureHiddenProp('SKU', val);
  }

  function whenFormReady(fn, timeoutMs = 8000) {
    if (fn()) return;
    const obs = new MutationObserver(() => { if (fn()) obs.disconnect(); });
    obs.observe(modal, { childList: true, subtree: true });
    setTimeout(() => obs.disconnect(), timeoutMs);
  }
  function pushCurrentToForm() {
    const v   = getSelectedVariant();
    const sku = (v && v.sku) ? v.sku : '';
    const url = (v && v.id) ? (location.origin + location.pathname + `?variant=${v.id}`) : location.href;

    // visible fields (if present)
    whenFormReady(() => setKlaviyoName(currentDisplayName()));
    whenFormReady(() => setKlaviyoSku(sku));

    // robust hidden props (always set)
    whenFormReady(() => ensureHiddenProp('SKU', sku));
    whenFormReady(() => ensureHiddenProp('Variant ID', v ? String(v.id) : ''));
    whenFormReady(() => ensureHiddenProp('Variant Title', v ? (v.title || '') : ''));
    whenFormReady(() => ensureHiddenProp('Product', PRODUCT_NAME));
    whenFormReady(() => ensureHiddenProp('Product URL', url));
  }

  // Also run when Notify is clicked (form might render right after open)
  notifyBtn.addEventListener('click', () => setTimeout(pushCurrentToForm, 0), { passive: true });

})();
</script>


