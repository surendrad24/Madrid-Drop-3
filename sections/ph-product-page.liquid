function formatMoney(cents, currency, locale = 'en') {
  if (isNaN(cents) || cents === null) {
    return '0';
  }
  
  const amount = cents / 100;
  
  // Format with currency but remove decimal part completely
  let formatted = new Intl.NumberFormat(locale, { 
    style: 'currency', 
    currency: currency,
    minimumFractionDigits: 0,  // No minimum decimal places
    maximumFractionDigits: 0   // No maximum decimal places (was typo: had extra space)
  }).format(amount);
  
  return formatted;
}
