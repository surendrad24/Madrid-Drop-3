<script>
document.addEventListener('DOMContentLoaded', function() {
  // Start animations
  if (typeof Motion !== 'undefined') {
    const { animate, inView, transform } = Motion;
    
    // Animate product container
    const productContainer = document.querySelector('.ph-pdp-product-container');
    if (productContainer) {
      inView(productContainer, (elem) => {
        animate(elem, 
          { opacity: [0, 1], y: [20, 0] }, 
          { duration: 0.8, easing: "ease-out" }
        );
      }, { once: true });
    }
    
    // Animate product title
    const productTitle = document.querySelector('.ph-pdp-product-title');
    if (productTitle) {
      inView(productTitle, (elem) => {
        animate(elem, 
          { opacity: [0, 1], y: [20, 0] }, 
          { duration: 0.6, delay: 0.2, easing: "ease-out" }
        );
      }, { once: true });
    }
    
    // Animate product description wrapper
    const descriptionWrapper = document.querySelector('.ph-pdp-product-description-wrapper');
    if (descriptionWrapper) {
      inView(descriptionWrapper, (elem) => {
        animate(elem, 
          { opacity: [0, 1], y: [20, 0] }, 
          { duration: 0.6, delay: 0.4, easing: "ease-out" }
        );
      }, { once: true });
    }
    
    // Animate the rest of the product details as a whole
    const productDetailsAnimate = document.querySelector('.ph-pdp-product-details--animate');
    if (productDetailsAnimate) {
      inView(productDetailsAnimate, (elem) => {
        animate(elem, 
          { opacity: [0, 1], y: [20, 0] }, 
          { duration: 0.6, delay: 0.6, easing: "ease-out" }
        );
      }, { once: true });
    }
  }
  
  const variants = {{ product.variants | json }};
  const defaultProductTitle = {{ product.title | json }};
  const defaultProductInfo = {{ product.metafields.custom.product_information | default: '' | strip | json }};
  const variantTitleRulesRaw = {{ product.metafields.custom.varient_title_rules.value | default: product.metafields.custom.varient_title_rules | json }};
  const variantExtraInfoRulesRaw = {{ product.metafields.custom.varient_extrainfo_rules.value | default: product.metafields.custom.varient_extrainfo_rules | json }};
  const variantMatchRulesRaw = {{ product.metafields.custom.varient_match_rules.value | default: product.metafields.custom.varient_match_rules | json }};

  function parseVariantRules(rawRules) {
    if (!rawRules) return null;
    if (typeof rawRules === 'string') {
      const trimmed = rawRules.trim();
      if (!trimmed) return null;
      try {
        return JSON.parse(trimmed);
      } catch (error) {
        return null;
      }
    }
    return rawRules;
  }

  function normalizeRuleToken(value) {
    return String(value || '').trim().toLowerCase();
  }

  function getVariantMatchPool(selectedVariant) {
    const optionValues = Array.isArray(selectedVariant?.options) ? selectedVariant.options : [];
    const normalizedOptions = optionValues.map(normalizeRuleToken).filter(Boolean);
    const normalizedTitle = normalizeRuleToken(selectedVariant?.title || '');
    return { normalizedOptions, normalizedTitle };
  }

  function matchesToken(token, matchPool) {
    const normalizedToken = normalizeRuleToken(token);
    if (!normalizedToken) return false;

    if (matchPool.normalizedOptions.includes(normalizedToken)) {
      return true;
    }

    return matchPool.normalizedTitle.includes(normalizedToken);
  }

  function keyMatchesVariant(ruleKey, matchPool) {
    if (!ruleKey) return false;
    const parts = String(ruleKey).split(/[|,]/).map((part) => part.trim()).filter(Boolean);
    if (!parts.length) return false;
    return parts.some((part) => matchesToken(part, matchPool));
  }

  function resolveRuleValue(rawRules, selectedVariant) {
    const parsedRules = parseVariantRules(rawRules);
    if (!selectedVariant) return '';
    if (!parsedRules) {
      if (typeof rawRules === 'string' && rawRules.trim()) {
        return rawRules.trim();
      }
      return '';
    }

    const matchPool = getVariantMatchPool(selectedVariant);

    if (Array.isArray(parsedRules)) {
      for (const rule of parsedRules) {
        if (!rule || typeof rule !== 'object') continue;

        const candidateTokens = [];
        if (Array.isArray(rule.variants)) candidateTokens.push(...rule.variants);
        if (Array.isArray(rule.sizes)) candidateTokens.push(...rule.sizes);
        if (Array.isArray(rule.options)) candidateTokens.push(...rule.options);
        if (Array.isArray(rule.values)) candidateTokens.push(...rule.values);
        if (typeof rule.variant === 'string') candidateTokens.push(rule.variant);
        if (typeof rule.size === 'string') candidateTokens.push(rule.size);
        if (typeof rule.option === 'string') candidateTokens.push(rule.option);
        if (typeof rule.key === 'string') candidateTokens.push(rule.key);
        if (typeof rule.match === 'string') candidateTokens.push(rule.match);

        const hasMatch = candidateTokens.some((token) => matchesToken(token, matchPool));
        if (!hasMatch) continue;

        const resolvedValue = rule.value ?? rule.title ?? rule.info ?? rule.text ?? '';
        if (typeof resolvedValue === 'string' && resolvedValue.trim()) {
          return resolvedValue.trim();
        }
      }
      return '';
    }

    if (typeof parsedRules === 'object') {
      const normalizedDefault = typeof parsedRules.default === 'string' ? parsedRules.default.trim() : '';
      for (const [key, value] of Object.entries(parsedRules)) {
        if (key === 'default') continue;
        if (!keyMatchesVariant(key, matchPool)) continue;
        if (typeof value === 'string' && value.trim()) {
          return value.trim();
        }
      }
      return normalizedDefault;
    }

    return '';
  }

  function parseMatchTokens(rawRules) {
    const parsed = parseVariantRules(rawRules);

    if (Array.isArray(parsed)) {
      return parsed.map((entry) => String(entry || '').trim()).filter(Boolean);
    }

    if (parsed && typeof parsed === 'object') {
      const tokens = [];
      if (Array.isArray(parsed.variants)) tokens.push(...parsed.variants);
      if (Array.isArray(parsed.sizes)) tokens.push(...parsed.sizes);
      if (Array.isArray(parsed.options)) tokens.push(...parsed.options);
      if (Array.isArray(parsed.values)) tokens.push(...parsed.values);
      if (typeof parsed.variant === 'string') tokens.push(parsed.variant);
      if (typeof parsed.size === 'string') tokens.push(parsed.size);
      if (typeof parsed.option === 'string') tokens.push(parsed.option);
      if (typeof parsed.key === 'string') tokens.push(parsed.key);
      if (typeof parsed.match === 'string') tokens.push(parsed.match);
      return tokens.map((entry) => String(entry || '').trim()).filter(Boolean);
    }

    if (typeof rawRules === 'string' && rawRules.trim()) {
      return rawRules
        .split(/[,\n|]/)
        .map((entry) => entry.trim())
        .filter(Boolean);
    }

    return [];
  }

  function hasStructuredRuleObject(rawRules) {
    const parsed = parseVariantRules(rawRules);
    return !!parsed && (Array.isArray(parsed) || typeof parsed === 'object');
  }

  function variantMatchesTokens(selectedVariant, tokens) {
    if (!selectedVariant || !tokens.length) return false;
    const matchPool = getVariantMatchPool(selectedVariant);
    return tokens.some((token) => matchesToken(token, matchPool));
  }

  function setTextForSelectors(selector, value) {
    if (typeof value !== 'string') return;
    document.querySelectorAll(selector).forEach((element) => {
      element.textContent = value;
    });
  }

  function applyVariantTitleInfoRules(selectedVariant) {
    const fallbackSmallSizeTokens = ['UK E', 'UK F', 'UK G'];
    const configuredMatchTokens = parseMatchTokens(variantMatchRulesRaw);
    const plainStringMatchTokens = configuredMatchTokens.length ? configuredMatchTokens : fallbackSmallSizeTokens;

