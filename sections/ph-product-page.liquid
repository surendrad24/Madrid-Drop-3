    .custom-ph-pdp-alternative-options {
    display: grid;
    grid-template-columns: 1fr 1fr; /* 2 per row */
    gap: 20px 0; /* vertical spacing between rows */
    margin-top: 10px;
  }

  .custom-ph-pdp-alternative-options .finish-col:nth-child(odd) {
    text-align: left; /* left align */
  }

  .custom-ph-pdp-alternative-options .finish-col:nth-child(even) {
    text-align: right; /* right align */
  }

  .custom-ph-pdp-alternative-options .finish-option {
    text-transform: uppercase;
    font-size: 10px;
    white-space: nowrap; /* prevent wrapping */
  }

  .custom-ph-pdp-alternative-options:first-child .finish-option {
      margin-bottom: 20px;
    }

    .finish-col:first-child .finish-option {
    border-bottom: 1px solid #333; /* underline effect */
    display: inline-block; /* ensures border aligns to text width */
    padding-bottom: 2px;   /* little breathing space */
  }



  /* Mobile: 1 column per row */
  @media (max-width: 767px) {
    .custom-ph-pdp-alternative-options {
      grid-template-columns: 1fr;   /* single column */
      gap: 12px 0;                   /* tighten vertical spacing if desired */
    }

    /* Normalize alignment on mobile */
    .custom-ph-pdp-alternative-options .finish-col {
      text-align: left !important;   /* override odd/even alignment */
    }

    /* Let labels wrap if needed on small screens */
    .custom-ph-pdp-alternative-options .finish-option {
      white-space: normal;
      font-size: 11px;               /* optional: slightly larger for readability */
    }

  }






