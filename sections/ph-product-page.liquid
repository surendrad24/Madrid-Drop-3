<div class="ph-pdp-product-container">
  <div class="ph-pdp-product-layout">
    <div class="ph-pdp-product-details">
      {% comment %} <form action="{{ routes.cart_url }}" method="post" enctype="multipart/form-data" data-bundle="{{ product.metafields.custom.custom_bundle != blank }}"> {% endcomment %}
      <form
        action="/cart/add"
        method="post"
        enctype="multipart/form-data"
        {% if product.metafields.custom.custom_bundle != blank %}
          data-bundle="true"
        {% else %}
          data-bundle="false"
        {% endif %}
      >
        <input type="hidden" name="id" value="{{ current_variant.id }}">

        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'title' %}
              <div {{ block.shopify_attributes }}>
                <h1 class="ph-pdp-product-title">
                  {{ product.title }}
                </h1>

                {% if product.metafields.custom.product_information %}
                  <div class="ph-pdp-product-subtitle">
                    {{ product.metafields.custom.product_information }}
                  </div>
                {% endif %}
              </div>

              {% if product.metafields.custom.starting_from_text_for_custom_product != blank %}

            <p class="ph-pdp-starting-from-span-text">{{ product.metafields.custom.starting_from_text_for_custom_product }}</p>

              {% endif %}

            {% when 'price' %}
              <div {{ block.shopify_attributes }}>
                <div class="ph-pdp-product-price" data-product-price>
                  {% assign price_whole = current_variant.price | divided_by: 100 | floor | times: 100 %}
                  {{ price_whole | money_without_trailing_zeros }}
                </div>
              </div>  

            {% when 'description' %}
              {% if product.description != blank %}
                <div {{ block.shopify_attributes }}>
                  <div class="ph-pdp-product-description-wrapper">
                    <div class="ph-pdp-product-description">
                      {% comment %}
                        Split the product description at the <!--more--> comment tag
                        This displays only the content before the "more" marker
                      {% endcomment %}
                      {% assign description_parts = product.description | split: '<p><!--more--></p>' %}
                      {{ description_parts[0] }}
                    </div>
                    <span class="ph-pdp-read-more">READ MORE</span>
                  </div>
                </div>
              {% endif %}
          {% endcase %}
        {% endfor %}

        <!-- Wrap remaining elements in a single container for animation -->
        <div class="ph-pdp-product-details--animate">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'plating_option' %}
                {% assign plating_option_index = -1 %}
                {% for option in product.options_with_values %}
                  {% if option.name == 'Plating' or option.name == 'Material' or option.name == 'Metal' %}
                    {% assign plating_option_index = forloop.index0 %}
                    {% assign plating_option = option %}
                  {% endif %}
                {% endfor %}

                {% if plating_option_index >= 0 and plating_option.values.size > 0 %}
                  <div class="ph-pdp-option-group" {{ block.shopify_attributes }}>
                    <div class="ph-pdp-option-header">
                      <div class="ph-pdp-option-title">{{ block.settings.option_label }}</div>
                      <div class="ph-pdp-option-subtitle">{{ block.settings.also_available_text }} </div>
                    </div>

                    <div class="ph-pdp-variant-text-options" data-option-index="{{ plating_option_index }}">
                      {% for value in plating_option.values %}
                        <div
                          class="ph-pdp-text-option {% if plating_option.selected_value == value %}selected{% endif %}"
                          data-option-value="{{ value | escape }}"
                        >
                          {{ value }}
                        </div>
                      {% endfor %}
                      <input
                        type="hidden"
                        name="options[{{ plating_option.name | escape }}]"
                        id="Option{{ plating_option_index }}"
                        value="{{ plating_option.selected_value | default: plating_option.values[0] | escape }}"
                      >
                    </div>
                  </div>
                {% endif %}

              {% when 'color_option' %}
                {% assign color_option_index = -1 %}
                {% for option in product.options_with_values %}
                  {% if option.name == 'Color' or option.name == 'Stone' %}
                    {% assign color_option_index = forloop.index0 %}
                    {% assign color_option = option %}
                  {% endif %}
                {% endfor %}

                {% if color_option_index >= 0 and color_option.values.size > 0 %}
                  <div class="ph-pdp-option-group" {{ block.shopify_attributes }}>
                    <div class="ph-pdp-option-header">
                      <div class="ph-pdp-option-title">{{ block.settings.option_label }}</div>
                      <div class="ph-pdp-option-subtitle">{{ block.settings.also_available_text }}</div>
                    </div>

                    <div class="ph-pdp-variant-boxes" data-option-index="{{ color_option_index }}">
                      {% for value in color_option.values %}
                        {% assign value_handle = value | handle %}
                        <div
                          class="ph-pdp-variant-box color-{{ value_handle }} {% if color_option.selected_value == value %}selected{% endif %}"
                          data-option-value="{{ value | escape }}"
                          title="{{ value }}"
                        ></div>
                      {% endfor %}
                      <input
                        type="hidden"
                        name="options[{{ color_option.name | escape }}]"
                        id="Option{{ color_option_index }}"
                        value="{{ color_option.selected_value | default: color_option.values[0] | escape }}"
                      >
                    </div>
                  </div>
                {% endif %}

                {% unless product.tags contains 'hookup-chain-ring' %}
                  {% if product.metafields.custom.finish.value %}
                    <div class="ph-pdp-option-group">
                      <div class="ph-pdp-option-header">
                        <div class="ph-pdp-option-title">FINISH</div>
                        {% if product.metafields.custom.finish_also_available.value != blank %}
                          <div class="ph-pdp-option-subtitle">ALSO AVAILABLE IN:</div>
                        {% endif %}
                      </div>

                      <div class="ph-pdp-finish-options">
                        <div class="ph-pdp-main-option">
                          <span>{{ product.metafields.custom.finish.value }}</span>
                        </div>

                        {% if product.metafields.custom.finish_also_available.value != blank %}
                          <div class="ph-pdp-mobile-option-subtitle">ALSO AVAILABLE IN:</div>
                          <div class="ph-pdp-alternative-options">
                            {% for finish in product.metafields.custom.finish_also_available.value %}
                              {% assign finish_parts = finish.title | split: '-' %}
                              {% assign product_id = finish.product_link | split: '/' | last | times: 1 %}
                              {% assign product_data = collections.all.products | where: 'id', product_id | first %}
                              {% assign finish_link = finish.product_link.value.url %}
                              <a href="{{ finish_link }}"> {{ finish_parts[0] }}</a>
                            {% endfor %}
                          </div>
                        {% endif %}
                      </div>
                    </div>
                  {% endif %}
                {% endunless %}

                <!-- FINISH OPTION SECTION -->
                {% if product.tags contains 'hookup-chain-ring' %}
                  {% if product.metafields.custom.finish.value %}
                    <div class="ph-pdp-option-group">
                      <div class="ph-pdp-option-header">
                        <div class="ph-pdp-option-title">FINISH</div>
                        {% if product.metafields.custom.finish_also_available.value != blank %}
                          {% if product.tags contains 'custom-order-products' %}
                            <div class="ph-pdp-option-subtitle">{{ product.metafields.custom.also_available_text }}</div>
                          {% else %}  

                          <div class="ph-pdp-option-subtitle">ALSO AVAILABLE INs:</div>
                        {% endif %}
                        {% endif %}
                      </div>

                      <div class="custom-ph-pdp-alternative-options">
                        {% for finish in product.metafields.custom.finish_also_available.value %}
                          {% assign finish_parts = finish.title | split: '----' %}
                          {% assign finish_name = finish_parts[0] | split: '/' | first %}
                          <!-- take only text before / -->

                          {% assign product_id = finish.product_link | split: '/' | last | times: 1 %}
                          {% assign product_data = collections.all.products | where: 'id', product_id | first %}
                          {% assign finish_link = finish.product_link.value.url %}

                          <div class="finish-col">
                            <a href="{{ finish_link }}" class="finish-option">
                              {{ finish_name }}
                            </a>
                          </div>
                        {% endfor %}
                      </div>
                    </div>
                  {% endif %}
                {% endif %}

