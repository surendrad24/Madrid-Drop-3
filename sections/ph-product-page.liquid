        const slowScrollFactor = 0.2;
        const slowScrollAmount = e.deltaY * slowScrollFactor;
        
        productImages.scrollBy({
          top: slowScrollAmount,
          behavior: 'smooth'
        });
      }, { passive: true });
      
      let touchStartY = 0;
      let touchEndY = 0;
      
      productImages.addEventListener('touchstart', function(e) {
        touchStartY = e.changedTouches[0].screenY;
      }, { passive: true });
      
      productImages.addEventListener('touchmove', function(e) {
        touchEndY = e.changedTouches[0].screenY;
        const touchDiff = touchStartY - touchEndY;
        
        productImages.scrollBy({
          top: touchDiff * 0.2, 
          behavior: 'smooth'
        });
        
        touchStartY = touchEndY;
      }, { passive: true });
    }
  }
});
