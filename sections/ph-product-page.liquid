<script>
  (function () {
    const stickyBar = document.getElementById('phStickyBar');
    if (!stickyBar) return;

    // Helper: hide/show sticky bar
    const setStickyHidden = (hidden) => {
      stickyBar.classList.toggle('is-hidden', !!hidden);
    };

    // Decide if cart drawer looks open (covers Dawn & your custom classes)
    const isCartOpen = () => {
      const cd = document.querySelector('cart-drawer');
      const nativeOpen = cd && (cd.classList.contains('active') || cd.hasAttribute('open'));
      const bodyLocked =
        document.body.classList.contains('overflow-hidden') || document.body.classList.contains('cart-overflow-hidden');
      const drawerEl = document.getElementById('CartDrawer');
      const drawerActive = drawerEl && drawerEl.classList.contains('active');
      return !!(nativeOpen || bodyLocked || drawerActive);
    };

    // Initial state
    setStickyHidden(isCartOpen());

    // 1) Observe <cart-drawer> attribute/class changes
    const cartDrawer = document.querySelector('cart-drawer');
    if (cartDrawer) {
      new MutationObserver((muts) => {
        setStickyHidden(isCartOpen());
      }).observe(cartDrawer, { attributes: true, attributeFilter: ['class', 'open'] });
    }

    // 2) Observe #CartDrawer (some themes use a div)
    const legacyDrawer = document.getElementById('CartDrawer');
    if (legacyDrawer) {
      new MutationObserver(() => setStickyHidden(isCartOpen())).observe(legacyDrawer, {
        attributes: true,
        attributeFilter: ['class'],
      });
    }

    // 3) Observe body class (your openCartDrawer() adds these)
    new MutationObserver(() => setStickyHidden(isCartOpen())).observe(document.body, {
      attributes: true,
      attributeFilter: ['class'],
    });

    // 4) Listen for common custom events (Dawn + apps often emit these)
    ['cart:open', 'cart:close', 'cart-drawer:open', 'cart-drawer:close'].forEach((evt) => {
      document.addEventListener(evt, () => setStickyHidden(isCartOpen()), { passive: true });
    });

    // 5) If you call your openCartDrawer() manually, also hide immediately
    if (typeof window.openCartDrawer === 'function') {
      const _open = window.openCartDrawer;
      window.openCartDrawer = function () {
        setStickyHidden(true);
        return _open.apply(this, arguments);
      };
    }
  })();
</script>
<script>
  let bundleSelections = {};  // Store selected sizes for each product

  // Function to handle size selection for a bundle product
  function selectBundleSize(bundleHandle, selectedSize) {
    // Update the selected size for the current bundle product
    bundleSelections[bundleHandle] = selectedSize;

    // Remove "selected" class from all size boxes for this product
    document.querySelectorAll(`[data-handle="${bundleHandle}"] .ph-pdp-size-box`).forEach(function(sizeBox) {
      sizeBox.classList.remove('selected');
    });

    // Add "selected" class to the clicked size box to highlight it
    const selectedSizeBox = document.querySelector(`[data-handle="${bundleHandle}"] .ph-pdp-size-box[data-option-value="${selectedSize}"]`);
    selectedSizeBox.classList.add('selected');

    console.log('Updated bundle selections:', bundleSelections);

    // Check the inventory for the selected size
    checkInventoryForBundle(bundleHandle, selectedSize);
  }

  // Function to check inventory for each selected variant in the bundle
  async function checkInventoryForBundle(bundleHandle, selectedSize) {
    try {
      // Fetch the bundle product data
      const res = await fetch(`/products/${bundleHandle}.js`);
      const productData = await res.json();

      // Find the variant based on the selected size
      const variant = productData.variants.find(v => v.option1 === selectedSize);

      console.log(`Checking inventory for ${bundleHandle} - ${selectedSize}:`, variant);

      if (variant) {
        // Log the entire variant object for debugging purposes
        console.log(`Variant found for ${bundleHandle} - ${selectedSize}:`, variant);

        // Check if inventory_quantity exists and log it
        if (variant.inventory_quantity !== undefined && variant.inventory_quantity !== null) {
          console.log(`Inventory for ${bundleHandle} - ${selectedSize}:`, variant.inventory_quantity);

          // Check inventory and disable the button if out of stock
          if (variant.inventory_quantity <= 0) {
            console.log(`The selected size ${selectedSize} for ${bundleHandle} is out of stock.`);
            alert(`The selected size ${selectedSize} for ${bundleHandle} is out of stock!`);
            document.getElementById('dynamic-button').disabled = true;
            document.getElementById('dynamic-button').innerText = "Out of Stock";
          } else {
            console.log(`The selected size ${selectedSize} for ${bundleHandle} is in stock.`);
          }
        } else {
          console.warn(`Inventory quantity is not available for ${bundleHandle} - ${selectedSize}`);
        }

      } else {
        console.warn(`No variant found for ${bundleHandle} with size ${selectedSize}`);
      }
    } catch (error) {
      console.error(`Error fetching inventory for ${bundleHandle}:`, error);
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    const addToCartButton = document.getElementById("dynamic-button");  // Add to cart button

    // Function to check if it's a bundle product
    function isBundleProduct() {
      return window.bundleProducts && window.bundleProducts.length > 0;
    }

    // Event listener for the add-to-cart button
    if (addToCartButton) {
      addToCartButton.addEventListener('click', function (e) {
        e.preventDefault();  // Prevent default form submission behavior

        if (isBundleProduct()) {
          addBundleProductsToCart(); // Handle adding bundle products to the cart
        } else {
          addNormalProductToCart(); // Handle adding a normal product to the cart
        }
      });
    }

    // Function to handle adding bundle products to the cart
    async function addBundleProductsToCart() {
      const sizeSelections = {};

      // Collect per-bundle size selections
      document.querySelectorAll('.bundle-size-boxes').forEach(group => {
        const handle = group.dataset.handle;
        const selectedBox = group.querySelector('.ph-pdp-size-box.selected');
        if (handle && selectedBox) {
          sizeSelections[handle] = selectedBox.dataset.optionValue;
        }
      });

      // Check that all have a size selected
      const unselected = window.bundleProducts.find(h => !sizeSelections[h]);
      if (unselected) {
        alert("Please select size for all bundled products before adding to cart.");
        return;
      }

      // Disable button briefly
      addToCartButton.disabled = true;
      addToCartButton.innerText = "Adding...";

      try {
        // Add all bundle products to the cart
        for (const handle of window.bundleProducts) {
          const selectedSize = sizeSelections[handle];
          const res = await fetch(`/products/${handle}.js`);
          const productData = await res.json();
          const variant = productData.variants.find(v => v.option1 === selectedSize);

          if (variant) {
            console.log(`Adding ${productData.title} - ${variant.title} to the cart.`);
            await fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ items: [{ id: variant.id, quantity: 1 }] })
            });
          } else {
            console.warn(`⚠️ No variant found for ${handle} (${selectedSize})`);
          }
        }

        // Restore button state
        addToCartButton.disabled = false;
        addToCartButton.innerText = "Add to Basket";

        // Reopen cart drawer after adding the bundle
        localStorage.setItem('openCartDrawerAfterReload', 'true');
        window.location.reload();
      } catch (err) {
        console.error('Error adding bundle:', err);
        addToCartButton.disabled = false;
        addToCartButton.innerText = "Add to Basket";
      }
    }

    // Function to handle adding normal products to the cart (as per your previous script)
    async function addNormalProductToCart() {
      const form = addToCartButton.closest('form');
      if (form) {
        try {
          const formData = new FormData(form);
          console.log("Form data being submitted:", formData);

          const response = await fetch('/cart/add.js', {
            method: 'POST',
            body: formData
          });

          if (!response.ok) {
            throw new Error(`Network response was not ok: ${response.status}`);
          }

          const responseJson = await response.json();

          // Set flag to open cart drawer after reload
          localStorage.setItem('openCartDrawerAfterReload', 'true');

          // Refresh the page
          window.location.reload();
        } catch (error) {
          console.error('Error adding to cart:', error);
        }
      }
    }
  });
  
</script>

