.ph-pdp-product-compare-price {
  position: relative;
  text-decoration: none !important; /* remove the thick default line */
  color: #888;
  font-size: 0.9em;
}

.ph-pdp-product-compare-price::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  width: 92%;

  height: 1px; /* <— reduce thickness here */
  background: #888; /* line color */

  top: 50%; /* center the line */
  transform: translateY(-50%);
}


