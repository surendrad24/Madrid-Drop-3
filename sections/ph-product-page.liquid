  /* Back-in-stock (BIS) modal */
  .ph-bis-modal{
    position:fixed; inset:0; display:flex; align-items:center; justify-content:center;
    visibility:hidden; opacity:0; pointer-events:none; transition:opacity .2s ease, visibility .2s ease;
  }
  .ph-bis-modal.is-open{ visibility:visible; opacity:1; pointer-events:auto; z-index: 10; }
  .ph-bis-backdrop{ position:absolute; inset:0; background:rgba(0,0,0,.45); }
  .ph-bis-dialog{
    position:relative; z-index:11; background:#fff; width:min(92vw,520px);
     padding:22px 22px 18px; box-shadow:0 10px 30px rgba(0,0,0,.15);
  }
  .ph-bis-title{ margin:0 0 6px; font-size:18px; text-transform:uppercase; letter-spacing:.06em; }
  .ph-bis-sub{ margin:0 0 14px; font-size:12px; color:#555; }
  .ph-bis-row{ display:flex; gap:8px; }
  .ph-bis-input{ flex:1 1 auto; height:40px; padding:0 12px; border:1px solid #e5e5e5; }
  .ph-bis-submit{ height:40px; padding:0 16px; background:#000; color:#fff; border:0; text-transform:uppercase; font-size:11px; }
  .ph-bis-close{ position:absolute; right:8px; top:6px; background:transparent; border:0; font-size:28px; line-height:1; cursor:pointer; }
  .ph-bis-success{ display:none; margin-top:10px; font-size:12px; color:#167c2a; }
  /* accessibility nicety */
  .ph-bis-modal[aria-hidden="true"] .ph-bis-dialog{ transform:translateY(6px); }
  .ph-bis-modal.is-open .ph-bis-dialog{
    transform:none;
    transition:transform .2s ease;
    max-width: 450px;
    padding-top: 24px;
  }


  /* Center modal properly when open */
.ph-bis-modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6); /* optional overlay */
  z-index: 9999;
  justify-content: center;
  align-items: center;
  visibility: hidden;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

/* Show and center it when open */
.ph-bis-modal.is-open {
  display: flex;             /* this centers the dialog */
  visibility: visible;
  opacity: 1;
  pointer-events: auto;
}

/* Modal content box */
.ph-bis-dialog {
  background: #fff;
  border-radius: 0px;
  padding: 24px;
  max-width: 600px;
  width: 90%;
  box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  transition: transform 0.3s ease, opacity 0.3s ease;
  transform: translateY(0);
}



