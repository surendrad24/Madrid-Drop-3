<script>
document.addEventListener('DOMContentLoaded', function () {
  // DOM refs
  const mainBtn   = document.querySelector('.ph-pdp-add-to-cart-button');
  const notifyBtn = document.getElementById('notify-button');
  const stickyBar = document.getElementById('phStickyBar');
  const stickyBtn = document.getElementById('phStickyAddToCart');
  const stickySel = document.getElementById('phStickySizeSelect'); // may be null

  if (!stickyBar || !stickyBtn) return;

  // Arrow flip + placeholder for size <select>
  if (stickySel) {
    const wrap = stickySel.parentElement; // <span class="ph-sticky-select-wrap">
    stickySel.addEventListener('mousedown', () => wrap.classList.add('is-open'));
    stickySel.addEventListener('change',   () => wrap.classList.remove('is-open'));
    stickySel.addEventListener('blur',     () => wrap.classList.remove('is-open'));
    stickySel.value = ''; // force placeholder at load
  }

  // Pull bar to <body> so it always sits on top
  document.body.appendChild(stickyBar);
  document.body.classList.add('has-sticky-add');

  // Hook into your existing variant change helper if present
  const updateVariantSelection =
    typeof window.updateVariantSelection === 'function' ? window.updateVariantSelection : () => {};

  // Helpers
  const notifyIsVisible = () =>
    !!(notifyBtn && !notifyBtn.classList.contains('hidden') && notifyBtn.offsetParent);

  const isCartOpen = () => {
    const cd = document.querySelector('cart-drawer');
    const nativeOpen = cd && (cd.classList.contains('active') || cd.hasAttribute('open'));
    const bodyLocked =
      document.body.classList.contains('overflow-hidden') ||
      document.body.classList.contains('cart-overflow-hidden');
    const legacy = document.getElementById('CartDrawer');
    const legacyOpen = legacy && legacy.classList.contains('active');
    return !!(nativeOpen || bodyLocked || legacyOpen);
  };

  // Keep sticky label/mode in sync with the active CTA (Notify or Add)
  function syncState() {
    if (notifyIsVisible()) {
      stickyBtn.disabled = false;
      stickyBtn.textContent = notifyBtn.textContent || 'Notify me';
      stickyBtn.dataset.mode = 'notify';
    } else {
      const disabled = !!(mainBtn && mainBtn.disabled);
      stickyBtn.disabled = disabled;
      stickyBtn.style.opacity = disabled ? '0.65' : '1';
      stickyBtn.textContent = (mainBtn && mainBtn.textContent?.trim()) || 'ADD TO BASKET';
      stickyBtn.dataset.mode = 'add';
    }

    // Also mirror size selection if the user already chose one
    if (stickySel) {
      const hiddenInput = document.getElementById(`Option${stickySel.dataset.optionIndex}`);
      if (hiddenInput && hiddenInput.value && stickySel.value !== '') {
        stickySel.value = hiddenInput.value;
      }
    }
  }

  // Observe both buttons for changes (text, class, disabled, etc.)
  syncState();
  if (mainBtn) {
    new MutationObserver(() => { syncState(); toggleVisibility(); }).observe(mainBtn, {
      attributes: true, attributeFilter: ['disabled', 'class', 'style'], childList: true, subtree: true
    });
  }
  if (notifyBtn) {
    new MutationObserver(() => { syncState(); toggleVisibility(); }).observe(notifyBtn, {
      attributes: true, attributeFilter: ['class', 'style'], childList: true, subtree: true
    });
  }

  // Size <select> → change hidden input + update variant
  if (stickySel) {
    stickySel.addEventListener('change', () => {
      const idx = +stickySel.dataset.optionIndex;
      const hiddenInput = document.getElementById(`Option${idx}`);
      if (hiddenInput) {
        hiddenInput.value = stickySel.value;
        document.querySelectorAll('.ph-pdp-size-box[data-option-value]').forEach(el => {
          el.classList.toggle('selected', el.dataset.optionValue === stickySel.value);
        });
        updateVariantSelection();
      }
    });
  }

  // Sticky CTA click: proxy to the correct action
  stickyBtn.addEventListener('click', (e) => {
    e.preventDefault();
    const mode = stickyBtn.dataset.mode ||
      (typeof window.__phStickyMode === 'function' ? window.__phStickyMode() : 'add');
    if (mode === 'notify') {
      notifyBtn?.click();     // opens your BIS modal
    } else {
      mainBtn?.click();       // normal add to cart
    }
  });

  // Hide sticky bar when the active CTA is on-screen (or when cart drawer is open)
  const getActiveCta = () => (notifyIsVisible() ? notifyBtn : mainBtn);
  function toggleVisibility() {
    const cta = getActiveCta();
    if (!cta) return;
    const r = cta.getBoundingClientRect();
    const anyPartVisible = r.height > 0 && r.top < window.innerHeight && r.bottom > 0;
    const shouldHide = anyPartVisible || isCartOpen();
    stickyBar.classList.toggle('is-hidden', shouldHide);
  }

  toggleVisibility();
  window.addEventListener('scroll', toggleVisibility, { passive: true });
  window.addEventListener('resize', toggleVisibility);
});
</script>

