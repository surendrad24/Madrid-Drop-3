          /* ——— universal sticky bar (mobile & desktop) ——— */
          .ph-sticky-bar{
            position:fixed;
            left:0;
            bottom:0;
            width:100%;
            height:56px;
            display:flex;
            align-items:center;
            justify-content:center;
            background:#1a1a1a;
            color:#fff;
            padding-right: 6px;
            z-index:2147483647;
            transition:transform .25s ease,opacity .25s ease;
          }
          body.has-sticky-add{padding-bottom:56px;}
          .ph-sticky-bar.is-hidden{transform:translateY(100%);opacity:0;pointer-events:none;}

          .ph-sticky-size-label{
            font-size:10px;font-family:'PhoriaBold',sans-serif;letter-spacing:.1em;padding-left: 2%;
          }
          .ph-sticky-size-select{
            appearance:none;-webkit-appearance:none;
            background:#fff;
            padding:12px 34px 12px 12px;   /* 34 px = room for arrow */
            font:10px/1 'PhoriaBold',sans-serif;
            text-transform:uppercase;
            cursor:pointer;
            position:relative;          /* needed for ::after anchor */
            
          }
          select[name="stickysize"] option {
            background-color: #fff;
            color: #000;
            font-family: 'PhoriaBold', sans-serif;
            text-transform: uppercase;
          }
          /* ▼ arrow for the sticky-bar size selector */
          .ph-sticky-size-select{
            padding-right:18px;                 /* make room for the arrow */
            background:#000;                    /* must match the select’s bg */
            position:relative;                  /* establish containing block */
            padding-left: 2px;
            color: #fff;
          }


          .ph-sticky-add-btn{
            flex:1 0 auto;
            height:38px;
            min-width:140px;
            background:#1a1a1a;
            color:#fff;
            border-color: white;
            font-size:10px;
            font-family:'PhoriaBold',sans-serif;
            text-transform:uppercase;
            cursor:pointer;
            transition:opacity .2s ease;
          }
          .ph-sticky-add-btn[disabled]{opacity:.65;cursor:not-allowed;}

          @media (min-width:1024px){
            .ph-sticky-bar{height:64px;gap:12px;width:50% !important;padding-right: 15%;padding-left: 5%;}
            /* desktop bar is only hidden when the JS adds .is-hidden */
            .ph-sticky-bar.is-hidden{transform:translateY(100%);opacity:0;}
            .ph-sticky-size-select{padding:12px 32px 12px 14px;}
            body.has-sticky-add{padding-bottom:64px;}
            .ph-sticky-size-label{
            font-size:10px;font-family:'PhoriaBold',sans-serif;letter-spacing:.1em;padding-left: 16%;
          }
          }
          /*  ►  REPLACE the current ::after rule with this one  */
          .ph-sticky-select-wrap::after{
            content:"";
            position:absolute;
            right:12px; top:50%;
            width:0; height:0; margin-top:-3px;
            border-left:5px solid transparent;
            border-right:5px solid transparent;
            border-top:5px solid #000;
            pointer-events:none;
            transition:transform .2s ease;       /* enables flip */
          }
          /* gives the ::after something to anchor to */
          .ph-sticky-select-wrap{
            position:relative;
            display:inline-block;
            padding-right: 2px;/* shrink-wrap to the <select> */
          }

          @media (min-width:1024px){
            .ph-sticky-select-wrap::after{
              right:16px; margin-top:-4px;
              border-left-width:6px; border-right-width:6px; border-top-width:6px;
            }
          }
          /* flips arrow when the list is open */
          .ph-sticky-select-wrap.is-open::after{
