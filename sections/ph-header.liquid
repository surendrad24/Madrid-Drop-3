{%- if settings.cart_type == "drawer" -%}
	{{ 'component-discounts.css' | asset_url | stylesheet_tag }}
	{{ 'component-cart-drawer.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
	<script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
<style>
    :root{
        --ph-announcement-bar-bg: #000;
        --ph-announcement-bar-color: #fff;
        --ph-menu-bg: transparent;
        --ph-inactive-tab-color: #81847A;
        --ph-primary-text: #1D1D1D;
        --ph-border-color: #D4D4D4;
        --ph-menu-color: #1D1D1D;
        --ph-menu-cart-bg: #1D1D1D;
        --ph-menu-cart-text: #fff;
    }
    header.ph-header__container{
        display: flex;
        flex-direction: column;
        width: 100%;
        position: fixed;
        top: 0;
        z-index: 1000;
    }
    .ph-announcement__bar{
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 10px;
        align-items: center;
        width: 100%;
        padding: 18px 36px 13px;
        background: var(--ph-announcement-bar-bg);
    }
    .ph-announcement-text{
        color: var(--ph-announcement-bar-color);
        font-size: 10px;
        text-transform: uppercase; 
        text-align: center; 
        margin: 0;
    }
    .ph-announcement-text a{
      color: #fff;
    }
    .ph-announcement-text strong{
      font-family: "PhoriaBold";
    }

    .ph-countdown-timer-outer-container {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;

    }
    .ph-announcement-timer {
      color: #fff;
      word-spacing: .3em;
      font-family: var(--font-body-family);
          font-weight: var(--font-body-weight);

    }

    .ph-timer-separator {
  color: #fff;
  font-weight: bold;
  font-size: 18px;
  margin: 0 6px;
  vertical-align: middle;
}


    .ph-countdown-timer-span {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 6px;
    }

    .ph-countdown-timer-count {
      padding: 2px 8px 2px 8px;
      background-color: #fff;
      color: #000;
      font-size: 12px;
      font-family: 'PhoriaBold';
      padding-top: 4px;
    }

    .ph-countdown-timer-count-text {
      font-size: 8px;
    }

    .ph-countdown-timer-inner-container {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
    }
    .ph-header{
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 36px;
        background: var(--ph-menu-bg);
    }
    .ph-menu{
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 46px;
        font-size: 12px;
        color: var(--ph-menu-color);
        text-transform: uppercase;
        flex: 1;
    }
    .ph-menu:last-child{
        justify-content: flex-end;
    }
    .ph-menu__items{
        display: flex;
        gap: 72px;
        font-size: 12px;
        padding-left: 0;
    }
    .ph-menu.right .ph-menu__items{
      gap: 46px;
    }
    .ph-menu__item{
        list-style: none;
        cursor: pointer;
        font-family: 'PhoriaBold';
        transition: var(--duration-default);
    }
    .ph-menu__item .header__account summary{
      height: auto;
      color: var(--ph-menu-color);
    }
    .ph-menu__item a{
        text-decoration: none;
        color: var(--ph-menu-color);
        transition: var(--duration-default);
    }
    .ph-logo{
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        max-width: 160px;
        height: 14px;
        padding: 25px 0;
    }
    .ph-logo img{
        display: none;
        max-width: 160px;
    }
    .ph-logo[data-logo-color="white"] .ph-white__logo{
        display: block;
    }
    .ph-logo[data-logo-color="black"] .ph-black__logo{
        display: block;
    }
    .ph-cart a > span, .cart-count-bubble > span{
        font-size: 12px;
        font-family: 'Phoriabold';
    }
   
    .cart-count-bubble{
        background: var(--ph-menu-cart-bg);
        width: 21px;
        height: 21px;
    }
    .cart-count-bubble > span{
        color: var(--ph-menu-cart-text);
        line-height: normal;
    }

    /* --- Menu drawer --- */
    
    #ph-side__nav__overlay{
        bottom: 0;
        cursor: pointer;
        position: fixed;
        right: 0;
        top: 0;
        z-index: 10001;
        background-color: rgba(20, 22, 24, 0.95) !important;
        left: -100%;
        opacity: 0;
        transition: opacity 600ms cubic-bezier(0.785, 0.135, 0.15, 0.86), visibility 0s 600ms, left 0s 600ms;
        width: 100%;
        height: 100%;
    }
    #ph-side__nav__overlay.open{
        left: 0;
        opacity: 0.5;
        visibility: visible;
        transition: opacity 600ms cubic-bezier(0.785, 0.135, 0.15, 0.86), visibility 0s 0s, left 0s 0s;
    }
    .ph-menu__drawer.left{
        box-sizing: border-box;
        bottom: 0;
        position: fixed;
        top: 0;
        left: 0;
        width: 564px;
        transition: box-shadow 600ms cubic-bezier(0.785, 0.135, 0.15, 0.86), transform 600ms cubic-bezier(0.785, 0.135, 0.15, 0.86);
        z-index: 10002;
        background-color: white;
        transform: translateX(-100%);
        opacity: 0.9;
        max-width: 50%;
    }
    .ph-menu__drawer.open {
        box-shadow: 9px 0px 19px rgba(0, 0, 0, 0.04);
        transform: translateX(0);
    }
    .ph-nav__menu--close{
        padding: 18px;
        cursor: pointer;
        font-size: 10px;
        text-transform: uppercase;
        display: block;
        font-family: 'PhoriaBold';
    }
    .ph-menu__tabs {
        display: flex;
        padding-top: 134px;
    }
    .ph-tab__button {
        padding: 0px 20px;
        border: none;
        background: none;
        cursor: pointer;
        color: var(--ph-inactive-tab-color);
        text-transform: uppercase;
        font-family: 'PhoriaRegular';
        font-size: 10px;
        font-weight: 600;
        line-height: 11px;
    }
    .ph-tab__button.active {
        color: var(--ph-primary-text);
    }
    .ph-tab__content {
        display: none;
        padding: 0 18px;
        padding-top: 45px;
    }
    .ph-tab__content li{
        list-style: none;
        text-transform: uppercase;
        font-size: 12px;
        font-family: 'PhoriaBold';
    }
    .ph-tab__content.active {
        display: flex;
        flex-direction: column;
        gap: 36px;
    }
    .ph-tab__content.active .ph-tab__otherlinks--title {
        font-size: 10px;
        margin-top: 18px;
        color: var(--ph-inactive-tab-color);
    }
    .ph-tab__content.active ul {
        display: flex;
        flex-direction: column;
        gap: 36px;
        padding-left: 0;
    }

    #ph-search__nav__overlay{
        cursor: pointer;
        bottom: 0;
        position: fixed;
        top: 0;
        z-index: 10001;
        background-color: rgba(20, 22, 24, 0.95) !important;
        right: -100%;
        opacity: 0;
        transition: opacity 600ms cubic-bezier(0.785, 0.135, 0.15, 0.86), visibility 0s 600ms, left 0s 600ms;
        width: 100%;
        height: 100%;
    }
    #ph-search__nav__overlay.open{
        left: 0;
        opacity: 0.5;
        visibility: visible;
        transition: opacity 600ms cubic-bezier(0.785, 0.135, 0.15, 0.86), visibility 0s 0s, left 0s 0s;
    }
    .ph-menu__drawer.right{
        box-sizing: border-box;
        /* bottom: 0; */
        position: fixed;
        top: 0;
        right: 0;
        width: 564px;
        transition: box-shadow 600ms cubic-bezier(0.785, 0.135, 0.15, 0.86), transform 600ms cubic-bezier(0.785, 0.135, 0.15, 0.86);
        z-index: 10002;
        background-color: white;
        transform: translateX(100%);
        opacity: 0.9;
        max-width: 50%;
        height: 100%;
        padding: 18px 18px 18px 36px;
    }
    .ph-menu__drawer.right.open{
        box-shadow: 0 50px 50px -30px rgba(0, 0, 0, 0.2), 0 30px 50px 0 rgba(0, 0, 0, 0.15);
        transform: translateX(0);
    }
    .ph-search__menu--close{
        /* padding: 18px; */
        cursor: pointer;
        font-size: 10px;
        text-transform: uppercase;
        text-align: right;
        font-family: 'PhoriaBold';
    }
    #ph-search__form{
        padding-top: 130px;
    }
    #ph-search__form input{
        margin: unset;
        padding-left: 0px;
        padding-right: 9px;
        padding-top: 0px;
        padding-bottom: 0px;
        font-size: 12px;
        font-weight: 700;
        color: var(--ph-primary-text);
        box-sizing: border-box;
        -webkit-appearance: none;
        transition: color 400ms cubic-bezier(0.785, 0.135, 0.15, 0.86), background-color 400ms cubic-bezier(0.785, 0.135, 0.15, 0.86), border-color 400ms cubic-bezier(0.785, 0.135, 0.15, 0.86);
        width: 100%;
        border: none;
        text-transform: uppercase;
        outline: none;
        font-family: 'PhoriaRegular';
    }

    .ph-search__suggestions{
        padding-top: 45px;
        display: flex;
        flex-direction: column;
        gap: 18px;
    }
    .ph-search__suggestions--title{
        font-size: 10px;
        color: var(--ph-inactive-tab-color);
        text-transform: uppercase;
        line-height: 11px;
        text-align: left;
        font-weight: 600;
    }
    .ph-search__suggestions--list{
        display: flex;
        flex-direction: column;
        gap: 18px;
        align-items: flex-start;
        padding-left: 0;
        margin: 0;
    }
    .ph-search__suggestions--list li{
        list-style: none;
    }
    .ph-search__suggestions--list li a{
        color: var(--ph-primary-text);
        text-decoration: none;
        text-transform: uppercase;
        font-size: 10px;
        font-family: 'PhoriaBold';
        line-height: 2.3;
    }
    .ph-menu__content--mobile{
        display: none;
    }
    .ph-menu__close--icon{
        display: none;
    }
    .ph-submenu__mobile{
       display: none; 
    }
    .ph-menu__back--icon{
      display: none;
    }
    #MainContent{
      {% if request.path != '/' %}
       padding-top: 100px;
      {% endif %}
    }
    @media screen and (min-width: 960px) {
        .ph-menu__drawer.open {
            border-right: 1px solid var(--ph-primary-text);
        }
    }
    @media screen and (max-width: 959px) {
        .ph-announcement__bar{
          padding: 11px 18px; 
        }
        .ph-announcement-text{
          font-size: 10px;
        }
        header.ph-header__container{
            z-index: 10002 !important;
        }
        .ph-header{
            z-index: 10002 !important;
            padding: 0 18px;
        }
        .ph-menu.left .ph-menu__items, .ph-menu.right .ph-menu__items{
            display: none;
        }
        .ph-menu.left .ph-menu__icon{
            display: flex;
            flex-direction: column;
            gap: 8px;
            cursor: pointer;
        }
        .ph-menu.left .ph-menu__icon span{
            width: 20px;
            height: 2px;
            background: var(--ph-menu-color);
            display: block;
            transition: var(--duration-default);
        }
        .ph-menu__drawer.left{
            max-width: none;
            width: 100%;
        }
        .ph-menu__tabs, .ph-menu__content{
            display: none;
        }
        .ph-menu__content--mobile{
            display: block;
        }
        .ph-menu__content--mobile ul{
            display: flex;
            flex-direction: column;
            gap: 36px;
            padding: 0 18px;
            font-family: 'PhoriaBold';
        }
        .ph-menu__content--mobile li{
            list-style: none;
            text-transform: uppercase;
        }
        .ph-menu__content--mobile #ph-search__form--mobile{
            padding: 54px 18px;
            margin-top: 45px;
        }
        .ph-menu__content--mobile #ph-search__form--mobile input{
            border: 1px solid var(--ph-border-color);
            padding: 21px 27px;
            width: 100%;
            text-transform: uppercase;
            outline: none;
            font-family: 'PhoriaRegular';
            border-radius: 0px;
        }
        .ph-nav__menu--close{
            display: none;
        }
        .ph-menu__close--icon{
            display: none;
            cursor: pointer;
            font-family: 'PhoriaBold';
        }
        ul.ph-submenu__mobile{
          margin-left: unset;
          overflow: hidden;
          box-sizing: border-box;
          display: flex;
          flex-direction: column;
          position: fixed;
          bottom: 0;
          top: 0;
          right: 0;
          left: 0;
          width: 100%;
          height: 100%;
          background-color: #fff;
          z-index: 10003;
          transform: translateX(-100%);
          transition: box-shadow 600ms cubic-bezier(0.785, 0.135, 0.15, 0.86), transform 600ms cubic-bezier(0.785, 0.135, 0.15, 0.86);
          padding: 110px 18px !important;
          align-items: flex-start;
          gap: 36px;
        }
        .ph-submenu__mobile li{
          /* padding: 64px 18px; */
          font-size: 10px;  
        }
        .ph-submenu__mobile li:first-child{
          color: var(--ph-inactive-tab-color);
        }
        .ph-submenu__mobile.active{
          box-shadow: 0 50px 50px -30px rgba(0, 0, 0, 0.2), 0 30px 50px 0 rgba(0, 0, 0, 0.15);
          transform: translateX(0);
        }
        .ph-submenu__mobile .ph-tab__otherlinks{
          display: flex;
          flex-direction: column;
          gap: 2rem;
          text-transform: uppercase;
          margin-top: 18px;
        }
        .ph-submenu__mobile .ph-tab__otherlinks span{
          font-size: 10px;
        }
        .ph-submenu__mobile .ph-tab__otherlinks span:first-child{
          color: var(--ph-inactive-tab-color) !important;
        }
        .ph-menu__back--icon{
          display: block;
          visibility: hidden;
          pointer-events: none;
        }
        .ph-user__account--mob{
          position: fixed;
          left: 0;
          bottom: 48px;
          margin-bottom: 54px;
          justify-content: space-between;
          width: 100%;
          align-items: end;
          display: inline-flex;
          text-transform: uppercase;
          cursor: pointer;
          font-family: 'PhoriaBold';
          font-size: 10px;
          padding: 0 18px;
        }
        .ph-menu__mobile--triggers{
          font-size: 10px;  
        }
        .ph-user__account--mob .header__account{
          display: block;
        }
    }
  .ph-i__icon{
        position: absolute;
        bottom: 0px;
        right: 50%;
        transform: translate(50%, -50%);
        display: inline-flex;
        max-width: 15px;
        pointer-events: none;
        margin-bottom: 5%;
        opacity: 0;
      }
      .ph-i__icon img{
        width: 100%;
        height: auto;
        object-fit: contain;
      }
    .ph-i__icon.mobile{
      display: none;
    }
  @media screen and (max-width: 959px){ 
    .ph-i__icon.desktop{
      display: none;
    }
    .ph-i__icon.mobile{
      display: inline-flex;
    }
    .ph-logo img{
      max-width: 137px;
    }
  }

 /* Default styles for menu items */
.ph-menu {
  display: flex;
  justify-content: flex-start;
  gap: 46px;
  font-size: 12px;
  color: #1D1D1D; /* Default text color (black) */
  background-color: transparent; /* Default background */
  text-transform: uppercase;
  flex: 1;
}

.ph-menu__item a {
  color: inherit;  /* Inherit the color set by .ph-menu */
  text-decoration: none;
  transition: var(--duration-default);
}

/* Set text color to white only on the home page */
body.template-index   .ph-menu {
  color: #fff;  /* Set menu text color to white */
}

body.template-index .ph-menu__item a {
  color: #fff;  /* Ensure menu links are white on home page */
}


body.template-index .cart-count-bubble {
  background-color: #fff;
}

body.template-index .cart-count-bubble > span {
  color: #000;
}



.ph-logo[data-logo-color="white"] .ph-white__logo{
        display: block;
    }
    .ph-logo[data-logo-color="black"] .ph-black__logo{
        display: block;
    }

body.template-index .ph-white__logo {
          display: block;

}

body.template-index .ph-black__logo {
          display: none !important;

}




/* For mobile view adjustments */
@media screen and (max-width: 959px) {
  .ph-menu__item a {
    font-size: 14px;  /* Example: Adjust font size for smaller screens */
  }

  body.template-index .ph-menu.left .ph-menu__icon span {
  background: #fff;
}
}

.remaining-text-container {
  margin-bottom: 14px;
}

.remaining-text {
  font-size: 10px;
}


</style>

<div id="ph-side__nav__overlay"></div>
<div id="ph-search__nav__overlay"></div>
<div class="ph-menu__drawer left">
    <div class="ph-nav__menu--close">
        Close
    </div>
    <div class="ph-menu__tabs">
        <button class="ph-tab__button" data-tab="0">{{ section.settings.menu_1_title }}</button>
        <button class="ph-tab__button" data-tab="1">{{ section.settings.menu_2_title }}</button>
    </div>
    <div class="ph-menu__content">
        <div class="ph-tab__content" data-content="0">
          {%- if section.settings.menu_1 != blank -%}
            <ul>
              {%- for link in linklists[section.settings.menu_1].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
                <li class="ph-tab__otherlinks--title">{{ section.settings.other_links_title }}</li>
                {%- if section.settings.other_links != blank -%}
                  {%- for link in linklists[section.settings.other_links].links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {% endfor %}
                {% endif %}
            </ul>
          {% endif %}
            <!-- <ul class="ph-tab__otherlinks">
            </ul> -->
        </div>
        <div class="ph-tab__content" data-content="1">
            {%- if section.settings.menu_2 != blank -%}
            <ul>
              {%- for link in linklists[section.settings.menu_2].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          {% endif %} 
        </div>
    </div>
    <div class="ph-menu__content--mobile">
        <form action="/search" method="get" role="search" id="ph-search__form--mobile">
            <input type="text" name="q" placeholder="Search..." aria-label="Search" required>
        </form>
        <ul class="ph-menu__mobile--triggers">
            <li data-index='0'>{{ section.settings.menu_1_title }}</li>
            <li data-index='1'>{{ section.settings.menu_2_title }}</li>
        </ul> 
        <div class="ph-user__account--mob">
          <a href="/account/login">Account</a>
        </div>
      <!-- <div class="ph-i__icon">
          <img src="https://cdn.shopify.com/s/files/1/0891/3541/5562/files/phoria-animated-submit-edit.png">
        </div> -->
        <ul class="ph-submenu__mobile"  data-submenu="0">
          <li>{{ section.settings.menu_1_title }}</li>
          {%- if section.settings.menu_1 != blank -%}
            {%- for link in linklists[section.settings.menu_1].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          {% endif %}
            <div class="ph-tab__otherlinks">
              <span>{{ section.settings.other_links_title }}</span>
              {%- if section.settings.other_links != blank -%}
                {%- for link in linklists[section.settings.other_links].links -%}
                  <span><a href="{{ link.url }}">{{ link.title }}</a></span>
                {% endfor %}
              {% endif %}
            </div>
          <div class="ph-i__icon mobile">
            <img src="https://cdn.shopify.com/s/files/1/0891/3541/5562/files/phoria-animated-submit-edit.png" width="" height="">
          </div>
        </ul>
        <ul class="ph-submenu__mobile"  data-submenu="1">
           <li>{{ section.settings.menu_2_title }}</li>
          {%- if section.settings.menu_2 != blank -%}
            {%- for link in linklists[section.settings.menu_2].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          {% endif %}
          <div class="ph-i__icon mobile">
            <img src="https://cdn.shopify.com/s/files/1/0891/3541/5562/files/phoria-animated-submit-edit.png" width="" height="">
          </div>
        </ul>
    </div>
  <div class="ph-i__icon desktop">
    <img src="https://cdn.shopify.com/s/files/1/0891/3541/5562/files/phoria-animated-submit-edit.png" width="" height="">
  </div>
</div>
<div class="ph-menu__drawer right">
    <div class="ph-search__menu--close">
        Close
    </div>

    <form action="/search" method="get" role="search" id="ph-search__form">
        <input type="text" name="q" placeholder="Search..." aria-label="Search" required>
    </form>

    <div class="ph-search__suggestions">
        <span class="ph-search__suggestions--title">{{ section.settings.search_suggestions_title }}</span>
        {%- if section.settings.search_suggestions != blank -%}
          <ul class="ph-search__suggestions--list">
            {%- for link in linklists[section.settings.search_suggestions].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
    </div>
</div>
<header class="ph-header__container">
    <div class="ph-announcement__bar">
        <p class="ph-announcement-text">{{ section.settings.announcement_text }}</p>
        {% comment %} <span class="ph-announcement-timer" id="ph-countdown-timer"></span> {% endcomment %}

    </div>
    <div class="ph-header">
        <div class="ph-menu left">
            <ul class="ph-menu__items">
                <li class="ph-menu__item">{{ section.settings.menu_1_title }}</li>
                <li class="ph-menu__item">{{ section.settings.menu_2_title }}</li>
            </ul>
            <div class="ph-menu__icon">
                <span></span>
                <span></span>
            </div>
            <div class="ph-menu__close--icon">
                Close
            </div>
            <div class="ph-menu__back--icon">
                <svg width="7" height="13" viewBox="0 0 7 13" fill="none" xmlns="http://www.w3.org/2000/svg">
