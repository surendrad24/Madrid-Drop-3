<script>
  document.addEventListener("DOMContentLoaded", function () {
    const elements = {
        announcementBar: document.querySelector('.ph-announcement__bar'),
        menuleft: document.querySelector('.ph-menu.left > .ph-menu__items'),
        menuRight: document.querySelector('.ph-menu.right > .ph-menu__items > .ph-menu__item:first-child'),
        navOverlay: document.getElementById('ph-side__nav__overlay'),
        searchOverlay: document.getElementById('ph-search__nav__overlay'),
        drawerLeft: document.querySelector('.ph-menu__drawer.left'),
        drawerRight: document.querySelector('.ph-menu__drawer.right'),
        navCloseBtn: document.querySelector('.ph-nav__menu--close'),
        searchCloseBtn: document.querySelector('.ph-search__menu--close'),
        buttons: document.querySelectorAll(".ph-tab__button"),
        contents: document.querySelectorAll(".ph-tab__content"),
        menuIcon: document.querySelector(".ph-menu__icon"),
        menuCloseIconMob: document.querySelector(".ph-menu__close--icon"),
        menuLogo: document.querySelector(".ph-logo"),
        mobileTriggers: document.querySelector(".ph-menu__mobile--triggers"),
        submenusMobile: document.querySelectorAll(".ph-submenu__mobile"),
        submenusCloseBtnMobile: document.querySelector(".ph-menu__back--icon"),
        header: document.querySelector(".ph-header__container"),
        root: document.documentElement,
        iIcon: document.querySelector('.ph-i__icon.desktop')
    };

    const firstFold = window.innerHeight;
    const isHomePage = window.location.pathname === "/"; 
    const facetsContainer = document.querySelector('.facets-container')
    let scrolled
    let activeTabIndex
    const { animate, inView, transform } = Motion

    const animateRevealUp = (item, index, delay = 0.1) =>{
      animate(item, 
          { opacity: [0, 1], y: [20, 0] },  // Animate from y: 20 to y: 0, opacity 0 to 1
          { duration: 0.5, delay: index * delay, easing: "ease-out" } // Stagger effect
      );
    }
    // Toggle drawer visibility
    const toggleDrawer = (overlay, drawer, isOpen) => {
      overlay.classList.toggle('open', isOpen);
      drawer.classList.toggle('open', isOpen);
      inView(".ph-menu__drawer.left.open ul", (element) => {
        document.querySelectorAll('.ph-menu__drawer.left.open .ph-tab__content ul li').forEach((li, index) => {
            animateRevealUp(li, index);
        });
      }, { once: false })
      inView(elements.iIcon, (el) =>{
        animateRevealUp(el, 1, document.querySelectorAll('.ph-menu__drawer.left.open .ph-tab__content ul li').length * 0.1);
      })
      inView(".ph-menu__drawer.right.open .ph-search__suggestions--list", (element) => {
        document.querySelectorAll('.ph-menu__drawer.right.open .ph-search__suggestions--list li').forEach((li, index) => {
            animateRevealUp(li, index);
        });
      }, { once: false })
      if(window.innerWidth < 960){
        scrolled = window.scrollY > (isHomePage ? firstFold : -1)
        elements.announcementBar.style.display = isOpen ? 'none' : 'flex'
        
        document.documentElement.style.setProperty('--ph-menu-color', `${isOpen ? '#1D1D1D' : (scrolled || {{section.settings.is_header_transition}} == false) ? '#1D1D1D' : '#fff'}`);
        document.documentElement.style.setProperty('--ph-menu-cart-bg', `${isOpen ? '#1D1D1D' : (scrolled || {{section.settings.is_header_transition}} == false) ? '#1D1D1D' : '#fff'}`);
        document.documentElement.style.setProperty('--ph-menu-cart-text', `${isOpen ? '#fff' : (scrolled || {{section.settings.is_header_transition}} == false) ? '#fff' : '#1D1D1D'}`);
        elements.menuCloseIconMob.style.display = isOpen ? 'block' : 'none'
        elements.menuIcon.style.display = !isOpen ? 'flex' : 'none'
        const oldLogoColor = elements.menuLogo.dataset.logoColor
        elements.menuLogo.dataset.logoColor = isOpen ? "black" : (scrolled || {{section.settings.is_header_transition}} == false) ? 'black' : 'white';
// -------------------- Animations on smaller screen sizes ------------------------
        const mobileElements = {
          triggers: [...document.querySelector('.ph-menu__drawer.left.open .ph-menu__content--mobile .ph-menu__mobile--triggers').children],
          account: document.querySelector('.ph-user__account--mob'),
        }
  
        mobileElements.triggers.forEach((trigger, index) => {
            inView(trigger, (el) => {
              animateRevealUp(el, index, 0.3);
            }, { once: false});
        })
        inView(mobileElements.account, (el) => {
          animateRevealUp(el, 1, mobileElements.triggers.length * 0.3 );
        }, { once: false});
      } 
    };

    // Handle tab activation
    const activateTab = (index) => {
      
      elements.buttons.forEach(btn => btn.classList.remove("active"));
      elements.contents.forEach(content => content.classList.remove("active"));

      elements.buttons[index].classList.add("active");
      elements.contents[index].classList.add("active");
      setTimeout(()=>{
        activeTabIndex != index && document.querySelectorAll('.ph-menu__drawer.left.open .ph-tab__content ul')[index].querySelectorAll('li').forEach((li, index) => {
          animateRevealUp(li, index)
      });
      activeTabIndex = index
      }, 0)
    };

    // Handle menu clicks
    const handleMenuClick = (menu, overlay, drawer) => {
      return (event) => {
        if(menu.parentElement.classList.contains('left')){
          const firstChildText = menu.children[0]?.innerText.toLowerCase();
          const clickedText = event.target.innerText.toLowerCase();   
          activateTab(clickedText === firstChildText ? 0 : 1);
        }else{
          document.getElementById('ph-search__form').querySelector('input').focus()
        }
        toggleDrawer(overlay, drawer, true);
      };
    };

    elements.menuleft.addEventListener('click', handleMenuClick(elements.menuleft, elements.navOverlay, elements.drawerLeft));
    elements.menuIcon.addEventListener('click', handleMenuClick(elements.menuleft, elements.navOverlay, elements.drawerLeft));
    elements.menuRight.addEventListener('click', handleMenuClick(elements.menuRight, elements.searchOverlay, elements.drawerRight));

    // Handle close actions
    elements.navOverlay.addEventListener('click', () => toggleDrawer(elements.navOverlay, elements.drawerLeft, false));
    elements.navCloseBtn.addEventListener('click', () => toggleDrawer(elements.navOverlay, elements.drawerLeft, false));
    elements.menuCloseIconMob.addEventListener('click', () => toggleDrawer(elements.navOverlay, elements.drawerLeft, false));
    elements.searchOverlay.addEventListener('click', () => toggleDrawer(elements.searchOverlay, elements.drawerRight, false));
    elements.searchCloseBtn.addEventListener('click', () => toggleDrawer(elements.searchOverlay, elements.drawerRight, false));

    // Attach tab event listeners
    elements.buttons.forEach((button, index) => {
        button.addEventListener("click", () => activateTab(index));
    });

    
 function updateHeader() {
    scrolled = window.scrollY > (isHomePage ? firstFold : 0);

    if (isHomePage) {
        elements.header.classList.toggle("scrolled", scrolled);
      {% if section.settings.is_header_transition %}
        elements.root.style.setProperty("--ph-menu-color", scrolled ? "#1D1D1D" : "#fff");
        elements.root.style.setProperty("--ph-menu-cart-bg", scrolled ? "#1D1D1D" : "#fff");
        elements.root.style.setProperty("--ph-menu-cart-text", scrolled ? "#fff" : "#1D1D1D");
        elements.menuLogo.dataset.logoColor = scrolled ? "black" : "white";
      {% else %}
          elements.root.style.setProperty("--ph-menu-color", "#1D1D1D");
        elements.root.style.setProperty("--ph-menu-cart-bg", "#1D1D1D");
        elements.root.style.setProperty("--ph-menu-cart-text", "#fff");
        elements.menuLogo.dataset.logoColor = "black";
      {% endif %}
    } else {
        const headerHeight = elements.header.getBoundingClientRect().height;
        elements.root.style.setProperty("--header-height", scrolled ? `${headerHeight}px` : "auto");
    }
}

    // Initial setup
    {% if section.settings.is_header_transition %}
    const initialColor = isHomePage ? "#fff" : "#1D1D1D";
    const initialCartBg = isHomePage ? "#fff" : "#1D1D1D";
    const initialCartText = isHomePage ? "#1D1D1D" : "#fff";
    const initialLogoColor = isHomePage ? "white" : "black";
    {% else %}
      const initialColor = "#1D1D1D";
      const initialCartBg = "#1D1D1D";
      const initialCartText = "#fff";
      const initialLogoColor = "black";
    {% endif %}
    
    elements.root.style.setProperty("--ph-menu-color", initialColor);
    elements.root.style.setProperty("--ph-menu-cart-bg", initialCartBg);
    elements.root.style.setProperty("--ph-menu-cart-text", initialCartText);
    elements.menuLogo.dataset.logoColor = initialLogoColor;
    
    // Attach event listener
    window.addEventListener("scroll", updateHeader);
    if(window.innerWidth < 960){
      let activeMobileSubmenuIndex = 0
      const openSubmenuMobile = (index) =>{
        elements.submenusMobile[index]?.classList.add('active');
        elements.menuCloseIconMob.style.display = 'none';
        elements.submenusCloseBtnMobile.style.pointerEvents = 'auto'
        elements.submenusCloseBtnMobile.style.visibility = 'visible'
        elements.submenusCloseBtnMobile.style.color = '#1D1D1D'
// ---------------- Animations on smaller screen sizes ---------------------
        const mobileElements = {
          submenuItems: [...document.querySelector('.ph-menu__drawer.left.open .ph-menu__content--mobile .ph-submenu__mobile.active').children]
        }
        mobileElements.submenuItems.forEach((submenuItem, index) =>{
         inView(submenuItem, (el) =>{
           animateRevealUp(el, index);
         }) 
        })
      }
      const closeSubmenuMobile = () =>{
        elements.submenusMobile[activeMobileSubmenuIndex].classList.remove('active');
        elements.menuCloseIconMob.style.display = 'block';
        elements.submenusCloseBtnMobile.style.pointerEvents = 'none'
        elements.submenusCloseBtnMobile.style.visibility = 'hidden'
        elements.submenusCloseBtnMobile.style.color = 'var(--ph-menu-color)'
      }
      elements.mobileTriggers.addEventListener('click', (e)=>{
        openSubmenuMobile(e.target.dataset.index)
        activeMobileSubmenuIndex = e.target.dataset.index
      })
      elements.submenusCloseBtnMobile.addEventListener('click', closeSubmenuMobile)
    }

      const announcementText = document.querySelector('.ph-announcement-text');
  if (announcementText) {
    // Get the original HTML
    const originalHTML = announcementText.innerHTML;
    
    // Check if it contains the divider
    if (originalHTML.includes('//')) {
      // Create a temporary div to work with the HTML
      const tempDiv = document.createElement('div');
      tempDiv.innerHTML = originalHTML;
      
      // Get the text content to find the position of '//'
      const fullText = tempDiv.textContent;
      const dividerIndex = fullText.indexOf('//');
      
      if (dividerIndex !== -1) {
        // Add a wrapper for the mobile version that preserves ALL content after the divider
        announcementText.classList.add('has-divider');
        
        // Clone the original to preserve all HTML tags and structure
        const mobileContent = tempDiv.cloneNode(true);
        
        // Create the HTML structure with appropriate wrappers
        announcementText.innerHTML = 
          '<span class="before-divider">' + originalHTML.substring(0, originalHTML.indexOf('//') + 2) + '</span>' +
          '<span class="after-divider">' + originalHTML.substring(originalHTML.indexOf('//') + 2) + '</span>';
      }
    }
  }
});

</script>

