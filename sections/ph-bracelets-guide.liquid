<style>
  .ph-bracelet-sizing-guide-container {
    width: 100%;
    max-width: 80vw;
    margin: 0 auto;
  }
  
  .ph-bracelet-sizing-guide-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 36px;
  }
  
  .ph-bracelet-sizing-guide-heading {
    font-size: 1.23vw;
    margin-bottom: 27px;
    margin-top: 0px;
    text-transform: uppercase;
    font-weight: 500;
    width: 100%;
  }
  
  .ph-bracelet-sizing-guide-intro {
    font-size: 10px;
    line-height: 2.3;
    margin-bottom: 90px;
    text-transform: uppercase;
    /* max-width: 800px; */
  }
  
  .ph-bracelet-sizing-method {
    width: 100%;
    margin-bottom: 36px;
  }
  
  .ph-bracelet-sizing-method-heading {
    font-size: 1.25vw;
    line-height: 1.2;
    margin-top: 0px;
    margin-bottom: 27px;
    text-transform: uppercase;
    font-weight: 500;
  }
  
  .ph-bracelet-sizing-method-description {
    font-size: 10px;
    line-height: 2.3;
    text-transform: uppercase;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .ph-bracelet-sizing-button-wrapper {
    margin: 36px 0 0 0;
  }
  
  .ph-bracelet-sizing-button {
    display: inline-block;
    min-width: 300px;
    padding: 13px 31px;
    background-color: #1c1c1c;
    color: #fff;
    text-transform: uppercase;
    font-size: 12px;
    text-decoration: none;
    text-align: center;
    transition: all 0.3s ease;
    font-family: 'PhoriaBold';
    line-height: 2.3;
    letter-spacing: 0px;
  }
  
  .ph-bracelet-sizing-button:hover {
    background-color: #000;
  }
  
  .ph-bracelet-sizing-divider {
    width: 100%;
    text-align: center;
    position: relative;
  }
  
  .ph-bracelet-sizing-divider span {
    display: inline-block;
    text-transform: uppercase;
    font-size: 12px;
    position: relative;
    margin-bottom: 36px;
    z-index: 1;
    font-family: 'PhoriaBold';
  }
  
  .ph-bracelet-sizing-steps {
    display: flex;
    flex-direction: column;
    gap: 18px;
    /* max-width: 800px; */
    margin: 0 auto;
  }
  
  .ph-bracelet-sizing-step {
    font-size: 10px;
    line-height: 2.3;
    text-transform: uppercase;
    text-align: center;
  }
  
  @media screen and (max-width: 989px) {
    .ph-bracelet-sizing-guide-inner{
      padding: 0 18px;
    }
    .ph-bracelet-sizing-guide-container {
      padding: 0px 18px;
      max-width: none;
    }
    
    .ph-bracelet-sizing-guide-heading {
      font-size: 18px;
      margin-bottom: 27px;
    }
    
    .ph-bracelet-sizing-method-heading {
      font-size: 18px;
      margin-bottom: 20px;
    }
    
    .ph-bracelet-sizing-button {
      font-size: 12px;
    }
    
    .ph-bracelet-sizing-steps {
      gap: 20px;
    }
  }
</style>

<div class="ph-bracelet-sizing-guide-container">
  <div class="ph-bracelet-sizing-guide-inner">
    {% if section.settings.heading != blank %}
      <h2 class="ph-bracelet-sizing-guide-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.intro_text != blank %}
      <div class="ph-bracelet-sizing-guide-intro">{{ section.settings.intro_text }}</div>
    {% endif %}
    
    <!-- Method 1: Paper Wrist Sizer -->
    <div class="ph-bracelet-sizing-method ph-sizing-method-1">
      {% if section.settings.method1_heading != blank %}
        <h3 class="ph-bracelet-sizing-method-heading">{{ section.settings.method1_heading }}</h3>
      {% endif %}
      
      {% if section.settings.method1_description != blank %}
        <div class="ph-bracelet-sizing-method-description">{{ section.settings.method1_description }}</div>
      {% endif %}
      
      {% if section.settings.method1_button_text != blank and section.settings.method1_pdf_link != blank %}
        <div class="ph-bracelet-sizing-button-wrapper">
          <a href="{{ section.settings.method1_pdf_link }}" class="ph-bracelet-sizing-button" target="_blank" download>
            {{ section.settings.method1_button_text }}
          </a>
        </div>
      {% endif %}
    </div>
    
    <!-- Divider -->
    {% if section.settings.divider_text != blank %}
      <div class="ph-bracelet-sizing-divider">
        <span>{{ section.settings.divider_text }}</span>
      </div>
    {% endif %}
    
    <!-- Method 2: Manual Measurement -->
    <div class="ph-bracelet-sizing-method ph-sizing-method-2">
      {% if section.settings.method2_heading != blank %}
        <h3 class="ph-bracelet-sizing-method-heading">{{ section.settings.method2_heading }}</h3>
      {% endif %}
      
      <div class="ph-bracelet-sizing-steps">
        {% if section.settings.method2_step1 != blank %}
          <div class="ph-bracelet-sizing-step">{{ section.settings.method2_step1 }}</div>
        {% endif %}
        
        {% if section.settings.method2_step2 != blank %}
          <div class="ph-bracelet-sizing-step">{{ section.settings.method2_step2 }}</div>
        {% endif %}
        
        {% if section.settings.method2_step3 != blank %}
          <div class="ph-bracelet-sizing-step">{{ section.settings.method2_step3 }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof Motion !== 'undefined' && {{ section.settings.enable_animations | default: true }}) {
      const { animate, inView } = Motion;
      
      // Animate container
      const container = document.querySelector('.ph-bracelet-sizing-guide-container');
      if (container) {
        inView(container, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate heading
      const heading = document.querySelector('.ph-bracelet-sizing-guide-heading');
      if (heading) {
        inView(heading, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.2, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate intro text
      const introText = document.querySelector('.ph-bracelet-sizing-guide-intro');
      if (introText) {
        inView(introText, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.4, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate first method
      const firstMethod = document.querySelector('.ph-sizing-method-1');
      if (firstMethod) {
        inView(firstMethod, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.6, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate divider
      const divider = document.querySelector('.ph-bracelet-sizing-divider');
      if (divider) {
        inView(divider, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.8, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate second method
      const secondMethod = document.querySelector('.ph-sizing-method-2');
      if (secondMethod) {
        inView(secondMethod, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 1.0, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate steps
      const steps = document.querySelector('.ph-bracelet-sizing-steps');
      if (steps) {
        inView(steps, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 1.2, easing: "ease-out" }
          );
        }, { once: true });
      }
    }
  });
</script>

{% schema %}
{
  "name": "Ph Bracelet Sizing",
  "tag": "section",
  "class": "ph-bracelet-sizing-guide-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "HOW TO FIND YOUR BRACELET SIZE"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Introduction Text",
      "default": "UNSURE OF YOUR BRACELET SIZE? WE WANT TO MAKE IT AS EASY AS POSSIBLE FOR YOU TO MEASURE AT HOME."
    },
    {
      "type": "header",
      "content": "Method 1: Paper Wrist Sizer"
    },
    {
      "type": "text",
      "id": "method1_heading",
      "label": "Method 1 Heading",
      "default": "1) MAKE YOUR OWN PAPER WRIST SIZER"
    },
    {
      "type": "textarea",
      "id": "method1_description",
      "label": "Method 1 Description",
      "default": "CLICK ON THE LINK BELOW. FOLLOW THE INSTRUCTIONS AND PRINT IT OUT ONTO A4 PAPER."
    },
    {
      "type": "text",
      "id": "method1_button_text",
      "label": "Method 1 Button Text",
      "default": "MAKE YOUR OWN WRIST SIZER - CLICK TO PRINT"
    },
    {
      "type": "url",
      "id": "method1_pdf_link",
      "label": "Method 1 PDF Link"
    },
    {
      "type": "text",
      "id": "divider_text",
      "label": "Divider Text",
      "default": "OR"
    },
    {
      "type": "header",
      "content": "Method 2: Manual Measurement"
    },
    {
      "type": "text",
      "id": "method2_heading",
      "label": "Method 2 Heading",
      "default": "2) MEASURE YOUR WRIST BY:"
    },
    {
      "type": "textarea",
      "id": "method2_step1",
      "label": "Method 2 Step 1",
      "default": "1) WRAPPING A STRIP OF PAPER, OR PIECE OF STRING, AROUND YOUR WRIST WHERE YOU'D LIKE YOUR NEW BRACELET TO SIT."
    },
    {
      "type": "textarea",
      "id": "method2_step2",
      "label": "Method 2 Step 2",
      "default": "2) USE THE CHART BELOW TO DETERMINE YOUR BRACELET SIZE."
    },
    {
      "type": "textarea",
      "id": "method2_step3",
      "label": "Method 2 Step 3",
      "default": "3) MEASURE THIS LENGTH WITH A RULER TO FIND YOUR CIRCUMFERENCE. FALLING BETWEEN TWO SIZES? WE RECOMMEND SIZING UP IF YOU ENJOY A LOOSER FIT OR SIZING DOWN IF YOU PREFER IT TO FIT MORE SNUG."
    },
    {
      "type": "checkbox",
      "id": "enable_animations",
      "label": "Enable Animations",
      "default": true,
      "info": "Enable fade-in animations when content comes into view"
    }
  ],
  "presets": [
    {
      "name": "Ph Bracelet Sizing"
    }
  ]
}
{% endschema %}