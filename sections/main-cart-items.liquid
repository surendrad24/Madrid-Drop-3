<script>
  document.addEventListener("DOMContentLoaded", ()=>{
    if (!customElements.get("cart-gift-note-checkbox")) {
  customElements.define(
    "cart-gift-note-checkbox",
    class CartGiftNoteCheckbox extends HTMLElement {
      constructor() {
        super();
        this.checkbox = this.querySelector('input[type="checkbox"]');

        if (!this.checkbox) return;

        this.checkbox.addEventListener("change", () => {
          if (this.checkbox.checked) {
            // Add gift-note product
            fetch(`/products/gift-note.js`)
              .then((res) => res.json())
              .then((product) => {
                const variantId = product.variants[0].id;

                return fetch("/cart/add.js", {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json",
                    Accept: "application/json",
                  },
                  body: JSON.stringify({
                    items: [{ id: variantId, quantity: 1 }],
                  }),
                });
              })
              .then(() => {
                // localStorage.setItem('openCartAfterReload', 'true');
                location.reload();
              })
              .catch((err) => {
                console.error("Failed to add gift note product:", err);
              });
          } else {
            // Remove gift-note product
            fetch("/cart.js")
              .then((res) => res.json())
              .then((cart) => {
                const giftNoteItem = cart.items.find((item) =>
                  item.handle === "gift-note"
                );

                if (!giftNoteItem) return;

                return fetch("/cart/change.js", {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json",
                    Accept: "application/json",
                  },
                  body: JSON.stringify({
                    id: giftNoteItem.key,
                    quantity: 0,
                  }),
                });
              })
              .then(() => {
                // localStorage.setItem('openCartAfterReload', 'true');
                location.reload();
              })
              .catch((err) => {
                console.error("Failed to remove gift note product:", err);
              });
          }
        });

        // Initialize checkbox state based on whether gift-note is in the cart
        fetch("/cart.js")
          .then((res) => res.json())
          .then((cart) => {
            const giftNoteInCart = cart.items.some(
              (item) => item.handle === "gift-note"
            );
            this.checkbox.checked = giftNoteInCart;
          });
      }
    }
  );
}
  document.addEventListener('cartUpdated', function(event) {
    console.log('Event received:', event.detail.message);
    // Initialize checkbox state based on whether gift-note is in the cart
        fetch("/cart.js")
          .then((res) => res.json())
          .then((cart) => {
            const giftNoteInCart = cart.items.some(
              (item) => item.handle === "gift-note"
            );
            console.log("giftNoteInCart", giftNoteInCart)
            document.querySelector('cart-gift-note-checkbox input[type="checkbox"]').checked = giftNoteInCart;
          });
  })
  })
</script>
                
<script>
  document.addEventListener("DOMContentLoaded", () => {    
  const accordionElements = {
    title: document.querySelectorAll('#{{ section.id }} .ph-cart-accordion__item--title'),
    content: document.querySelectorAll('#{{ section.id }} .ph-cart-accordion__item--content'),
  }

  accordionElements.title.forEach((item, index) => {
    item.addEventListener('click', () => {
      const isCurrentlyExpanded = accordionElements.content[index].classList.contains('expended');
      
      // Toggle the clicked one
      accordionElements.content[index].classList.toggle('expended');
      item.querySelector('svg').classList.toggle('rotate');

      const heading = item.querySelector('.ph-cart-accordion__item--title > h2');
      heading.style.fontFamily = isCurrentlyExpanded ? "PhoriaRegular" : "PhoriaBold";

      // Close others
      accordionElements.content.forEach((content, i) => {
        if (i !== index) {
          content.classList.remove('expended');
          accordionElements.title[i].querySelector('svg').classList.remove('rotate');
          accordionElements.title[i].querySelector('.ph-cart-accordion__item--title > h2').style.fontFamily = "PhoriaRegular";
        }
      });
    });
  });
});


  document.addEventListener('DOMContentLoaded', () => {
    // Check if Motion library is available
    if (typeof Motion !== 'undefined') {
      const { animate, inView, transform } = Motion;
      
      // Animate each banner item individually when it comes into view
      const cartElements = [...document.querySelector('.main-cart .container').children];
      
      cartElements.forEach((elem, index) => {
        inView(elem, (el) => {
          // Apply different animation based on banner position
          const delay = index * 0.2; // Stagger delay for multiple banners
          const xOffset = index % 2 === 0 ? '100px' : '100px'; // Alternate slide direction
          
          animate(el, 
            { opacity: [0, 1], y: [xOffset, 0] }, 
            { duration: 0.7, delay: delay, easing: "ease-out" }
          );
        }, { once: true, amount: 0.1 });
      });
      
      const cartContents = [...document.querySelector('.ph-main__cart').children];
      
      cartContents.forEach((elem, index) => {
        inView(elem, (el) => {
          // Apply different animation based on banner position
          const delay = index * 0.5; // Stagger delay for multiple banners
          const xOffset = index % 2 === 0 ? '100px' : '100px'; // Alternate slide direction
          
          animate(el, 
            { opacity: [0, 1], y: [xOffset, 0] }, 
            { duration: 0.7, delay: delay, easing: "ease-out" }
          );
        }, { once: true, amount: 0.1 });
      });
    }
  });
</script>
