{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- unless settings.cart_type == 'drawer' -%}
  {{ 'component-discounts.css' | asset_url | stylesheet_tag }}
  {{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

{% style %}
  {% render 'section-margin' %}
{% endstyle %}

<style>
    #{{ section.id }}.ph-cart-accordion {
      margin-top: 36px;
    }

    .ph-cart-accordion__title {
      font-size: 2.266vw;
      line-height: 1.2; 
      margin-bottom: 0px;
    }

    #{{ section.id }} .ph-cart-accordion__item {
        border-top: 1px solid #f1f2ee;
        max-width: 276px;
    }
    #{{ section.id }} .ph-cart-accordion__item:last-child {
        border-bottom: 1px solid #f1f2ee;
    }

    #{{ section.id }} .ph-cart-accordion__item--title {
        position: relative;
    }

    #{{ section.id }} .ph-cart-accordion__item--title h2 {
      font-size: 10px;
      padding: 18px 0;
      text-transform: uppercase;
      font-family: 'PhoriaRegular';
      margin: 0;
      display: inline-block;
      width: 90%;
      line-height: 1.75;
    }

    #{{ section.id }} .ph-cart-accordion__item--title svg {
        width: 10px;
        height: 10px;
        position: absolute;
        top: 50%;
        right: 0;
        transform: translateY(-50%) rotate(-45deg);
        transition: all 0.2s ease-in-out;
    }
    #{{ section.id }} svg.rotate{
        transform: translateY(-50%) rotate(0deg);
    }

    #{{ section.id }} .ph-cart-accordion__item--content {
        font-size: 10px;
        line-height: 2.3;
        font-weight: 400;
        font-family: 'PhoriaRegular';
        text-transform: uppercase;
        max-height: 0;
        padding: 0;
        overflow: hidden;
        transition: all .2s ease-in-out;
    }
  .ph-cart-accordion__item--content a{
    word-wrap: break-word;
  }
    #{{ section.id }} .ph-cart-accordion__item--image {
      width: 100%;
      height: 100%;
      max-width: 276px;
    }
    #{{ section.id }} .ph-cart-accordion__item--image img{
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    #{{ section.id }} .ph-cart-accordion__item--content p strong{
       font-family: 'PhoriaBold';
       font-weight: 400 !important;
    }
    #{{ section.id }} .ph-cart-accordion__item--content.expended{
        /* height: auto; */
        max-height: 1500px;
    }
    .ph-cart__inner{
       display: flex;
        flex-direction: column;
      flex: 1;
      padding-left: 36px;
      
    }
  .ph-cart__item--details{
    justify-content: center;
  }
  .ph-cart-item__bottom{
    justify-content: flex-end;
    column-gap: 5vw;
    max-width: 367px;
  }
@media screen and (max-width: 1120px){
  .ph-cart-item__bottom{
    column-gap: 7vw;
  }
}
  /* -- complementary gift box checkbox styles  */

.ph-cart-custom-checkbox {
  display: flex;
  align-items: center;
  cursor: pointer;
  font-size: 10px;
  gap: 8px;
  user-select: none;
  width: 44.2rem;
  max-width: 100%;
  margin-bottom: 18px;
}
.ph-cart-custom-title{
  font-size: 10px;
  font-family: 'PhoriaBold';
  font-weight: 400 !important;
  line-height: 2.3;
  width: 44.2rem;
  max-width: 100%;
}

.ph-cart-custom-checkbox input[type="checkbox"].sr-only {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

.ph-cart-custom-checkbox .checkmark {
  width: 18px;
  height: 18px;
  border: 1px solid #000;
  display: inline-block;
  position: relative;
  transition: all 0.2s;
  flex-shrink: 0;
}

.ph-cart-custom-checkbox input:checked + .checkmark::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 39%;
  width: 5px;
  height: 10px;
  border: solid black;
  border-width: 0 1.5px 1.5px 0;
  transform: translate(-50%, -50%) rotate(45deg);
}
  .totals__shipping.subtitle{
    font-size: 10px;
    line-height: 2.3;

  }
  .totals__shipping-value{
    font-size: 10px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .totals__shipping-value strong{
    font-family: 'PhoriaBold';
    font-weight: 400 !important;
  }
  .totals__shipping-value span{
    width: 20px;
    height: 20px;
    border: 1px solid #1D1D1D;
    display: inline-block;
    position: relative;
  }
  .totals__shipping-value span::before{
    content: '';
    width: 12px;
    height: 12px;
    background: #1D1D1D;
    position: absolute;
    top: 50.5%;
    left: 50.5%;
    transform: translate(-50%, -50%);
  }

  .ph-cart__checkoutbtn{
    margin-top: 20px;
  }
  .ph-cart__checkoutbtn .cart__checkout-button{
    text-transform: uppercase;
    font-size: 12px;
    line-height: 2.3;
    padding: 13px 18px;
    font-weight: normal !important;
  }
  .ph-empty-cart__text{
    text-align: center;
    font-size: 10px;
    font-family: 'PhoriaRegular';
    margin: 0;
    margin-top: 18px;
  }
  .ph-empty-cart__text strong{
    font-family: 'PhoriaBold';
    font-weight: 400 !important;
  }
  {% if cart.item_count == 0 %}
  .main-cart__wrapper{
    justify-content: center;
  }
  @media screen and (min-width: 989px){
    .section-cart-items{
      height: 347px;
    }
  }
  {% endif %}
@media screen and (max-width: 989px){
  .ph-cart-custom-checkbox, .ph-cart-custom-title{
    margin-left: 0;
  }
}

  /* -----------------------------------------  */
  @media screen and (min-width: 990px){ 
    .ph-cart__checkoutbtn{
      max-width: calc(50% + 15px);
      margin-left: auto;
    }
    .section-cart-items{
      padding-top: 88px !important;
    }
    {% if template == 'cart' %}
     .container{
      padding-left: 36px;
      padding-right: 36px; 
     }
    {% endif %}
     #{{ section.id }}.ph-cart-accordion {
      width: 25%;
    }
  }
  
    @media screen and (max-width: 989px){
      .section-cart-items{
        padding-top: 36px !important;
      }
      .ph-cart__inner{
        padding-left: 0;
      }
      #{{ section.id }}.ph-cart-accordion {
        order: 2;
        margin-top: 36px;
        width: 100%;
      }
      #{{ section.id }} .ph-cart-accordion__item {
        max-width: none;
      }
      #{{ section.id }} .ph-cart-accordion__item--image {
        max-width: none;
      }
     .ph-cart-accordion__title {
          font-size: 22px;
          margin-bottom: 9px;
          margin-top: 0px;
      }
      #{{ section.id }} .ph-cart-accordion__item--title h2{
        font-size: 12px;
      }
      #{{ section.id }} .ph-cart-accordion__item--title svg {
        width: 10px;
        height: 10px;
      }
      cart-items{
        padding-bottom: 0;
        margin-bottom: 0;
        border-color: #f1f2ee;
      }
      .cart-item:last-child{
        border-bottom: 0;
      }
    }
  @media screen and (max-width: 649px){
    .ph-cart-item__bottom{
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      column-gap: 18px;
      row-gap: 18px;
      max-width: 367px;
    }
    .cart-item cart-remove-button a{
      padding: 0;
      margin-top: 9px;
    }
    .container{
      padding-left: 18px; 
      padding-right: 18px; 
    }
  }



  .price-compare-price-main-cart {
    text-decoration: line-through;
    font-family: var(--font-body-family);
    font-size: 10px;
  }
</style>

<script>console.log("Cart -- > ", {{cart | json}})</script>
<div class="main-cart section-{{ section.id }}">
  <div class="container">
    {% comment %}<div class="page-header">
      <div class="page-header__inner">
        <h1 class="main-page-title page-title title--page h3">{{ 'sections.cart.title' | t }}</h1>
        <a href="{{ routes.all_products_collection_url }}" class="button button--simple button--arrow focus-inset">
          <span>{{ 'general.continue_shopping' | t }}</span>
        </a>
      </div>
    </div>{% endcomment %}

    <h1 class="ph-cart-accordion__title" {% if cart.item_count == 0 %}style="text-align: center;"{% endif %}>Basket</h1>
    <div class="main-cart__wrapper ph-main__cart">
      {% if cart.item_count == 0 %} <p class="ph-empty-cart__text">Your Basket is empty. <a href="/collections/shop-all"><strong>Click here</strong></a> to continue shopping.</p> {% else %}
      <div id="{{ section.id }}" class="ph-cart-accordion">
        {% if section.settings.acc_title1 != blank %}
        <div class="ph-cart-accordion__item">
            <div class="ph-cart-accordion__item--title">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
                <h2>{{ section.settings.acc_title1 }}</h2>
            </div>
            <div class="ph-cart-accordion__item--content">{{ section.settings.acc_content1 }}</div>
          </div>
        {% endif %}
        {% if section.settings.acc_title2 != blank %}
        <div class="ph-cart-accordion__item">
            <div class="ph-cart-accordion__item--title">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
                <h2>{{ section.settings.acc_title2 }}</h2>
            </div>
            <div class="ph-cart-accordion__item--content">{{ section.settings.acc_content2 }}</div>
          </div>
        {% endif %}
        {% if section.settings.acc_title3 != blank %}
        <div class="ph-cart-accordion__item">
            <div class="ph-cart-accordion__item--title">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
                <h2>{{ section.settings.acc_title3 }}</h2>
            </div>
            <div class="ph-cart-accordion__item--content">
              {{ section.settings.acc_content3 }}
              {% if section.settings.acc_image3 != blank %}
                <a href="{{ section.settings.acc_image3_link }}"><div class="ph-cart-accordion__item--image">
                  <img src="{{ section.settings.acc_image3 | image_url }}" width="" height="" alt="{{ section.settings.acc_title3  }}">
                </div></a>
              {% endif %}
            </div>
          </div>
        {% endif %}
        {% if section.settings.acc_title4 != blank %}
        <div class="ph-cart-accordion__item">
            <div class="ph-cart-accordion__item--title">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
                <h2>{{ section.settings.acc_title4 }}</h2>
            </div>
            <div class="ph-cart-accordion__item--content">{{ section.settings.acc_content4 }}</div>
        </div>
        {% endif %}
        {% if section.settings.acc_title5 != blank %}
        <div class="ph-cart-accordion__item">
            <div class="ph-cart-accordion__item--title">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
                <h2>{{ section.settings.acc_title5 }}</h2>
            </div>
            <div class="ph-cart-accordion__item--content">{{ section.settings.acc_content5 }}</div>
          </div>
        {% endif %}
      </div>
      <div class="ph-cart__inner">
      <cart-items class="{% if cart == empty %} is-empty{% endif %}">
        <div id="main-cart-shipping" data-id="{{ section.id }}">
					{% comment %}<p class="main-cart--title h3">{{ 'sections.cart.title' | t }}</p>{% endcomment %}
          <div class="js-contents-shipping">
            {% if settings.show_shipping %}
              <div class="cart-shipping" data-min-spend="{{ settings.min_spend | times: 100.0 }}" data-total="{{ cart.total_price }}"
                data-message = " {{ settings.message_shipping }}">
                <span class="cart-shipping__progress">
                  <span class="cart-shipping__progress-current"></span>
                </span>
                <p class="cart-shipping__message cart-shipping__message_default active secondary_text"></p>
                <p class="cart-shipping__message cart-shipping__message_success secondary_text">
                  {{ settings.message_shipping_free }}
                </p>
              </div>
            {% endif %}
          </div>
        </div>
        <div class="cart__warnings">
          <div class="cart__empty-wrapper">
            <p class="cart__empty-text h3">{{ 'sections.cart.empty' | t }}</p>
          </div>
          <a href="{{ routes.collections_url | sort_by: 'best-selling' }}" class="button button--tertiary focus-inset secondary_text">
           <span>  {{ 'general.cart.button_label' | t }} </span>
          </a>
        </div>

        <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="cart">
          <div id="main-cart-items" data-id="{{ section.id }}">
            <div class="js-contents">
              {%- if cart != empty -%}
                <div class="cart-items">
									{%- for item in cart.items -%}
										<div class="cart-item" id="CartItem-{{ item.index | plus: 1 }}">

											<div class="cart-item__media">
												{% if item.image %}
													<div
														class="cart-item__media-wrapper"
														{%- if settings.cart_image_ratio == 'landscape' -%}
															style="padding-bottom: 75%;"
														{%- endif -%}
														{%- if settings.cart_image_ratio == 'portrait' -%}
															style="padding-bottom: 133%;"
														{%- endif -%}
														{%- if settings.cart_image_ratio == 'square' -%}
															style="padding-bottom: 100%;"
														{%- endif -%}
													>
														{% assign width_ratio =  1 %}
														{% if item.image.width < item.image.height or settings.cart_image_ratio == 'landscape'  %}
															{% assign width_ratio =  1 %}
														{% elsif item.image.width > item.image.height %}
															{% assign width_ratio =  item.image.width | plus: 0.0 | divided_by: item.image.height | round: 2 %}
															{% if settings.cart_image_ratio == 'portrait' %}
																{% assign width_ratio = width_ratio | times: 1.3 %}
															{% endif %}
														{% endif %}

														{% assign width = 140 | times: width_ratio %}

														<img
															class="cart-item__image"
															src="{{ item.image | image_url }}"
															alt="{{ item.image.alt | escape }}"
															loading="lazy"
															width="{{ width }}"
															height="auto"
															{%- if settings.cart_image_fit == 'contain' -%}
																style="object-fit: contain;"
															{%- endif -%}
															{%- if settings.cart_image_fit == 'cover' -%}
																style="object-fit: cover;"
															{%- endif -%}
														>
													</div>
												{% endif %}
											</div>

											<div class="cart-item__info">
												<div class="cart-item__top cart-item__row ph-cart__item--details"> 
													<div class="cart-item__col cart-item__details">
															{%- if settings.cart_show_vendor -%}
																<p class="card__subtitle">{{ item.product.vendor }}</p>
															{%- endif -%}
			
															<a href="{{ item.product.url }}" class="cart-item__name break">
																<span>{{ item.product.title | escape }}</span>
															</a>
			
															{%- if item.variant.available and item.unit_price_measurement -%}
																<div class="unit-price caption">
																	<span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
																	{% if settings.currency_code_enabled %}
																		{{ item.variant.unit_price | money_with_currency }}
																	{% else %}
																		{{ item.variant.unit_price | money }}
																	{% endif %}
																	<span aria-hidden="true">/</span>
																	<span class="visually-hidden">&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span>
																	{%- if item.variant.unit_price_measurement.reference_value != 1 -%}
																		{{- item.variant.unit_price_measurement.reference_value -}}
																	{%- endif -%}
																	{{ item.variant.unit_price_measurement.reference_unit }}
																</div>
															{%- endif -%}
			
															{%- if item.product.has_only_default_variant == false
																or item.properties.size != 0
																or item.selling_plan_allocation != null
															-%}
																<dl class="product-option__group secondary_text">
                                                                  {% if item.product.metafields.custom.finish.value != blank %}
                                                          			<div class="product-option">
                                                                          <dd>Finish: <span style="font-size: 10px; font-family: 'PhoriaBold'; font-weight: 400 !important;">{{ item.product.metafields.custom.finish.value }}</span></dd>
                                                                      </div>
                                                                  {% endif %}
                                                                  {% if item.product.metafields.custom.stone.value != blank %}
                                                        			<div class="product-option">
                                                                        <dd>Stone: <span style="font-size: 10px; font-family: 'PhoriaBold'; font-weight: 400 !important;">{{ item.product.metafields.custom.stone.value }}</span></dd>
                                                                    </div>
                                                                  {% endif %}
																	{%- if item.product.has_only_default_variant == false -%}
																		{%- for option in item.options_with_values -%}
																			<div class="product-option">
																				<dd>{% if option.name == 'Denominations' %}Price{% else %}{{ option.name }}{% endif %}: <span style="font-size: 10px; font-family: 'PhoriaBold'; font-weight: 400 !important;">{{ option.value }}</span></dd>
																			</div>
																		{%- endfor -%}
																	{%- endif -%}
																	{%- for property in item.properties -%}
																		{%- assign property_first_char = property.first | slice: 0 -%}
																		{%- if property.last != blank and property_first_char != '_' -%}
																			<div class="product-option">
																				<dt>{{ property.first }}:</dt>
																				<dd>
																					{%- if property.last contains '/uploads/' -%}
																						<a href="{{ property.last }}" target="_blank">
																							{{ property.last | split: '/' | last }}
																						</a>
																					{%- else -%}
																						{{ property.last }}
																					{%- endif -%}
																				</dd>
																			</div>
																		{%- endif -%}
																	{%- endfor -%}
																</dl>
			
																<p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
															{%- endif -%}
			
															<ul
																class="discounts list-unstyled"
																role="list"
																aria-label="{{ 'customer.order.discount' | t }}"
															>
																{%- for discount in item.discounts -%}
																	<li class="discounts__discount">
																		{%- render 'icon-discount' -%}
																		{{ discount.title }}
																	</li>
																{%- endfor -%}
															</ul>
			
															<p class="cart-item__error" id="Line-item-error-{{ item.index | plus: 1 }}">
																<span class="cart-item__error-text"></span>
															</p>
													</div>

													<div class="cart-item__col cart-item__prices_and_totals">
														<div class="cart-item__prices">
															<div class="cart-item__price-wrapper">
																{%- if item.original_price != item.final_price -%}
																	<dl class="cart-item__discounted-prices">
																		<dt class="visually-hidden">
																			{{ 'products.product.price.regular_price' | t }}
																		</dt>
																		<dd>
																			<span class="cart-item__old-price price">
																				{% if settings.currency_code_enabled %}
																					{{ item.original_price | money_without_trailing_zeros }}
																				{% else %}
																					{{ item.original_price | money_without_trailing_zeros }}
																				{% endif %}
																			</span>
																		</dd>
																		<dt class="visually-hidden">
																			{{ 'products.product.price.sale_price' | t }}
																		</dt>
																		<dd class="price price_sale">
																			{% if settings.currency_code_enabled %}
																				{{ item.final_price | money_without_trailing_zeros }}
																			{% else %}
																				{{ item.final_price | money_without_trailing_zeros }}
																			{% endif %}
																		</dd>
																	</dl>
																{%- else -%}
																	<span class="price">
																		{% if settings.currency_code_enabled %}
																			{{ item.original_price | money_without_trailing_zeros }}
																		{% else %}
																			{{ item.original_price | money_without_trailing_zeros }}
																		{% endif %}
																	</span>
																{%- endif -%}
															</div>
                                                            <cart-remove-button
        													id="Remove-{{ item.index | plus: 1 }}"
        													data-index="{{ item.index | plus: 1 }}"
        												>
        													<a
        														class="button button--simple focus-inset"
        														href="{{ item.url_to_remove }}"
        														aria-label="{{ 'sections.cart.remove_title' | t: title: item.title }}"
        													>
        														<span>{{ 'sections.cart.remove' | t }}</span>
        													</a>
        												</cart-remove-button>
														</div>
													</div>
												</div>
	
												<div class="cart-item__bottom cart-item__row ph-cart-item__bottom">
													<div class="cart-item__col cart-item__quantity">
														<label class="visually-hidden" for="Quantity-{{ item.index | plus: 1 }}">
															{{ 'products.product.quantity.label' | t }}
														</label>
														<quantity-input class="quantity">
															<button class="quantity__button no-js-hidden focus-inset" name="minus" type="button">
																<span class="visually-hidden">
																	{{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}
																</span>
																{% render 'icon-minus' %}
															</button>
															<input
																class="quantity__input focus-inset"
																type="number"
																name="updates[]"
																value="{{ item.quantity }}"
																min="0"
																aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
