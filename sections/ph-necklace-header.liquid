<style>
  .ph-modular-guide-container {
    max-width: 80vw;
    margin: 0 auto;
    padding: 75px 36px 90px 36px;
  }
  
  .ph-modular-guide-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  
  .ph-modular-guide-heading {
    font-size: 1.25vw;
    line-height: 1.2;
    margin: 0;
    text-transform: uppercase;
    font-weight: 500;
    width: 100%;
    opacity: 0;
  }
  
  .ph-modular-guide-subheading {
    font-size: 10px;
    line-height: 2.3;
    margin: auto;
    margin-top: 27px;
    text-transform: uppercase;
    max-width: 900px;
    opacity: 0; /* Start invisible for animation */
  }

  .ph-modular-guide-subheading p{
    margin: 0;
  }

  .ph-modular-guide-subheading p strong{
    font-family: 'PhoriaBold';
  }
  
  
  .ph-modular-guide-image-wrapper {
    width: 100%;
    max-width: 80vw;
    padding: 18px 36px;
    margin: auto;
    opacity: 0; /* Start invisible for animation */
  }
  
  .ph-modular-guide-image {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .ph-modular-guide-steps {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    font-size: 10px;
    line-height: 2.3;
    max-width: 900px;
    width: 100%;
  }
  
  .ph-modular-guide-step {
    font-size: 10px;
    text-transform: uppercase;
    width: 100%;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    opacity: 0; /* Start invisible for animation */
  }
  
  .ph-step-number {
    margin-right: 8px;
  }
  
  .ph-step-text {
    text-align: center;
  }

  @media screen and (max-width: 1020px) {
  .ph-modular-guide-container {
    max-width: 100%;
    margin: 0 auto;
    padding: 75px 18px 90px;
  }

  .ph-modular-guide-image-wrapper {
    width: 100%;
    max-width: 100%;
    padding: 18px 0;
    margin: auto;
    opacity: 0; /* Start invisible for animation */
  }

  .ph-modular-guide-heading {
    font-size: 18px;
  }
    
}
  
  @media screen and (max-width: 768px) {
   .ph-modular-guide-container {
     max-width: 100%;
     margin: 0 auto;
     padding: 60px 18px 90px;
   }
  }
</style>

<div class="ph-modular-guide-container">
  <div class="ph-modular-guide-inner">
    {% if section.settings.heading != blank %}
      <h2 class="ph-modular-guide-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    {% if section.settings.subheading != blank %}
      <div class="ph-modular-guide-subheading">{{ section.settings.subheading }}</div>
    {% endif %}
    
    {% if section.settings.guide_image != blank %}
      <div class="ph-modular-guide-image-wrapper">
        <img 
          src="{{ section.settings.guide_image | img_url: 'master' }}" 
          alt="Modular necklace guide" 
          class="ph-modular-guide-image"
          loading="lazy"
          width="{{ section.settings.guide_image.width }}"
          height="{{ section.settings.guide_image.height }}"
        >
      </div>
    {% endif %}
    
    <div class="ph-modular-guide-steps">
      {% if section.settings.step1 != blank %}
        <div class="ph-modular-guide-step">
          <span class="ph-step-text">1) {{ section.settings.step1 }}</span>
        </div>
      {% endif %}
      
      {% if section.settings.step2 != blank %}
        <div class="ph-modular-guide-step">
          <span class="ph-step-text">2) {{ section.settings.step2 }}</span>
        </div>
      {% endif %}
      
      {% if section.settings.step3 != blank %}
        <div class="ph-modular-guide-step">
          <span class="ph-step-text">3) {{ section.settings.step3 }}</span>
        </div>
      {% endif %}
      
      {% if section.settings.step4 != blank %}
        <div class="ph-modular-guide-step">
          <span class="ph-step-text">4) {{ section.settings.step4 }}</span>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof Motion !== 'undefined' && {{ section.settings.enable_animations | default: true }}) {
      const { animate, inView, transform } = Motion;
      
      // Animate heading
      const heading = document.querySelector('.ph-modular-guide-heading');
      if (heading) {
        inView(heading, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate subheading
      const subheading = document.querySelector('.ph-modular-guide-subheading');
      if (subheading) {
        inView(subheading, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.15, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate image
      const imageWrapper = document.querySelector('.ph-modular-guide-image-wrapper');
      if (imageWrapper) {
        inView(imageWrapper, (elem) => {
          animate(elem, 
            { opacity: [0, 1], y: [30, 0] }, 
            { duration: 0.6, delay: 0.3, easing: "ease-out" }
          );
        }, { once: true });
      }
      
      // Animate steps
      const steps = document.querySelectorAll('.ph-modular-guide-step');
      steps.forEach((elem, index) => {
        inView(elem, (el) => {
          animate(el, 
            { opacity: [0, 1], y: [20, 0] }, 
            { duration: 0.6, delay: 0.45 + (index * 0.1), easing: "ease-out" }
          );
        }, { once: true });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Ph Necklace Head",
  "tag": "section",
  "class": "ph-modular-guide-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "HOW TO MAKE A NECKLACE USING OUR MODULAR CHAIN BRACELETS"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>ALL PHORIA BRACELETS ARE <strong>MODULAR</strong> - OUR CARABINER CLASPS CAN BE CONNECTED WITH ANY OTHER PHORIA BRACELET TO CREATE ANY STYLE OF <strong>NECKLACE</strong> YOU CHOOSE.</p>"
    },
    {
      "type": "image_picker",
      "id": "guide_image",
      "label": "Guide Image"
    },
    {
      "type": "text",
      "id": "step1",
      "label": "Step 1",
      "default": "SIMPLY OPEN OUR CARABINER CLASP BY PULLING THE CLASP APART ON ONE OF YOUR BRACELETS"
    },
    {
      "type": "text",
      "id": "step2",
      "label": "Step 2",
      "default": "USE THIS TO LINK THROUGH THE CHAIN LINK ON YOUR SECOND NECKLACE"
    },
    {
      "type": "text",
      "id": "step3",
      "label": "Step 3",
      "default": "SHUT THE CLASP SHUT"
    },
    {
      "type": "text",
      "id": "step4",
      "label": "Step 4",
      "default": "DO THE SAME FOR THE SECOND BRACELET TO LINK TO YOUR OTHER ONE"
    },
    {
      "type": "checkbox",
      "id": "enable_animations",
      "label": "Enable animations",
      "default": true,
      "info": "Enable fade-in animations when content comes into view"
    }
  ],
  "presets": [
    {
      "name": "Ph Necklace Head"
    }
  ]
}
{% endschema %}