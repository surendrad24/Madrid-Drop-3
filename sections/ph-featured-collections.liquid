<style>
  .collection-promo {
  position: absolute;
  bottom: 72px;
  right: 36px;
  white-space: pre-line;        /* honors the \n from textarea */
  letter-spacing: 0.1em;
  font-family: 'PhoriaBold';
  font-size: 48px;
  font-weight: 700;
  line-height: 1;
  text-transform: uppercase;
  pointer-events: none;
  margin: 0 0 clamp(1rem, 2vw, 2rem); /* spacing: fluid gap below, centered */
  text-align: end;
}
@media (max-width: 768px) {
  .collection-promo {
    bottom: 42px;
    right: 16px;
    position: absolute;
    letter-spacing: 0.1em;
    font-family: 'PhoriaBold';
    font-size: 36px;
    margin-bottom: clamp(0.75rem, 4vw, 1.5rem);
    text-align: end;
  }
}
/* Tile 1 promo color */
.promo-1 {
  color: {{ section.settings.promo_text_1_color }};
}

/* Tile 2 promo color */
.promo-2 {
  color: {{ section.settings.promo_text_2_color }};
}

  .two-column-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
  }  
  .collection-item {
    position: relative;
    overflow: hidden;
  }
  
  .collection-item img {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .collection-title {
    position: absolute;
    bottom: 36px;
    right: 36px;
    color: #fff;
    font-family: 'PhoriaBold';
    font-size: 16px;
  }
  .collection-1{
    color: {{section.settings.collection1_title_color}};
  }
  .collection-2{ 
    color: {{section.settings.collection2_title_color}};
  }

   @media (max-width: 959px) {
    .two-column-grid {
      grid-template-columns: 1fr;
    }
    .collection-title {
      position: absolute;
      bottom: 18px;
      right: 18px;
    }
     {% if section.settings.reverse_columns %}
      .collection-item:first-child{
        order: 2;
      }
     {% endif %}
  }
  
</style>
<div class="two-column-grid">
  <a class="collection-item" 
    {% if section.settings.link_1 != blank %}
       href="{{ section.settings.link_1 }}"
    {% endif %}
    {% if section.settings.link_1 == blank %}
       aria-disabled="true"
    {% endif %}>
    {% if section.settings.image_1 %}
      <img src="{{ section.settings.image_1 | image_url }}" alt="{{ section.settings.title_1 }}" height="" width="">
    {% endif %}
    {% if section.settings.promo_text_1 %}
  <div class="collection-promo promo-1">{{ section.settings.promo_text_1}}</div>
{% endif %}
    <div class="collection-title collection-1">
        <span>{{ section.settings.title_1 }}</span>
    </div>
  </a>
  
  <a class="collection-item" 
    {% if section.settings.link_2 != blank %}
        href="{{ section.settings.link_2 }}"
    {% endif %}
    {% if section.settings.link_2 == blank %}
        aria-disabled="true"
    {% endif %}>
    {% if section.settings.image_2 %}
      <img src="{{ section.settings.image_2 | image_url }}" alt="{{ section.settings.title_2 }}" height="" width="">
    {% endif %}
    {% if section.settings.promo_text_2 %}
  <div class="collection-promo promo-2">{{ section.settings.promo_text_2}}</div>
{% endif %}

    <div class="collection-title collection-2">
        <span>{{ section.settings.title_2 }}</span>
    </div>
  </a>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Check if Motion library is available
    if (typeof Motion !== 'undefined') {
      const { animate, inView, transform } = Motion;
      console.log("Motion", inView)
      
      // Animate each collection item individually when it comes into view
      const collectionItems = document.querySelectorAll('.collection-item');
      
      collectionItems.forEach((elem, index) => {
        inView(elem, (el) => {
          // Apply staggered animation delay
          const delay = index * 0.2; // Stagger delay between items
          
          animate(el, 
            { opacity: [0, 1], y: ["100px", 0] }, 
            { duration: 0.7, delay: delay, easing: "ease-out" }
          );
        }, { once: true, amount: 0.1 });
      });
    }
  });
</script>

